<Routine Name="Alarms_main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[JSR(Alarms,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Check all alarms if alarm status is changed]]>
</Comment>
<Text>
<![CDATA[FOR(Alarm_Act,ALARM_IX,1,95,1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[JSR(Steam_T_P,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Alarm text language selection]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Language.1) EQ(HMI.Language,1) COP(AlarmTextEN,AlarmText,1) ,XIC(Option.Language.4) EQ(HMI.Language,4) COP(AlarmTextSP,AlarmText,1) ,XIC(Option.Language.5) EQ(HMI.Language,5) COP(AlarmTextFR,AlarmText,1) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Alarm_Act" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set alarm DINT- and Bit addresses and alarm number]]>
</Comment>
<Text>
<![CDATA[[LIMIT(1,ALARM_IX,31) MOVE(0,DINT_IX) MOVE(ALARM_IX,BIT_IX) ,LIMIT(32,ALARM_IX,63) MOVE(1,DINT_IX) SUB(ALARM_IX,32,BIT_IX) ,LIMIT(64,ALARM_IX,95) MOVE(2,DINT_IX) SUB(ALARM_IX,64,BIT_IX) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[ACTIVATE ALARM]]>
</Comment>
<Text>
<![CDATA[XIC(Alarm_ACT[DINT_IX].[BIT_IX])XIO(Alarm_ON[DINT_IX].[BIT_IX])[OTL(Alarm_ON[DINT_IX].[BIT_IX]) OTU(Alarm_ACK[DINT_IX].[BIT_IX]) ,MOVE(1,HMI.Alarm_banner) ,CONCAT(time,AlarmText.Alarm_ON,Alarm_text) EQ(Option.Printer_type,0) CONCAT(Alarm_text,Line_feed,Alarm_text) ,CONCAT(Alarm_text,AlarmText.Alarms[ALARM_IX],Alarm_text) COP(Alarm_text,Alarm_print[A_pointer],1) ,LT(A_pointer,20) ADD(A_pointer,1,A_pointer) ,RES(DEACT_DELAY) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[1 Sec Delay for HMI for Alarm detection]]>
</Comment>
<Text>
<![CDATA[TON(DEACT_DELAY,?,?);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Deactivate alarm and create alrm OFF print line]]>
</Comment>
<Text>
<![CDATA[XIO(Alarm_ACT[DINT_IX].[BIT_IX])XIC(Alarm_ACT_AND_ACKED[DINT_IX].[BIT_IX])XIC(Alarm_ON[DINT_IX].[BIT_IX])XIC(DEACT_DELAY.DN)[OTU(Alarm_ACT_AND_ACKED[DINT_IX].[BIT_IX]) OTU(Alarm_ON[DINT_IX].[BIT_IX]) ,CONCAT(time,AlarmText.Alarm_OFF,Alarm_text) EQ(Option.Printer_type,0) CONCAT(Alarm_text,Line_feed,Alarm_text) ,CONCAT(Alarm_text,AlarmText.Alarms[ALARM_IX],Alarm_text) COP(Alarm_text,Alarm_print[A_pointer],1) ,LT(A_pointer,20) ADD(A_pointer,1,A_pointer) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Alarm acknowledged, make alarm string and add to stack]]>
</Comment>
<Text>
<![CDATA[XIC(Alarm_ON[DINT_IX].[BIT_IX])XIC(Alarm_ACK[DINT_IX].[BIT_IX])XIO(Alarm_ACT_AND_ACKED[DINT_IX].[BIT_IX])[OTL(Alarm_ACT_AND_ACKED[DINT_IX].[BIT_IX]) ,MOVE(2,HMI.Alarm_banner) ,CONCAT(time,AlarmText.Alarm_ACK,Alarm_text) CONCAT(Alarm_text,User_name,Alarm_text) ,EQ(Option.Printer_type,0) CONCAT(Alarm_text,Line_feed,Alarm_text) ,CONCAT(Alarm_text,AlarmText.Alarms[ALARM_IX],Alarm_text) COP(Alarm_text,Alarm_print[A_pointer],1) ,LT(A_pointer,20) ADD(A_pointer,1,A_pointer) ,NE(Process.Power_brake_status,2) CLR(Process.Power_brake_status) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Steam_T_P" Type="RLL">
<Description>
<![CDATA[Calculated saturated steam pressure]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Saturated steam calculation for alarms and valve control
Calculate the satured steam pressure using the equation: P=e(((T-99,64)/(T+230))*11,78)
This rung calculates Sat_P = (((T-99,64)/(T+230))*11,78)]]>
</Comment>
<Text>
<![CDATA[[XIO(Step_bit[0].12) XIO(Step_bit[0].13) MOVE(TE517_Chamber.Temperature,Sat_P[0]) ,EQ(Process.Step,12) MOVE(Run.Forced_air_rem_temp,Sat_P[0]) ,EQ(Process.Step,13) MOVE(Run.Exposure_temperature,Sat_P[0]) ,CPT(Sat_P[1],(Sat_P[0]-99.64)/(Sat_P[0]+230)*11.78) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[ Saturated steam pressure value
This rung calculates P = e exp(sat_P)
]]>
</Comment>
<Text>
<![CDATA[[LN(2,LN2) ,CPT(e_value,2**(1.0/LN2)) ,CPT(Process.Saturated_P,e_value**Sat_P[1]*1000) ,ADD(Process.Saturated_P,Common_set.Air_in_chamber_limit,Air_in_ch_limit) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
