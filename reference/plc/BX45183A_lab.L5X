<Routine Name="Pure_steam_sample_control" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Latch / Unlatch button S9]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].7)GE(Process.Step,2)ONS(ONS_S9)[XIO(DIG_OUT[0].6) OTL(S9_latched) ,XIC(DIG_OUT[0].6) OTU(S9_latched) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Unlatch S9]]>
</Comment>
<Text>
<![CDATA[[LE(Process.Step,1) ,XIC(Alarm_ACT[0].16) ]OTU(S9_latched);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Steam sample sanitation timer to delay PV192 opening]]>
</Comment>
<Text>
<![CDATA[XIC(S9_latched)[MUL(10,1000,Sample_sanitation_timer.PRE) ,TON(Sample_sanitation_timer,?,?) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[PV192 must be open for 60sec before sampling can be started]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_OUT[1].19)TON(PV192_open_timer,?,?);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Latch / Unlatch button S11]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].8)XIC(S9_latched)XIC(PV192_open_timer.DN)ONS(ONS_S11)[XIO(S11_help) OTL(S11_latched) ,XIC(S11_help) OTU(S11_latched) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Help bit to latch S11]]>
</Comment>
<Text>
<![CDATA[XIC(S11_latched)OTE(S11_help);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Unlatch S11]]>
</Comment>
<Text>
<![CDATA[[XIO(S9_latched) ,XIC(Alarm_ACT[0].21) ]OTU(S11_latched);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Run_Control" Type="RLL">
<Description>
<![CDATA[Process step
status control]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Process not running
Reset cycle status variables]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_bit[0].2) ,XIC(Step_bit[0].5) ][OTU(Process.Running) OTU(Process.Cycle_aborted) ,OTU(Process.Precond_abort) ,OTU(Process.B_cycle_abort) ,OTU(Process.VHP_Abort) ,OTU(Process.VHP_Gen_Abort) ,CLR(Process.Prec_status) ,CLR(Process.Postc_status) ,OTU(Process.Abort_before_Equalization) ,OTU(Process.Abort_Equal_unload_confirmed) ,OTU(Process.Power_brake_1) ,OTU(Process.Power_brake_3) ,NE(Probe_failure_ack,0) MOVE(0,Probe_failure_ack) ,OTU(Process.Cooling_pulses_done) ,OTU(HMI.Abort_screen_43) ,CLR(Pulse_counter_Controller_Tag) ,RES(DEC_Condensate_OK_delay) ,RES(DEC_Condensate_end_heat_time) ,OTU(Process.DEC_condensate_high) ,OTU(VIRASURE_Temperature_Reached) ,OTU(Process.DEC_step68_completed) ,OTU(Vac_pump_tank_cooling) ,OTU(Process.FIT_Sanitization_temp_reached) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Add cycle alarmed text to summary report]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)[NE(Alarm_ACT[0],0) ,NE(Alarm_ACT[1],0) ,NE(Alarm_ACT[2],0) ]COP(Abort_txt,Summary[0].Result,1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Activate process step timer]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_bit[0].9) ,XIC(Step_bit[0].11) ,XIC(Step_bit[0].12) ,EQ(Run.Exposure_type,1) [XIC(Step_bit[0].15) GE(TE517_Chamber.Temperature,Step_setpoint_help) ,XIC(Step_bit[2].1) [XIO(Option.DecV_process) GE(TE517_2_DEC.Temperature,Step_setpoint_help) ,XIC(Option.DecV_process) GE(TE517_Chamber.Temperature,Step_setpoint_help) ] ,XIC(Step_bit[2].18) GE(SAMX_Control_temperature,Step_setpoint_help) ] GE(Load_temp_min,Step_setpoint_help) ,EQ(Run.Exposure_type,4) XIC(Step_bit[0].15) GE(TE517_1_Filter.Temperature,Step_setpoint_help) ,XIC(Step_bit[0].17) ,XIC(Step_bit[0].19) ,LIMIT(22,Process.Step,25) ,XIC(Step_bit[0].29) ,LIMIT(33,Process.Step,35) ,LIMIT(41,Process.Step,42) ,XIC(Step_bit[1].4) ,XIC(Step_bit[1].6) ,XIC(Step_bit[1].12) ,XIC(Step_bit[1].18) ,LIMIT(54,Process.Step,55) ,XIC(Step_bit[1].24) XIC(DIG_IN[1].16) ,XIC(Step_bit[1].25) XIC(DIG_IN[1].18) ,XIC(Step_bit[1].29) ,XIC(Step_bit[1].31) ,XIC(Step_bit[2].4) XIC(Process.DEC_condensate_high) XIC(DEC_Condensate_OK_delay.DN) XIO(Step_timer.DN) ,LIMIT(83,Process.Step,84) ,XIC(Step_bit[2].25) GE(TE517_5_FIT_Sanitization.Temperature,Run.FIT_Sanitization_temp) ,LIMIT(90,Process.Step,91) ,LIMIT(94,Process.Step,98) ]OTE(Process.Step_timer);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Process step timer]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_timer)[XIO(HMI.Wait_pressed) RTO(Step_timer,?,?) ,EQ(Run.Precycle_type,3) EQ(Process.Step,42) OTE(VS_flow_testS42) ,SUB(Step_timer.PRE,Step_timer.ACC,rem_msec) ,XIO(VS_flow_testS42) DIV(rem_msec,60000,Process.Remaining_minutes) ,XIO(VS_flow_testS42) CPT(Process.Remaining_seconds,(rem_msec-(Process.Remaining_minutes*60000))/1000) ,XIC(VS_flow_testS42) DIV(Step_timer.ACC,1000,Process.Remaining_seconds) ,GT(Password_level,1) OTE(HMI.Wait_active) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Reset step timer if step changes]]>
</Comment>
<Text>
<![CDATA[NE(Process.Step_memory,Process.Step)XIO(Step_bit[0].0)XIO(Step_bit[0].1)[CLR(Step_timer.PRE) RES(Step_timer) ,CLR(Process.Remaining_seconds) ,CLR(Process.Remaining_minutes) ,OTU(HMI.Wait_pressed) OTU(Process.Step_ready) ,MOVE(Process.Step,Process.Step_memory) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Total cycle time minutes for print]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)[TON(Cycle_time,?,?) ,DIV(Cycle_time.ACC,60000,Cycle_time_min) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Cycle hour counter]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Running) XIC(Process.S_pulse) ADD(1,Cycles.Seconds,Cycles.Seconds) ,EQ(Cycles.Seconds,60) [ADD(1,Cycles.Minutes,Cycles.Minutes) ,CLR(Cycles.Seconds) ] ,EQ(Cycles.Minutes,60) [ADD(1,Cycles.Hours,Cycles.Hours) ,CLR(Cycles.Minutes) ] ,XIC(HMI.Counter_reset) XIC(Cycles.Counter_Selected) [CLR(Cycles.Seconds) CLR(Cycles.Minutes) CLR(Cycles.Hours) ,CLR(Cycles.Counter) OTU(Cycles.Counter_Selected) ] ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Calculate support pressure low limit]]>
</Comment>
<Text>
<![CDATA[[NE(Run.Precond_1_type,4) NE(Run.Postcond_1_type,6) SUB(Run.Support_press,210,Process.Support_low) ,[EQ(Run.Precond_1_type,4) ,EQ(Run.Postcond_1_type,6) ] SUB(Process.SAMX_pressure_sp,70,Process.Support_low) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Calculate ATM pressure limits]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_bit[0].2) XIO(DIG_IN[1].0) ,XIC(Step_bit[0].5) XIO(DIG_IN[1].16) ,[XIC(Step_bit[0].3) ,XIC(Step_bit[0].6) ,XIC(Step_bit[0].2) ,XIC(Step_bit[0].5) ] LT(Process.ATM_high,1000) XIC(DIG_IN[0].1) XIC(DIG_IN[0].0) ]EQ(Festo_Status[0],16384)LIMIT(600,PT549_Chamber.Pressure_mBar,1200)[MOVE(PT549_Chamber.Pressure_mBar,Process.ATM_pressure) ,SUB(Process.ATM_pressure,40,Process.ATM_low) ,ADD(Process.ATM_pressure,40,Process.ATM_high) ,ADD(Process.ATM_pressure,100,Process.ATM_HI_Preheating) ,ADD(Process.ATM_pressure,100,VHP_P_HI) ,SUB(Process.ATM_pressure,100,VHP_P_LO) ,ADD(Process.ATM_pressure,250,VHP_P_HI_AL) ,SUB(Process.ATM_pressure,250,VHP_P_LO_AL) ,SUB(Process.ATM_pressure,20,ATM_Low_20) ,ADD(Process.ATM_pressure,20,ATM_High_20) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Reset help variable from display]]>
</Comment>
<Text>
<![CDATA[[LT(Process.Step,8) ,XIC(Step_bit[0].12) ,XIC(Step_bit[0].14) ,XIC(Step_bit[2].0) ]CLR(Step_pressure_setpoint);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Temp setpoint for display]]>
</Comment>
<Text>
<![CDATA[[[XIC(Step_bit[0].12) ,XIC(Step_bit[0].20) ,XIC(Step_bit[0].22) ,XIC(Step_bit[0].24) ,XIC(Step_bit[1].12) ,XIC(Step_bit[2].2) ,XIC(Step_bit[2].19) ,XIC(Step_bit[2].20) ] MOVE(Step_temperature_setpoint,HMI.Temperature_setpoint) ,[XIC(Step_bit[0].14) ,XIC(Step_bit[0].15) ,XIC(Step_bit[2].0) ,XIC(Step_bit[2].1) ,XIC(Step_bit[2].17) ,XIC(Step_bit[2].18) ] MOVE(Run.Exposure_temperature,HMI.Temperature_setpoint) ,[XIC(Step_bit[0].21) ,XIC(Step_bit[2].2) [LT(Run.Postcond_1_type,3) ,EQ(Run.Postcond_1_type,5) ] NE(Run.Postcond_2_type,3) ,EQ(Process.Step,67) ,EQ(Process.Step,68) ,LE(Process.Step,11) ,LIMIT(16,Process.Step,19) ] CLR(HMI.Temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Set user confirm active if load temp is lost during cooling]]>
</Comment>
<Text>
<![CDATA[XIC(Alarm_ACT[1].4)[XIC(Step_bit[0].20) ,LIMIT(22,Process.Step,24) ,LIMIT(83,Process.Step,84) ]NE(Probe_failure_ack,2)MOVE(1,Probe_failure_ack);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Force load probes selected if Cooling or Slow Exhaust is configured]]>
</Comment>
<Text>
<![CDATA[[LIMIT(3,Run.Postcond_1_type,4) ,LIMIT(3,Run.Postcond_2_type,4) ,EQ(Run.Exposure_type,2) ,EQ(Run.Postcond_1_type,6) ,XIC(Run.Overshoot_selected) ]XIC(Process.Running)[XIO(Run.Load_2) XIO(Run.Load_3) XIO(Run.Load_4) OTL(Run.Load_1) ,XIC(Option.Load_2) XIO(Run.Load_1) XIO(Run.Load_3) XIO(Run.Load_4) OTL(Run.Load_2) ,XIC(Option.Load_3) XIO(Run.Load_1) XIO(Run.Load_2) XIO(Run.Load_4) OTL(Run.Load_3) ,XIC(Option.Load_4) XIO(Run.Load_1) XIO(Run.Load_2) XIO(Run.Load_3) OTL(Run.Load_4) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Force load probes unselected if option not valid]]>
</Comment>
<Text>
<![CDATA[[XIO(Option.Load_2) OTU(Run.Load_2) ,XIO(Option.Load_3) OTU(Run.Load_3) ,XIO(Option.Load_4) OTU(Run.Load_4) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Process control bit when doors sealed]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].0)XIC(DIG_IN[1].1)XIC(DIG_IN[1].2)[XIC(DIG_IN[1].16) XIC(DIG_IN[1].17) XIC(DIG_IN[1].18) ,XIO(Option.Double_door) ]OTE(Process.Doors_locked);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Timer for releasing sealed door gasket]]>
</Comment>
<Text>
<![CDATA[XIO(Vac_pump_tank_draining_active)[XIC(Process.Pull_gasket) TON(Unseal_backup,?,?) ,XIC(Unseal_backup.DN) OTU(Process.Pull_gasket) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[Select SAMX control temp use secondary if primary out-of-range]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SAMX_process)[XIO(TE517_3_Chamber.out_of_range) MOVE(TE517_3_Chamber.Temperature,SAMX_Control_temperature) ,XIC(TE517_3_Chamber.out_of_range) MOVE(TE517_4_Chamber.Temperature,SAMX_Control_temperature) ,XIC(TE517_3_Chamber.out_of_range) XIC(TE517_4_Chamber.out_of_range) OTE(SAMX_Control_temp_out_of_range) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[VHP Biodec 10.4.41chamber pressure set point high limit]]>
</Comment>
<Text>
<![CDATA[SUB(1100,10.0,VHP_P_ch_hi_lim_10mBar);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[VHP Biodec 10.4.41 aeration air to chamber start limit]]>
</Comment>
<Text>
<![CDATA[XIC(Step_bit[1].6)LT(PT549_Chamber.Pressure_mBar,Process.ATM_pressure)OTL(VHP_YY624_open_areation);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[VHP Biodec 10.4.41chamber aeration air disabled]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_bit[0].21) ,XIC(Step_bit[0].1) ]OTU(VHP_YY624_open_areation);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[Option 10.2.8  Domestic Cooling Water Recycling Package for Vacuum Pump and Effluent Cooling
Calculated vacuum pump water switching temperature]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Vac_Pump_Water_Save)GT(PT549_Chamber.Pressure_mBar,0)CPT(Process.Vac_pump_switch_temp,11.004*LN(PT549_Chamber.Pressure_mBar)-25.376);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[Calculate Average Heat Barrier Temperature]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DecV_process)[XIO(TE527_2_VIRASURE.out_of_range) XIO(TE527_3_VIRASURE.out_of_range) CPT(VIRASURE_Temperature,(TE527_2_VIRASURE.Temperature+TE527_3_VIRASURE.Temperature)/2) ,XIO(TE527_2_VIRASURE.out_of_range) XIC(TE527_3_VIRASURE.out_of_range) MOVE(TE527_2_VIRASURE.Temperature,VIRASURE_Temperature) ,XIO(TE527_3_VIRASURE.out_of_range) XIC(TE527_2_VIRASURE.out_of_range) MOVE(TE527_3_VIRASURE.Temperature,VIRASURE_Temperature) ,XIC(TE527_2_VIRASURE.out_of_range) XIC(TE527_3_VIRASURE.out_of_range) MOVE(-9999,VIRASURE_Temperature) OTE(VIRASURE_Control_temp_out_of_range) ,MOVE(600,VIRASURE_Min_Temp) ,XIO(TE527_2_VIRASURE.out_of_range) LE(TE527_2_VIRASURE.Temperature,VIRASURE_Min_Temp) MOVE(TE527_2_VIRASURE.Temperature,VIRASURE_Min_Temp) ,XIO(TE527_3_VIRASURE.out_of_range) LE(TE527_3_VIRASURE.Temperature,VIRASURE_Min_Temp) MOVE(TE527_3_VIRASURE.Temperature,VIRASURE_Min_Temp) ,LIMIT(69,Process.Step,59) XIO(Step_bit[0].0) XIO(Step_bit[0].1) MOVE(VIRASURE_Temperature,VIRASURE_Control_Temperature) ];]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[Decontaminaination process abort condensate level monitoring during Step S67_DEC_Equalization and Step S68_DEC_Abort_Condens_removal
Condensate level low (OK) two minute timer]]>
</Comment>
<Text>
<![CDATA[LIMIT(67,Process.Step,68)[XIC(DIG_IN[1].4) ,XIC(DEC_Condensate_OK_delay.DN) ]TON(DEC_Condensate_OK_delay,?,?);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[Vacuum pump circulation tank draining active control

]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Tank_LS896) ,XIC(Option.Vac_Pump_Water_Save) ][XIC(Step_bit[0].2) ,XIC(Step_bit[0].5) ]EQ(Process.Service_cycle,0)GE(Vac_pump_tank_drain_cycle_counter,Common_set.Cycle_counter_for_tank_draining)XIO(Data_save_controller)XIO(Unseal_backup.TT)[OTL(Vac_pump_tank_draining_active) ,CLR(Vac_pump_tank_drain_cycle_counter) ];]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[Reset vacuum pump circulation tank draining timer and control bit when draining time elapsed and tank is filled again

]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Tank_LS896) ,XIC(Option.Vac_Pump_Water_Save) ][XIC(Step_bit[0].2) ,XIC(Step_bit[0].5) ]XIC(Vac_pump_tank_drain_time.DN)XIC(Vac_pump_tank_draining_active)XIC(DIG_IN[1].13)[OTU(Vac_pump_tank_draining_active) ,RES(Vac_pump_tank_drain_time) ];]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[Vacuum pump circulation tank draining, cycles left before next drain.
Information for HMI

]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Tank_LS896) ,XIC(Option.Vac_Pump_Water_Save) ]SUB(Common_set.Cycle_counter_for_tank_draining,Vac_pump_tank_drain_cycle_counter,Vac_pump_tank_drain_cycles_left_HMI);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[Option 10.2.8  Domestic Cooling Water Recycling Package for Vacuum Pump and Effluent Cooling
Force fresh water to tank to prevent boiling after heating or exposure]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Vac_Pump_Water_Save)[LIMIT(13,Process.Step,15) ,LIMIT(64,Process.Step,65) ]GE(PT549_Chamber.Pressure_mBar,Process.ATM_HI_Preheating)OTL(Vac_pump_tank_cooling);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[Option 10.2.8  Domestic Cooling Water Recycling Package for Vacuum Pump and Effluent Cooling
Force fresh water to tank to prevent boiling after heating or exposure]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Vac_Pump_Water_Save)XIC(Vac_pump_tank_cooling)[LIMIT(16,Process.Step,17) ,LIMIT(67,Process.Step,68) ,EQ(Process.Step,21) ]LE(PT549_Chamber.Pressure_mBar,Process.ATM_high)OTU(Vac_pump_tank_cooling);]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Comment>
<![CDATA[Set User Name to NONE if password level is 0]]>
</Comment>
<Text>
<![CDATA[EQ(Password_level,0)COP(User_name_reset,User_name,1)COP(User_name_reset,User_name_full,1);]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Comment>
<![CDATA[Set HMI screen force number to 0 if screen force command is not enabled]]>
</Comment>
<Text>
<![CDATA[[XIO(HMI.Force_On_NS) CLR(HMI.Force_NS) ,OTU(HMI.Force_On_NS) ,EQ(HMI.Force_SVC,HMI.Active_NS) CLR(HMI.Force_SVC) ];]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Comment>
<![CDATA[FIT valve pulsing system 15 second interval: 
used with controls
10s ON - 5s OFF
5s ON - 10s OFF]]>
</Comment>
<Text>
<![CDATA[[LIMIT(89,Process.Step,90) ,XIC(Step_bit[3].2) ]TON(FIT_valve_pulse_interval,?,?);]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Comment>
<![CDATA[FIT valve pulsing system: 10s ON - 5s OFF]]>
</Comment>
<Text>
<![CDATA[LIMIT(89,Process.Step,90)LIMIT(1,FIT_valve_pulse_interval.ACC,10000)OTE(Process.FIT_valve_10s_on_pulse);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Comment>
<![CDATA[FIT valve pulsing system: 5s ON - 10s OFF]]>
</Comment>
<Text>
<![CDATA[XIC(Step_bit[3].2)LIMIT(1,FIT_valve_pulse_interval.ACC,5000)OTE(Process.FIT_valve_5s_on_pulse);]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Comment>
<![CDATA[Reset FIT valve pulsing system 15 second interval]]>
</Comment>
<Text>
<![CDATA[[XIC(FIT_valve_pulse_interval.DN) ,XIO(Step_bit[2].25) XIO(Step_bit[2].26) XIO(Step_bit[3].2) ]RES(FIT_valve_pulse_interval);]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Comment>
<![CDATA[FIT WATER TANK MANUAL DRAIN FROM PC PANEL BUTTON STARTS HERE
FIT water tank manual drain system
Reset FIT water tank manual drain system when tank is empty and delay elapsed or manual drain is not allowed]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.FIT_tank_drain) XIO(Step_bit[0].2) XIO(Step_bit[0].5) ,XIC(Process.FIT_manual_tank_drain) XIC(FIT_water_tank_drain_low_delay.DN) ][OTU(Process.FIT_tank_drain) ,OTU(Process.FIT_manual_tank_drain) ];]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Comment>
<![CDATA[FIT water tank manual drain system
Start FIT water tank manual drain system ]]>
</Comment>
<Text>
<![CDATA[XIC(Process.FIT_tank_drain)[XIC(Step_bit[0].2) ,XIC(Step_bit[0].5) ]OTL(Process.FIT_manual_tank_drain);]]>
</Text>
</Rung>
<Rung Number="36" Type="N">
<Comment>
<![CDATA[FIT water tank manual drain system
Delay starts when FIT water tank low level has been reached ]]>
</Comment>
<Text>
<![CDATA[XIC(Process.FIT_manual_tank_drain)XIC(DIG_IN[1].23)TON(FIT_water_tank_drain_low_delay,?,?);]]>
</Text>
</Rung>
<Rung Number="37" Type="N">
<Comment>
<![CDATA[Service HMI
-unlatch control if HMI not powered on AND service hmi not enabled from main display
-latch control if service hmi enabled from main display
-latch service hmi enabled button in main display, if service hmi powered on and has control]]>
</Comment>
<Text>
<![CDATA[[XIO(HMI.ServiceHMI) XIO(DIG_IN[0].13) [OTU(ServiceHMI_control) ,ONS(ServiceHMI_OutputForce_release) OTU(HMI.DO_force) ] ,XIC(HMI.ServiceHMI) XIC(DIG_IN[0].13) OTL(ServiceHMI_control) ,XIC(ServiceHMI_control) XIC(DIG_IN[0].13) OTL(HMI.ServiceHMI) ];]]>
</Text>
</Rung>
<Rung Number="38" Type="N">
<Comment>
<![CDATA[Save last successful file transfer date/time and destination path]]>
</Comment>
<Text>
<![CDATA[[EQ(HMI.Transfer_status,1) XIO(Transfer_time_saved) [COP(Date_time[0],HMI.Last_transfer_time[0],7) ,COP(HMI.Transfer_path,HMI.Last_transfer_path,1) ,OTL(Transfer_time_saved) ] ,GT(HMI.Transfer_status,1) OTU(Transfer_time_saved) ];]]>
</Text>
</Rung>
<Rung Number="39" Type="N">
<Comment>
<![CDATA[Start file transfer]]>
</Comment>
<Text>
<![CDATA[[XIC(HMI.Transfer_enabled) NE(HMI.Transfer_status,3) EQ(Date_time[3],HMI.Transfer_hour) EQ(Date_time[4],HMI.Transfer_minute) EQ(Date_time[5],0) OTL(Transfer_files_help) ,XIC(Transfer_files_help) XIO(Process.Running) [OTL(HMI.Trigger_transfer) ,OTU(Transfer_files_help) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S0_Emergency_stop" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S0 Emergency stop
Force step number and E-stop screen]]>
</Comment>
<Text>
<![CDATA[XIC(Alarm_ACT[1].3)[MOVE(0,Process.Step) ,XIO(DIG_IN[0].2) [MOVE(11,HMI.Force_NS) ,MOVE(11,HMI.Force_SVC) ,OTL(HMI.Force_On_NS) ] ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[E-stop release when cycle is not running]]>
</Comment>
<Text>
<![CDATA[XIO(Process.Running)XIC(DIG_IN[0].2)EQ(Process.Step,0)[MOVE(Process.Step_memory,Process.Step) ,MOVE(40,HMI.Force_SVC) ,[XIC(DIG_IN[1].16) [LIMIT(5,Process.Step,6) ,EQ(Process.Step,26) ] ,XIC(DIG_IN[1].0) [EQ(Process.Step,2) NE(Process.Service_cycle,2) ,EQ(Process.Step,3) ,EQ(Process.Step,30) ] ] OTL(Process.Pull_gasket) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[E-stop release when cycle is running and user is logged in]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)XIC(DIG_IN[0].2)EQ(Process.Step,0)[OTL(Process.Running_and_estop_released) ,[MOVE(10,HMI.Force_NS) ,MOVE(40,HMI.Force_SVC) ,OTL(HMI.Force_On_NS) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S10_Pressure_level" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S10 Pressure level
Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,1)[EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ,EQ(Pulse_counter,1) MOVE(Run.Prec_1_1st_pressure_level,Step_pressure_setpoint) ,EQ(Pulse_counter,2) MOVE(Run.Prec_1_2nd_pressure_level,Step_pressure_setpoint) ,GE(Pulse_counter,3) MOVE(Run.Prec_1_3rd_pressure_level,Step_pressure_setpoint) ,MOVE(Pulse_counter,Pulse_counter_Controller_Tag) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set precondition 2 pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,2)[EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ,EQ(Pulse_counter,1) MOVE(Run.Prec_2_1st_pressure_level,Step_pressure_setpoint) ,EQ(Pulse_counter,2) MOVE(Run.Prec_2_2nd_pressure_level,Step_pressure_setpoint) ,GE(Pulse_counter,3) MOVE(Run.Prec_2_3rd_pressure_level,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the next sep]]>
</Comment>
<Text>
<![CDATA[[GE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(11,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S11_Pressure_hold" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S11 Pressure hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,1)[EQ(Pulse_counter,1) MUL(Run.Prec_1_1st_pressure_hold_time,1000,Step_timer.PRE) ,EQ(Pulse_counter,2) MUL(Run.Prec_1_2nd_pressure_hold_time,1000,Step_timer.PRE) ,GE(Pulse_counter,3) MUL(Run.Prec_1_3rd_pressure_hold_time,1000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,2)[EQ(Pulse_counter,1) MUL(Run.Prec_2_1st_pressure_hold_time,1000,Step_timer.PRE) ,EQ(Pulse_counter,2) MUL(Run.Prec_2_2nd_pressure_hold_time,1000,Step_timer.PRE) ,GE(Pulse_counter,3) MUL(Run.Prec_2_3rd_pressure_hold_time,1000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the vacuum pulse step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][MOVE(8,Process.Step) ,[EQ(Process.Prec_status,1) XIO(Run.Prec_1_First_pulse_type) ,EQ(Process.Prec_status,2) XIO(Run.Prec_2_First_pulse_type) ] ADD(Pulse_counter,1,Pulse_counter) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S12_Forced_air_rem" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S12 Forced air removal
Set step values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.Forced_air_rem_time,60000,Step_timer.PRE) ,MOVE(Run.Forced_air_rem_temp,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Process.Prec_status,1) EQ(Run.Precond_2_type,0) ,EQ(Process.Prec_status,2) ]MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the precond 2 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Process.Prec_status,1)EQ(Run.Precond_2_type,2)[XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,MOVE(2,Process.Prec_status) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S13_Heating_up_1" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S13 Heating up 1 (with rates)
if rates are not selected move to the next step]]>
</Comment>
<Text>
<![CDATA[[CLR(Process.Prec_status) CLR(Pulse_counter) ,[XIO(Run.Rates_selected) ,EQ(Run.Exposure_type,4) ] MOVE(14,Process.Step) RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[MOVE(Run.Heating_up_trans_point,Step_pressure_setpoint);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the next sep]]>
</Comment>
<Text>
<![CDATA[[GE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,GE(PT549_Chamber.Pressure_mBar,Process.Saturated_P) ,XIC(Process.Step_pressed) ]MOVE(14,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S14_Heating_up_2" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S14 Heating up
If exposure type is None and postcondition is none move to the Equalization]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,0)EQ(Run.Postcond_1_type,0)EQ(Run.Postcond_2_type,0)MOVE(21,Process.Step);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[If exposure type is None and postcondition is VD/PD or HPPD move to the Vacuum level step]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,0)[[LIMIT(1,Run.Postcond_1_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) [LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(2,Process.Postc_status) ]MOVE(16,Process.Step);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[If exposure type is None and postcondition is Cooling or Slow exhaust move to the next step]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,0)[[EQ(Run.Postcond_1_type,3) MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,3) MOVE(2,Process.Postc_status) ] MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(1,Process.Postc_status) [NE(Run.Precond_1_type,3) MOVE(20,Process.Step) ,EQ(Run.Precond_1_type,3) MOVE(64,Process.Step) ] ,RET() ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Set temperature transition point from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[SUB(Run.Exposure_temperature,Run.Exposure_temp_dev_low,Step_setpoint_help) ,ADD(Step_setpoint_help,0.2,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the next step if time type]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,1)[GE(Load_temp_min,Step_temperature_setpoint) GE(TE517_Chamber.Temperature,Step_temperature_setpoint) ,XIC(Process.Step_pressed) ]MOVE(15,Process.Step);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Program transition to the next step if Fo type]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,2)[GE(Load_temp_min,100) GE(TE517_Chamber.Temperature,100) ,XIC(Process.Step_pressed) ]MOVE(15,Process.Step);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Program transition to the next step if Filter type sterilization]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,4)[GE(TE517_1_Filter.Temperature,Step_temperature_setpoint) ,XIC(Process.Step_pressed) ]MOVE(15,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S15_Exposure" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S15 Exposure
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Exposure_type,1) ,EQ(Run.Exposure_type,4) ]MUL(Run.Exposure_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Exposure_type,1) XIC(Step_timer.DN) ,EQ(Run.Exposure_type,2) GT(FO_value[4],FO_value[3]) ,EQ(Run.Exposure_type,4) XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Transition to the Postcond 1 step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)NE(Run.Postcond_1_type,0)[[LIMIT(1,Run.Postcond_1_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(16,Process.Step) ,EQ(Run.Postcond_1_type,3) MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(20,Process.Step) ,EQ(Run.Postcond_1_type,6) MOVE(83,Process.Step) ,MOVE(1,Process.Postc_status) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Transition to the Postcond 2 step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Run.Postcond_1_type,0)NE(Run.Postcond_2_type,0)[[LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] MOVE(16,Process.Step) ,EQ(Run.Postcond_2_type,3) MOVE(22,Process.Step) ,MOVE(2,Process.Postc_status) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Transition to the Equalization]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Run.Postcond_1_type,0)EQ(Run.Postcond_2_type,0)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S16_Vacuum_level" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S16 Vacuum level
Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Postc_status,1)[MOVE(Run.Postc_1_Vacuum_level,Step_pressure_setpoint) ,NE(Run.Postcond_1_type,1) EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set pressure level from cycle parameters when postcond 2]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Postc_status,2)[MOVE(Run.Postc_2_Vacuum_level,Step_pressure_setpoint) ,NE(Run.Postcond_2_type,1) EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Set pressure level from common settings when cycle is aborted]]>
</Comment>
<Text>
<![CDATA[XIC(Process.B_cycle_abort)MOVE(Common_set.Equaliation_vacuum_level,Step_pressure_setpoint);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the next sep]]>
</Comment>
<Text>
<![CDATA[[LE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(17,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S17_Vacuum_hold" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S17 Vacuum hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Postc_status,1)MUL(Run.Postc_1_Vacuum_hold_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set step timer preset values from cycle parameters when postcond 2]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Postc_status,2)MUL(Run.Postc_2_Vacuum_hold_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Set step timer preset values from cycle parameters cycle aborted]]>
</Comment>
<Text>
<![CDATA[XIC(Process.B_cycle_abort)MUL(Common_set.Equalization_vacuum_delay,1000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the pressure pulse step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Process.Postc_status,1) NE(Run.Postcond_1_type,1) LT(Pulse_counter,Run.Postc_1_Number_of_drying_pulses) ,EQ(Process.Postc_status,2) NE(Run.Postcond_2_type,1) LT(Pulse_counter,Run.Postc_2_Number_of_drying_pulses) ]MOVE(18,Process.Step);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the equalization step when Vacuum Drying type]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Process.Postc_status,1) EQ(Run.Postcond_1_type,1) EQ(Run.Postcond_2_type,0) ,EQ(Process.Postc_status,2) EQ(Run.Postcond_2_type,1) ]MOVE(21,Process.Step);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Program transition to the equalization step when Pulse Drying type]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Process.Postc_status,1) NE(Run.Postcond_1_type,1) EQ(Run.Postcond_2_type,0) EQ(Pulse_counter,Run.Postc_1_Number_of_drying_pulses) ,EQ(Process.Postc_status,2) NE(Run.Postcond_2_type,1) EQ(Pulse_counter,Run.Postc_2_Number_of_drying_pulses) ][MOVE(21,Process.Step) ,CLR(Pulse_counter) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Program transition to the Cooling step when Postcond 2 type is Cooling]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Process.Postc_status,1)EQ(Run.Postcond_2_type,3)[NE(Run.Postcond_1_type,1) EQ(Pulse_counter,Run.Postc_1_Number_of_drying_pulses) ,EQ(Run.Postcond_1_type,1) ][MOVE(22,Process.Step) ,MOVE(2,Process.Postc_status) ,CLR(Pulse_counter) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Program transition to the Vacuum level step when Postcond 2 type is VD or PD]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Process.Postc_status,1)[LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ][NE(Run.Postcond_1_type,1) EQ(Pulse_counter,Run.Postc_1_Number_of_drying_pulses) ,EQ(Run.Postcond_1_type,1) ][MOVE(16,Process.Step) ,MOVE(2,Process.Postc_status) ,CLR(Pulse_counter) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Program transition to the Equalization step when Abort Vacuum level (from common settings) is done]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]XIC(Process.B_cycle_abort)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S18_Pressure_level" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S18 Pressure level
Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Process.Postc_status,1) MOVE(Run.Postc_1_Pressure_level,Step_pressure_setpoint) ,EQ(Process.Postc_status,2) MOVE(Run.Postc_2_Pressure_level,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition from S18 Pressure Level to S19 Pressure hold]]>
</Comment>
<Text>
<![CDATA[[GE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(19,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S19_Pressure_hold" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S19 Pressure hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Process.Postc_status,1) MUL(Run.Postc_1_Pressure_hold_time,60000,Step_timer.PRE) ,EQ(Process.Postc_status,2) MUL(Run.Postc_2_Pressure_hold_time,60000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the vacuum pulse step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][MOVE(16,Process.Step) ,ADD(Pulse_counter,1,Pulse_counter) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S1_Initialization" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Initialization timer counting when power is switched on]]>
</Comment>
<Text>
<![CDATA[[TON(Initialization,?,?) ,[XIO(Initialization.DN) ,XIO(PrintingACT) TOF(HMI_Act_Delay,?,?) ] [XIC(Process.Running) [EQ(Process.Power_brake_status,1) XIO(Process.Power_brake_1) OTL(Process.Power_brake_1) ,EQ(Process.Power_brake_status,3) XIO(Process.Power_brake_3) OTL(Process.Power_brake_3) ] ,RET() ] ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Transition to Standby step if process is not running ]]>
</Comment>
<Text>
<![CDATA[XIC(Initialization.DN)XIO(Process.Running)[MOVE(Process.Step_memory,Process.Step) ,CLR(Process.Power_brake_status) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Power brake over 30 minutes]]>
</Comment>
<Text>
<![CDATA[XIC(Initialization.DN)[EQ(Process.Power_brake_status,3) ,EQ(Process.Power_brake_status,0) XIC(Process.Power_brake_3) ]XIC(Process.Running)[OTL(Process.Cycle_aborted) ,MOVE(Process.Step_memory,Process.Step) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Power brake less than 60 seconds]]>
</Comment>
<Text>
<![CDATA[XIC(Initialization.DN)[EQ(Process.Power_brake_status,1) ,EQ(Process.Power_brake_status,0) XIC(Process.Power_brake_1) ]XIC(Process.Running)[MOVE(Process.Step_memory,Process.Step) ,OTU(Process.Power_brake_1) ,CLR(Process.Power_brake_status) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Unseal gasket if seal is pressurised after a power break]]>
</Comment>
<Text>
<![CDATA[XIC(Initialization.DN)[[LIMIT(5,Process.Step,6) ,EQ(Process.Step,26) ] XIC(DIG_IN[1].16) ,[EQ(Process.Step,2) NE(Process.Service_cycle,2) ,EQ(Process.Step,3) ,EQ(Process.Step,30) ] XIC(DIG_IN[1].0) ]OTL(Process.Pull_gasket);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(Initialization.DN)RES(Initialization);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S20_Slow_exhaust" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S20 Slow Exhaust
Step setpoint variables]]>
</Comment>
<Text>
<![CDATA[[MOVE(1,Process.Postc_status) ,MOVE(Process.ATM_pressure,Step_pressure_setpoint) MOVE(Run.Slow_exhaust_temp,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Step is ready when hottest load below 100 C and pressure is ambient]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].0)XIC(DIG_IN[0].1)LE(Load_temp_max,Run.Slow_exhaust_temp)[LIMIT(Process.ATM_low,PT549_Chamber.Pressure_mBar,Process.ATM_high) ,XIC(PT549_Chamber.out_of_range) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Change warning display if load probe failure during Slow exhaust]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Probe_failure_ack,1)[MOVE(13,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[User continues cycle when load probe failure]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Continue)MOVE(2,Probe_failure_ack);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the Equalization when user has confirmed load probe failure]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Probe_failure_ack,2)[MOVE(21,Process.Step) ,CLR(Process.Postc_status) CLR(Probe_failure_ack) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)NE(Probe_failure_ack,1)XIO(Process.Probes_fail)[[LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] [MOVE(16,Process.Step) ,MOVE(2,Process.Postc_status) ] ,[EQ(Run.Postcond_2_type,0) ,XIC(Process.Cycle_aborted) ] MOVE(21,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S21_Equalization" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S21 Equalization
Move ATM pressure to the setpoint]]>
</Comment>
<Text>
<![CDATA[[MOVE(Process.ATM_pressure,Step_pressure_setpoint) ,CLR(Process.Prec_status) ,CLR(Process.Postc_status) ,CLR(Pulse_counter) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Help bit for transition from equalization]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].0)XIC(DIG_IN[0].1)XIO(Process.Equal_press)[LIMIT(Process.ATM_low,PT549_Chamber.Pressure_mBar,Process.ATM_high) ,XIC(PT549_Chamber.out_of_range) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Transition to ST unseal step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)NE(Process.Service_cycle,2)EQ(Unload_confirm,0)[XIO(Process.Cycle_aborted) [LIMIT(1,Run.Interlock_type,2) ,EQ(Run.Interlock_type,6) ] ,XIC(Process.Cycle_aborted) [NE(Run.Precycle_type,7) ,EQ(Run.Precycle_type,7) XIC(HMI.VHP_Confirm_unseal_button) ] [EQ(Interlock_type_help,1) ,EQ(Interlock_type_help,6) ] ]MOVE(25,Process.Step);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Transition to NS unseal step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)[[XIO(Process.Cycle_aborted) LIMIT(3,Run.Interlock_type,5) ,XIC(Process.Cycle_aborted) [NE(Run.Precycle_type,7) ,EQ(Run.Precycle_type,7) XIC(HMI.VHP_Confirm_unseal_button) ] EQ(Interlock_type_help,3) ] EQ(Unload_confirm,0) ,EQ(Process.Service_cycle,2) ][MOVE(29,Process.Step) ,EQ(Process.Service_cycle,2) CLR(Process.Service_cycle) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Change unload side selection screen if cycle aborted after sterilization is completed]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Unload_confirm,1)EQ(Alarm_ACK[0],-1)EQ(Alarm_ACK[1],-1)EQ(Alarm_ACK[2],-1)[MOVE(12,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Transition to next step when user select unloading side]]>
</Comment>
<Text>
<![CDATA[EQ(Unload_confirm,1)[XIC(HMI.Abort_NS) [MOVE(3,Interlock_type_help) ,CLR(Unload_confirm) ,OTL(Process.Abort_Equal_unload_confirmed) ,OTU(HMI.Abort_NS) ] ,XIC(HMI.Abort_ST) [EQ(Run.Interlock_type,1) MOVE(1,Interlock_type_help) ,GT(Run.Interlock_type,1) MOVE(6,Interlock_type_help) ,CLR(Unload_confirm) ,OTL(Process.Abort_Equal_unload_confirmed) ,OTU(HMI.Abort_ST) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S22_Cooling_delay" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 22: Cooling delay
If product is already cooling move to the next step ]]>
</Comment>
<Text>
<![CDATA[XIO(Process.Probes_fail)LE(Load_temp_max,Run.Cooling_temp)[LE(TE518_Jacket.Temperature,Run.Cooling_temp) ,XIO(Option.VHP_process) ][LIMIT(1,Run.Postcond_2_type,2) [MOVE(16,Process.Step) ,MOVE(2,Process.Postc_status) ] ,[EQ(Run.Postcond_2_type,0) ,EQ(Run.Postcond_2_type,3) ,XIC(Process.Cycle_aborted) ] MOVE(21,Process.Step) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set step values]]>
</Comment>
<Text>
<![CDATA[[MUL(Common_set.Cooling_delay,1000,Step_timer.PRE) ,MOVE(Run.Cooling_temp,Step_temperature_setpoint) ,MOVE(Run.Support_press,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Transition to the next step]]>
</Comment>
<Text>
<![CDATA[GT(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint)XIC(Step_timer.DN)MOVE(24,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S23_Spare" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S24_Cooling" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S24 Cooling
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[MUL(Run.Cooling_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Step is ready when product is cooled below setpoint and timer has elapsed]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)LT(Load_temp_max,Run.Cooling_temp)OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Change warning display if load probe failure during cooling]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Probe_failure_ack,1)[MOVE(13,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[User continues cycle when load probe failure]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Continue)MOVE(2,Probe_failure_ack);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)NE(Probe_failure_ack,1)[[LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] [MOVE(16,Process.Step) ,MOVE(2,Process.Postc_status) ] ,[EQ(Run.Postcond_2_type,0) ,EQ(Run.Postcond_2_type,3) ,XIC(Process.Cycle_aborted) ] MOVE(21,Process.Step) ,CLR(Probe_failure_ack) XIO(Option.Jacket_closed_loop) XIO(Option.CA_process) OTL(Process.Jacket_air) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S25_Unseal_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S25 Unseal ST door
Step timer]]>
</Comment>
<Text>
<![CDATA[MUL(Common_set.Door_unsealing_delay,1000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)XIO(DIG_IN[1].18)MOVE(26,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S26_Enable_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 26: Enable ST
Program transition to next step when cycle ends to ST door]]>
</Comment>
<Text>
<![CDATA[NE(Run.Interlock_type,1)XIO(DIG_IN[1].16)XIO(DIG_IN[1].17)EQ(Festo_Status[0],16384)MOVE(5,Process.Step);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to next step when cycle continues]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Interlock_type,1)XIO(DIG_IN[1].16)XIO(DIG_IN[1].17)EQ(Festo_Status[0],16384)MOVE(27,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S27_Unload_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 27: Unload ST
Program transition to next step ]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].16)XIC(DIG_IN[1].17)MOVE(28,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S28_Seal_ST_door" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S28 Seal ST door
Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[XIC(DIG_IN[1].18) MOVE(29,Process.Step) ,XIC(Alarm_ACT[0].4) MOVE(25,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S29_Unseal_NS" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S29 Unseal NS door
Step timer]]>
</Comment>
<Text>
<![CDATA[MUL(Common_set.Door_unsealing_delay,1000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)XIO(DIG_IN[1].2)MOVE(30,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S2_Standby_NS" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 2: Standby NS
Program transition to next step if starting is not disabled]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Start_disabled,0)MOVE(3,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S30_Enable_NS" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 30: Enable NS
Program transition to next step ]]>
</Comment>
<Text>
<![CDATA[[NE(Run.Interlock_type,4) ,XIO(Process.Running) EQ(Interlock_type_help,3) ]XIO(DIG_IN[1].0)XIO(DIG_IN[1].1)EQ(Festo_Status[0],16384)MOVE(2,Process.Step);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to next step when cycle continues]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Interlock_type,4)NE(Interlock_type_help,3)XIO(DIG_IN[1].0)XIO(DIG_IN[1].1)EQ(Festo_Status[0],16384)MOVE(31,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S31_Unload_NS" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 31: Unload NS
Program transition to next step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].0)XIC(DIG_IN[1].1)MOVE(32,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S32_Seal_NS_door" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S32 Seal NS door
Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[XIC(DIG_IN[1].2) MOVE(25,Process.Step) ,XIC(Alarm_ACT[0].3) MOVE(29,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S33_LRT_Vacuum_lev" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set step transition pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[MOVE(Run.FA_vacuum_test_level,Step_pressure_setpoint) ,MUL(Run.FA_vacuum_init_time,60000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Precycle_type,1) LE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) XIC(Step_timer.DN) ,LIMIT(2,Run.Precycle_type,3) LE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(34,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S34_LRT_Stabilization" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S34 Leak rate test Stabilization
Set step timer value]]>
</Comment>
<Text>
<![CDATA[MUL(Run.FA_stabilizat_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the LRT vacuum hold step
Store pressure value for compare max leak]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][ADD(PT549_Chamber.Pressure_mBar,Run.FA_acceptable_leak_rate,Accept_leak_value) ,MOVE(Accept_leak_value,Step_pressure_setpoint) ,MOVE(PT549_Chamber.Pressure_mBar,LRT_start_value) ,MOVE(35,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S35_LRT_vacuum_hold" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S35 Leak rate test Vacuum hold
Set step timer value]]>
</Comment>
<Text>
<![CDATA[MUL(Run.FA_vacuum_test_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Leak rate test failed if pressure raise too high]]>
</Comment>
<Text>
<![CDATA[GT(PT549_Chamber.Pressure_mBar,Accept_leak_value)OTL(Process.Leak_test_abort);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the precond 1 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Run.Precond_1_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_1_type,2) XIO(Run.Prec_1_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_1_type,2) XIC(Run.Prec_1_First_pulse_type) MOVE(10,Process.Step) ,EQ(Run.Precond_1_type,3) MOVE(60,Process.Step) ,NE(Run.Precond_1_type,0) MOVE(1,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the precond 2 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Run.Precond_1_type,0)[EQ(Run.Precond_2_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_2_type,2) XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_2_type,2) XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,NE(Run.Precond_2_type,0) MOVE(2,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Move to the postcondition step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)EQ(Run.Exposure_type,0)[EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,0) MOVE(21,Process.Step) ,[[LIMIT(1,Run.Postcond_1_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) [LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] MOVE(2,Process.Postc_status) ] MOVE(16,Process.Step) ,[EQ(Run.Postcond_1_type,3) MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,3) MOVE(2,Process.Postc_status) ] MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(1,Process.Postc_status) MOVE(20,Process.Step) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[[NE(Process.Step,35) ,XIC(Process.Leak_test_abort) ]SUB(PT549_Chamber.Pressure_mBar,LRT_start_value,LRT_leak_value);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S36_VHP_Dehumidification" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S36 VHP Dehumidification
Option 10.4.41
]]>
</Comment>
<Text>
<![CDATA[MOVE(Process.ATM_pressure,Step_pressure_setpoint)MUL(Run.VHP_Dehumidification_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Next step 37 
VHP Biodecontamination]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]LIMIT(Process.ATM_low,PT549_Chamber.Pressure_mBar,Process.ATM_high)LT(Load_temp_max,40)GT(Load_temp_min,16)MOVE(37,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S37_VHP_Biodecontamination" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S37 VHP Biodecontamination
Option 10.4.41 Chamber VHP concentration controlled by External VHP Generator]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].10)TON(VHP_ready_delay,?,?);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Next step 38
VHP Aeration]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Biodec)[XIC(VHP_ready_delay.DN) ,XIC(Process.Step_pressed) ][MOVE(38,Process.Step) ,RES(VHP_ready_delay) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Next step 21
Equalization]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Ports)EQ(Run.Precycle_type,7)XIC(Process.Running)[XIC(HMI.Abort) ,XIC(HMI.VHP_Stop_button) ]MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S38_VHP_Aeration" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S38 VHP Aeration
Option 10.4.41
Flushing VHP gas through the vacuum pump
]]>
</Comment>
<Text>
<![CDATA[MUL(Run.VHP_Aeration_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Next Step 21 Equalization]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S3_Ready_to_Start_NS" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 3: Ready to start NS]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_start)[MOVE(4,Process.Step) ,LE(Run.Interlock_type,3) MOVE(3,Interlock_type_help) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the FIT Sanitization (S89) step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_start)EQ(Run.Precycle_type,8)MOVE(89,Process.Step);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the FIT Flush (S91) step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_start)EQ(Run.Precycle_type,9)MOVE(91,Process.Step);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the FIT Test (S94 tank fill) step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_start)EQ(Run.Precycle_type,10)[MOVE(94,Process.Step) ,MOVE(PT1004_Filter_FIT.Pressure_mBar,Process.FIT_atm_pressure) ,ADD(Process.FIT_atm_pressure,100,Process.FIT_Step94_pressure) ,ADD(Process.FIT_atm_pressure,Run.FIT_Test_pressure,Process.FIT_Test_pressure_abs) ,MOVE(0,Process.FIT_Air_volume) ,MOVE(0,Process.FIT_RT_Flow_rate) ,MOVE(0,Process.FIT_Flow_rate_end) ,MOVE(0,Process.FIT_Flow_rate_end) ,MOVE(0,Process.FIT_Max_Flow_rate) ,MOVE(0,Process.FIT_Test_temperature) ,MOVE(0,Process.FIT_Temp_Low) ,MOVE(0,Process.FIT_Temp_High) ,OTL(HMI.FIT_PY1012_Man_Auto) ,OTU(Process.FIT_OK) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[If starting is disabled return to the Standby step]]>
</Comment>
<Text>
<![CDATA[NE(Process.Start_disabled,0)MOVE(2,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S40_VFT_Vacuum_level" Type="RLL">
<Description>
<![CDATA[S40 VIRASURE Flow Test, Vacuum level]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S40 VIRASURE Flow Test, Vacuum level
Set step transition pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[MOVE(Run.VS_init_vacuum_level,Step_pressure_setpoint);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[LE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(41,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S41_VFT_Stabilization" Type="RLL">
<Description>
<![CDATA[S41 VIRASURE Flow Test, Stabilization]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S41 VIRASURE Flow Test, Stabilization
Set step timer value]]>
</Comment>
<Text>
<![CDATA[MUL(Run.VS_stabilizat_time,1000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the "S42 VIRASURE Flow Test, Time Test" step
]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][MOVE(Run.VS_test_target_vacuum_level,Step_pressure_setpoint) ,MOVE(PT549_Chamber.Pressure_mBar,LRT_start_value) ,MOVE(42,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S42_VFT_Flow_Test" Type="RLL">
<Description>
<![CDATA[S42 VIRASURE Flow Test, Time Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S42 VIRASURE Flow Test, Time Test

Set step timer value]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.VS_test_max_time,1000,Step_timer.PRE) ,MUL(Run.VS_test_min_time,1000,VS_flow_test_min_time_help) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[GE(PT549_Chamber.Pressure_mBar,Run.VS_test_target_vacuum_level) LT(Step_timer.ACC,VS_flow_test_min_time_help) ,LT(PT549_Chamber.Pressure_mBar,Run.VS_test_target_vacuum_level) XIC(Step_timer.DN) ]OTL(Process.Leak_test_abort);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the Equalization step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) XIO(Process.Leak_test_abort) ,GE(PT549_Chamber.Pressure_mBar,Run.VS_test_target_vacuum_level) ]MOVE(21,Process.Step);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Store test time value]]>
</Comment>
<Text>
<![CDATA[[NE(Process.Step,42) ,XIC(Process.Leak_test_abort) ][SUB(PT549_Chamber.Pressure_mBar,LRT_start_value,LRT_leak_value) ,DIV(Step_timer.ACC,1000,VS_test_time_value) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S44_Preheating" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S44 Preheating
Set step timer value]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.Preheat_time,60000,Step_timer.PRE) ,MOVE(Run.Preheat_temp,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the precond 1 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Run.Precond_1_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_1_type,2) XIO(Run.Prec_1_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_1_type,2) XIC(Run.Prec_1_First_pulse_type) MOVE(10,Process.Step) ,EQ(Run.Precond_1_type,3) MOVE(60,Process.Step) ,EQ(Run.Precond_1_type,4) MOVE(81,Process.Step) ,NE(Run.Precond_1_type,0) MOVE(1,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the precond 2 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Run.Precond_1_type,0)[EQ(Run.Precond_2_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_2_type,2) XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_2_type,2) XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,NE(Run.Precond_2_type,0) MOVE(2,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Move to the postcondition step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)EQ(Run.Exposure_type,0)[EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,0) MOVE(21,Process.Step) ,[[LIMIT(1,Run.Postcond_1_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) [LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] MOVE(2,Process.Postc_status) ] MOVE(16,Process.Step) ,[EQ(Run.Postcond_1_type,3) MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,3) MOVE(2,Process.Postc_status) ] MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(1,Process.Postc_status) MOVE(20,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S4_Seal_NS_door" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S4 Seal NS door
Program transition to the pretest step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)LIMIT(1,Run.Precycle_type,2)[MOVE(33,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the VIRASURE flow test step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precycle_type,3)[MOVE(40,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the VHP step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precycle_type,4)[MOVE(50,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the Preheating step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precycle_type,5)[MOVE(44,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[ VHP Biodec 10.4.41 Program transition to the  Dehumidification Step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precycle_type,6)[MOVE(36,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[ VHP Ports 10.4.40 Program transition to the  Biodecontamination Step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precycle_type,7)[MOVE(37,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Program transition to the precond 1 step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)[EQ(Run.Precond_1_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_1_type,2) XIO(Run.Prec_1_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_1_type,2) XIC(Run.Prec_1_First_pulse_type) MOVE(10,Process.Step) ,EQ(Run.Precond_1_type,3) [XIO(Run.Prec_1_First_pulse_type) MOVE(60,Process.Step) ,XIC(Run.Prec_1_First_pulse_type) MOVE(62,Process.Step) ] ,EQ(Run.Precond_1_type,4) MOVE(81,Process.Step) ,NE(Run.Precond_1_type,0) MOVE(1,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Program transition to the precond 2 step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precond_1_type,0)[EQ(Run.Precond_2_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_2_type,2) XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_2_type,2) XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,NE(Run.Precond_2_type,0) MOVE(2,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].2)EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Continue next step check if no precondition
If exposure type is None and postcondition is none move to the Equalization]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Step,13)EQ(Run.Exposure_type,0)EQ(Run.Postcond_1_type,0)EQ(Run.Postcond_2_type,0)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S50_VHP_Unseal_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S50 VHP Unseal ST door
Step timer]]>
</Comment>
<Text>
<![CDATA[MUL(Common_set.Door_unsealing_delay,1000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)[XIO(DIG_IN[1].18) MOVE(51,Process.Step) ,XIC(DIG_IN[1].18) MOVE(57,Process.Step) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S51_VHP_Opening_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S51 VHP Open ST door
Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].21)MOVE(53,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S53_VHP_Dehumidification" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S53 VHP Dehumification
Handshake with VHP unit]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].10)EQ(VHP_handshake,0)[MOVE(1,VHP_handshake) ,XIO(Common_set.VHP_handshake) MOVE(2,VHP_handshake) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Handshake with VHP unit]]>
</Comment>
<Text>
<![CDATA[XIO(DIG_IN[0].10)EQ(VHP_handshake,1)MOVE(2,VHP_handshake);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[When VHP injection starts move to next program step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].10)[EQ(VHP_handshake,2) ,XIO(Common_set.VHP_handshake) ]CLR(VHP_handshake)MOVE(54,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S54_VHP_Sterilization" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S54 VHP Sterilization (Door Open Time)
Step timer]]>
</Comment>
<Text>
<![CDATA[MUL(Run.VHP_Door_open_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]MOVE(55,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S55_VHP_Cycling_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S55 VHP Sterilization (Door Cycling)
Step timer]]>
</Comment>
<Text>
<![CDATA[MUL(Run.VHP_Door_cycling_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Door cycling commands]]>
</Comment>
<Text>
<![CDATA[[[XIC(DIG_IN[1].21) ,XIC(DIG_IN[1].16) ] TON(VHP_Door_Delay,?,?) ,[XIC(DIG_IN[1].21) XIC(VHP_Door_Delay.DN) ,XIC(Process.Cycle_aborted) ,XIC(Step_timer.DN) ] OTU(Process.VHP_Open_ST) OTL(Process.VHP_Close_ST) ,XIC(VHP_Door_Delay.DN) XIC(DIG_IN[1].16) OTU(Process.VHP_Close_ST) OTL(Process.VHP_Open_ST) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Cycle_aborted) ]XIC(DIG_IN[1].16)MOVE(57,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S56_VHP_Close_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S56 VHP Close ST Door
Step timer]]>
</Comment>
<Text>
<![CDATA[MOVE(5000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)XIC(DIG_IN[1].16)MOVE(57,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S57_VHP_Seal_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S57 VHP ST Door Sealing Time
Load step timer
Move to equalization if prosess is aborted]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.VHP_Door_sealing_time,60000,Step_timer.PRE) ,OTU(Process.VHP_Close_ST) XIC(Step_timer.DN) XIC(Process.Cycle_aborted) MOVE(21,Process.Step) RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the precond 1 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]XIC(DIG_IN[1].18)[EQ(Run.Precond_1_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_1_type,2) XIO(Run.Prec_1_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_1_type,2) XIC(Run.Prec_1_First_pulse_type) MOVE(10,Process.Step) ,EQ(Run.Precond_1_type,3) MOVE(60,Process.Step) ,NE(Run.Precond_1_type,0) MOVE(1,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the precond 2 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]XIC(DIG_IN[1].18)EQ(Run.Precond_1_type,0)[EQ(Run.Precond_2_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_2_type,2) XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_2_type,2) XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,NE(Run.Precond_2_type,0) MOVE(2,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]XIC(DIG_IN[1].18)EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Continue next step check if no precondition
If exposure type is None and postcondition is none move to the Equalization]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]XIC(DIG_IN[1].18)EQ(Process.Step,13)EQ(Run.Exposure_type,0)EQ(Run.Postcond_1_type,0)EQ(Run.Postcond_2_type,0)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S5_Standby_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 5: Standby ST
Program transition to next step if starting is not disabled]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Start_disabled,0)MOVE(6,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S60_DEC_Vacuum_level" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S60 DEC Vacuum level
Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ,EQ(Pulse_counter,1) MOVE(Run.Prec_1_1st_vacuum_level,Step_pressure_setpoint) ,EQ(Pulse_counter,2) MOVE(Run.Prec_1_2nd_vacuum_level,Step_pressure_setpoint) ,GE(Pulse_counter,3) MOVE(Run.Prec_1_3rd_vacuum_level,Step_pressure_setpoint) ,MOVE(Pulse_counter,Pulse_counter_Controller_Tag) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next sep]]>
</Comment>
<Text>
<![CDATA[[LE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ][XIC(Option.DecV_process) XIC(VIRASURE_Temperature_Reached) ,XIO(Option.DecV_process) ]MOVE(61,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S61_DEC_Vacuum_hold" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S61 DEC Vacuum hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Pulse_counter,1) MUL(Run.Prec_1_1st_vacuum_hold_time,1000,Step_timer.PRE) ,EQ(Pulse_counter,2) MUL(Run.Prec_1_2nd_vacuum_hold_time,1000,Step_timer.PRE) ,GE(Pulse_counter,3) MUL(Run.Prec_1_3rd_vacuum_hold_time,1000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Pulse_counter,Run.Prec_1_Number_of_air_rem_pulses)[MOVE(64,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the pressure pulse step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Process.Step,61)LT(Pulse_counter,Run.Prec_1_Number_of_air_rem_pulses)[MOVE(62,Process.Step) ,XIC(Run.Prec_1_First_pulse_type) ADD(Pulse_counter,1,Pulse_counter) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S62_DEC_Pressure_level" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S62 Pressure level
Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ,EQ(Pulse_counter,1) MOVE(Run.Prec_1_1st_pressure_level,Step_pressure_setpoint) ,EQ(Pulse_counter,2) MOVE(Run.Prec_1_2nd_pressure_level,Step_pressure_setpoint) ,GE(Pulse_counter,3) MOVE(Run.Prec_1_3rd_pressure_level,Step_pressure_setpoint) ,MOVE(Pulse_counter,Pulse_counter_Controller_Tag) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next sep]]>
</Comment>
<Text>
<![CDATA[[GE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(63,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S63_DEC_Pressure_hold" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S63 Pressure hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Pulse_counter,1) MUL(Run.Prec_1_1st_pressure_hold_time,1000,Step_timer.PRE) ,EQ(Pulse_counter,2) MUL(Run.Prec_1_2nd_pressure_hold_time,1000,Step_timer.PRE) ,GE(Pulse_counter,3) MUL(Run.Prec_1_3rd_pressure_hold_time,1000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the vacuum pulse step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][MOVE(60,Process.Step) ,XIO(Run.Prec_1_First_pulse_type) ADD(Pulse_counter,1,Pulse_counter) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S64_DEC_Heating_up" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S64 DEC Heating up
If exposure type is None move to the next step]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,0)[EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,0) [NE(Run.Precond_1_type,3) MOVE(21,Process.Step) ,EQ(Run.Precond_1_type,3) MOVE(66,Process.Step) ] ,[[LIMIT(1,Run.Postcond_1_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) LIMIT(1,Run.Postcond_2_type,2) MOVE(2,Process.Postc_status) ] MOVE(16,Process.Step) ,[EQ(Run.Postcond_1_type,3) MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_1_type,0) EQ(Run.Postcond_2_type,3) MOVE(2,Process.Postc_status) ] MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(1,Process.Postc_status) MOVE(20,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set temperature transition point from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[SUB(Run.Exposure_temperature,Run.Exposure_temp_dev_low,Step_setpoint_help) ,CLR(Pulse_counter) ADD(Step_setpoint_help,0.2,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the next step if time type]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Exposure_type,1) ,EQ(Run.Exposure_type,3) ][GE(Load_temp_min,Step_temperature_setpoint) [XIO(Option.DecV_process) GE(TE517_2_DEC.Temperature,Step_temperature_setpoint) ,XIC(Option.DecV_process) GE(TE517_Chamber.Temperature,Step_temperature_setpoint) ] ,XIC(Process.Step_pressed) ]MOVE(65,Process.Step);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the next sep if Fo type]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,2)[GE(Load_temp_min,100) [XIO(Option.DecV_process) GE(TE517_2_DEC.Temperature,100) ,XIC(Option.DecV_process) GE(TE517_Chamber.Temperature,100) ] ,XIC(Process.Step_pressed) ]MOVE(65,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S65_DEC_Exposure" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S65 DEC Exposure
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,1)MUL(Run.Exposure_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Exposure_type,1) XIC(Step_timer.DN) ,EQ(Run.Exposure_type,2) GT(FO_value[4],FO_value[3]) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Transition to the Postcond 1 step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)[[LIMIT(1,Run.Postcond_1_type,2) ,EQ(Run.Postcond_1_type,5) ] MOVE(16,Process.Step) ,EQ(Run.Postcond_1_type,3) MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(20,Process.Step) ,MOVE(1,Process.Postc_status) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Transition to the Postcond 2 step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Run.Postcond_1_type,0)[[LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] MOVE(16,Process.Step) ,EQ(Run.Postcond_2_type,3) MOVE(22,Process.Step) ,MOVE(2,Process.Postc_status) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Transition to the Equalization]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Run.Postcond_1_type,0)EQ(Run.Postcond_2_type,0)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S66_DEC_Abort_Slow_exhaust" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S66 DEC Abort Slow Exhaust
Step setpoint variables]]>
</Comment>
<Text>
<![CDATA[[MOVE(1,Process.Postc_status) ,MOVE(100,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to next step ]]>
</Comment>
<Text>
<![CDATA[[[LT(Run.Postcond_1_type,3) ,EQ(Run.Postcond_1_type,5) ] NE(Run.Postcond_2_type,3) ,LT(Load_temp_max,Step_temperature_setpoint) ]MOVE(67,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S67_DEC_Equalization" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S67 DEC Equalization
Move ATM pressure to the setpoint]]>
</Comment>
<Text>
<![CDATA[[MOVE(Process.ATM_pressure,Step_pressure_setpoint) ,CLR(Process.Prec_status) ,CLR(Process.Postc_status) ,CLR(Pulse_counter) ,XIO(DIG_IN[1].4) OTL(Process.DEC_condensate_high) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Help bit for transition from equalization


]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[0].0)XIC(DIG_IN[0].1)[LIMIT(Process.ATM_low,PT549_Chamber.Pressure_mBar,Process.ATM_high) ,XIC(PT549_Chamber.out_of_range) ][XIO(Process.DEC_condensate_high) XIC(DEC_Condensate_OK_delay.DN) ,XIC(Process.DEC_condensate_high) XIC(DEC_Condensate_OK_delay.DN) XIC(Process.DEC_step68_completed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Process.DEC_condensate_high)XIO(Process.DEC_step68_completed)MOVE(68,Process.Step);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Transition to ST unseal step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Unload_confirm,0)[XIO(Process.Cycle_aborted) [LIMIT(1,Run.Interlock_type,2) ,EQ(Run.Interlock_type,6) ] ,XIC(Process.Cycle_aborted) EQ(Interlock_type_help,6) ]MOVE(25,Process.Step);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Transition to NS unseal step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)[XIO(Process.Cycle_aborted) LIMIT(3,Run.Interlock_type,5) ,XIC(Process.Cycle_aborted) EQ(Interlock_type_help,3) ]EQ(Unload_confirm,0)MOVE(29,Process.Step);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Change unload side selection screen if cycle aborted after sterilization is completed]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Unload_confirm,1)EQ(Alarm_ACK[0],-1)EQ(Alarm_ACK[1],-1)[MOVE(12,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Transition to next step when user select unloading side]]>
</Comment>
<Text>
<![CDATA[[XIC(HMI.Abort_NS) [MOVE(3,Interlock_type_help) ,CLR(Unload_confirm) ,OTL(Process.Abort_Equal_unload_confirmed) ,OTU(HMI.Abort_NS) ] ,XIC(HMI.Abort_ST) [MOVE(6,Interlock_type_help) ,CLR(Unload_confirm) ,OTL(Process.Abort_Equal_unload_confirmed) ,OTU(HMI.Abort_ST) ] ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Reset tags when not in proper steps]]>
</Comment>
<Text>
<![CDATA[NE(Process.Step,67)NE(Process.Step,68)NE(Process.Step,0)NE(Process.Step,1)[RES(DEC_Condensate_OK_delay) ,OTU(Process.DEC_condensate_high) ,RES(DEC_Condensate_end_heat_time) ,OTU(Process.DEC_step68_completed) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S68_DEC_Abort_Condens_removal" Type="RLL">
<Description>
<![CDATA[Decontamination process]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S68 DEC Abort Condensate Removal

Step setpoint variables:
Set vacuum level to step pressure setpoint, vacuum leveli is controlled throughout the step.
Set time (step timer) for residual condensate removal after condensate level has been low for 2 minutes, vacuum and heating control continues.]]>
</Comment>
<Text>
<![CDATA[[MOVE(Common_set.DEC_abort_condensate_vacuum_level,Step_pressure_setpoint) ,XIC(Process.DEC_condensate_high) XIC(DEC_Condensate_OK_delay.DN) MUL(Common_set.DEC_abort_condensate_heating_time,60000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(DEC_Condensate_OK_delay.DN)[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][MOVE(67,Process.Step) ,OTL(Process.DEC_step68_completed) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S6_Ready_to_Start_ST" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step 6: Ready to start ST]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_start)[MOVE(7,Process.Step) ,GE(Run.Interlock_type,4) MOVE(6,Interlock_type_help) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[If starting is disabled return to the Standby step]]>
</Comment>
<Text>
<![CDATA[NE(Process.Start_disabled,0)MOVE(5,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S7_Seal_ST_door" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S7 Seal ST door
Program transition to the pretest step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)LIMIT(1,Run.Precycle_type,2)[MOVE(33,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the VIRASURE flow test step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)EQ(Run.Precycle_type,3)[MOVE(40,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the Preheating step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)EQ(Run.Precycle_type,5)[MOVE(44,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[ VHP Biodec 10.4.41 Program transition to the  Dehumidification Step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)EQ(Run.Precycle_type,6)[MOVE(36,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[ VHP Ports 10.4.40 Program transition to the  Biodecontamination Step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)EQ(Run.Precycle_type,7)[MOVE(37,Process.Step) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Program transition to the precond 1 step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)[EQ(Run.Precond_1_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_1_type,2) XIO(Run.Prec_1_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_1_type,2) XIC(Run.Prec_1_First_pulse_type) MOVE(10,Process.Step) ,EQ(Run.Precond_1_type,3) [XIO(Run.Prec_1_First_pulse_type) MOVE(60,Process.Step) ,XIC(Run.Prec_1_First_pulse_type) MOVE(62,Process.Step) ] ,EQ(Run.Precond_1_type,4) MOVE(81,Process.Step) ,NE(Run.Precond_1_type,0) MOVE(1,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Program transition to the precond 2 step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)EQ(Run.Precond_1_type,0)[EQ(Run.Precond_2_type,1) MOVE(12,Process.Step) ,EQ(Run.Precond_2_type,2) XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,EQ(Run.Precond_2_type,2) XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,NE(Run.Precond_2_type,0) MOVE(2,Process.Prec_status) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_IN[1].18)EQ(Run.Precond_1_type,0)EQ(Run.Precond_2_type,0)MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Continue next step check if no precondition
If exposure type is None and postcondition is none move to the Equalization]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Step,13)EQ(Run.Exposure_type,0)EQ(Run.Postcond_1_type,0)EQ(Run.Postcond_2_type,0)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S81_SAMX_Heating_up" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S81 SAMX Heating up

Set temperature transition point from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Exposure_type,1) [SUB(Run.Exposure_temperature,Run.Exposure_temp_dev_low,Step_setpoint_help) ,ADD(Step_setpoint_help,0.2,Step_temperature_setpoint) ] ,EQ(Run.Exposure_type,2) MOVE(100,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[[GE(Load_temp_min,Step_temperature_setpoint) GE(SAMX_Control_temperature,Step_temperature_setpoint) ,XIC(Process.Step_pressed) ][MOVE(82,Process.Step) ,CLR(Process.Prec_status) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S82_SAMX_Exposure" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S82 SAMX Exposure
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,1)MUL(Run.Exposure_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Transition to the Postcond 1 SAMX Cooling Initialization step]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Exposure_type,1) XIC(Step_timer.DN) ,EQ(Run.Exposure_type,2) GT(FO_value[4],FO_value[3]) ,XIC(Process.Step_pressed) ][MOVE(83,Process.Step) ,MOVE(1,Process.Postc_status) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S83_SAMX_Cooling_Init" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S83 SAMX Cooling initialization
Step time from Common Settings Cooling Delay]]>
</Comment>
<Text>
<![CDATA[[MUL(Common_set.Cooling_delay,1000,Step_timer.PRE) ,MOVE(Run.Cooling_temp,Step_temperature_setpoint) ,MOVE(1,Process.Postc_status) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)MOVE(84,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S84_SAMX_Cooling" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S84 SAMX Cooling
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[MUL(Run.Cooling_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Step is ready when product is cooled below setpoint and timer has elapsed]]>
</Comment>
<Text>
<![CDATA[XIC(Step_timer.DN)LT(Load_temp_max,Run.Cooling_temp)LT(SAMX_Control_temperature,Run.Cooling_temp)OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Change warning display if load probe failure during cooling]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)EQ(Probe_failure_ack,1)[MOVE(13,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[User continues cycle when load probe failure]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Continue)MOVE(2,Probe_failure_ack);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the next step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)NE(Probe_failure_ack,1)[[LIMIT(1,Run.Postcond_2_type,2) ,EQ(Run.Postcond_2_type,5) ] [MOVE(16,Process.Step) ,MOVE(2,Process.Postc_status) ] ,[EQ(Run.Postcond_2_type,0) ,XIC(Process.Cycle_aborted) ] MOVE(21,Process.Step) ,CLR(Probe_failure_ack) XIO(Option.Jacket_closed_loop) OTL(Process.Jacket_air) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S89_FIT_Sanitization" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S89 FIT Sanitization
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.FIT_Sanitization_time,60000,Step_timer.PRE) ,MOVE(Run.FIT_Sanitization_temp,Step_temperature_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[GT(TE517_5_FIT_Sanitization.Temperature,Run.FIT_Sanitization_temp)OTL(Process.FIT_Sanitization_temp_reached);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Transition to the FIT Cooling]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)MOVE(90,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S8_Vacuum_level" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S8 Vacuum level
Set pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,1)[EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ,EQ(Pulse_counter,1) MOVE(Run.Prec_1_1st_vacuum_level,Step_pressure_setpoint) ,EQ(Pulse_counter,2) MOVE(Run.Prec_1_2nd_vacuum_level,Step_pressure_setpoint) ,GE(Pulse_counter,3) MOVE(Run.Prec_1_3rd_vacuum_level,Step_pressure_setpoint) ,MOVE(Pulse_counter,Pulse_counter_Controller_Tag) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set precondition 2 pressure level from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,2)[EQ(Pulse_counter,0) MOVE(1,Pulse_counter) ,EQ(Pulse_counter,1) MOVE(Run.Prec_2_1st_vacuum_level,Step_pressure_setpoint) ,EQ(Pulse_counter,2) MOVE(Run.Prec_2_2nd_vacuum_level,Step_pressure_setpoint) ,GE(Pulse_counter,3) MOVE(Run.Prec_2_3rd_vacuum_level,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition to the next sep]]>
</Comment>
<Text>
<![CDATA[[LE(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(9,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S90_FIT_Cooling" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test
Cooling after sanitization]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S90 FIT Cooling after sanitization
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[MUL(Run.FIT_Sanitiz_cooling_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Move to the equalization step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S91_FIT_Flush" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test
Feed Water Branch Flush]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S91 FIT Feed Water Branch Flush
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[MUL(Common_set.FIT_Piping_flush_time,1000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Move to the tank filling step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)MOVE(92,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S92_FIT_Water_Tank_Filling" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test
Water Tank Filling]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[MUL(Run.FIT_Tank_filling_time,60000,Step_timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[S92 FIT Water Tank Filling

Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIO(DIG_IN[1].22) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Move to the equalization step]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)MOVE(21,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S94_FIT_Fill" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S94 FIT Fill
Transition to S95, when air filter assembly pressure (PT1004) indicates a value higher than 0.1 barg (atm + 100 mbar (1.45 psi)).]]>
</Comment>
<Text>
<![CDATA[MOVE(Process.FIT_Step94_pressure,Step_pressure_setpoint);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[GT(PT1004_Filter_FIT.Pressure_mBar,Step_pressure_setpoint) ,XIC(Process.Step_pressed) ]MOVE(95,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S95_FIT_Pressurize" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S95 FIT Pressurize
Transition to S96, when air filter assembly pressure (PT1004) has reached the configured test ]]>
</Comment>
<Text>
<![CDATA[ADD(Process.FIT_atm_pressure,Run.FIT_Test_pressure,Process.FIT_Test_pressure_abs)MOVE(Process.FIT_Test_pressure_abs,Step_pressure_setpoint);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[GE(PT1004_Filter_FIT.Pressure_mBar,Process.FIT_Test_pressure_abs) ,XIC(Process.Step_pressed) ][MOVE(96,Process.Step) ,SUB(PT1004_Filter_FIT.Pressure_mBar,500,Process.FIT_Test_press_minus500) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S96_FIT_Stabilization" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S96 FIT Stabilization
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.FIT_Stabilization_time,60000,Step_timer.PRE) ,MOVE(Process.FIT_Test_pressure_abs,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Process.Step_ready)[MOVE(PT1004_Filter_FIT.Pressure_mBar,Process.FIT_Step97_pressure) ,MOVE(TE1018_Filter_FIT.Temperature,Process.FIT_Test_temperature) ,SUB(Process.FIT_Test_temperature,Run.FIT_Max_temp_difference,Process.FIT_Temp_Low) ,ADD(Process.FIT_Test_temperature,Run.FIT_Max_temp_difference,Process.FIT_Temp_High) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Upstream Gas Volume
V2 (new vol) = Patm * V1 / P2(test)
Max Flow Rate
((0.66-0.33) / (50-20)) * (test water temp-20) + 0.33
(0.66-0.33) / (50-20) = 0.011 = constant used in formula
Values are from PALL AB1PFR air filter cartridge
Temperature / Flow Rate table]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)[NE(Process.FIT_Step97_pressure,0) CPT(Process.FIT_Air_volume,Process.FIT_atm_pressure*Common_set.FIT_Initial_air_volume/Process.FIT_Step97_pressure) ,CPT(Process.FIT_Max_Flow_rate,0.011*(Process.FIT_Test_temperature-20.0)+0.33) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Transition to the FIT Test]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)MOVE(97,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S97_FIT_Test_time" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S97 FIT Test time
Set step timer preset value from cycle parameters]]>
</Comment>
<Text>
<![CDATA[[MUL(Run.FIT_Test_time,60000,Step_timer.PRE) ,MOVE(Process.FIT_Step97_pressure,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[MOVE(PT1004_Filter_FIT.Pressure_mBar,Process.FIT_Step97_RTpressure);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Flow Rate calculation
Fr=(dP*V2)/(P2*t)
Calculate first (P2*t)]]>
</Comment>
<Text>
<![CDATA[CPT(Process.FIT_RT_Flow_rate_help,(Process.FIT_Step97_pressure-Process.FIT_atm_pressure)*Run.FIT_Test_time);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Flow Rate calculation
Fr=(dP*V2)/(P2*t)]]>
</Comment>
<Text>
<![CDATA[NE(Process.FIT_RT_Flow_rate_help,0)CPT(Process.FIT_RT_Flow_rate,(Process.FIT_Step97_pressure-Process.FIT_Step97_RTpressure)*Process.FIT_Air_volume/Process.FIT_RT_Flow_rate_help);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Transition to the FIT Drain]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)[MOVE(98,Process.Step) ,MOVE(Process.FIT_RT_Flow_rate,Process.FIT_Flow_rate_end) ,LE(Process.FIT_Flow_rate_end,Process.FIT_Max_Flow_rate) OTL(Process.FIT_OK) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S98_FIT_Drain" Type="RLL">
<Description>
<![CDATA[Filter Integrity Test]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S98 FIT Drain
Set step timer preset value 300 seconds = 5 minutes
Transition to equalization step, when draining time elapsed or step pressed.]]>
</Comment>
<Text>
<![CDATA[MOVE(300000,Step_timer.PRE)OTL(Process.FIT_automatic_tank_drain);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program transition help bit for moving]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]OTE(Process.Step_ready);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Transition to the Equalization S21]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_ready)[MOVE(21,Process.Step) ,OTU(Process.FIT_automatic_tank_drain) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="S9_Vacuum_hold" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[S9 Vacuum hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,1)[EQ(Pulse_counter,1) MUL(Run.Prec_1_1st_vacuum_hold_time,1000,Step_timer.PRE) ,EQ(Pulse_counter,2) MUL(Run.Prec_1_2nd_vacuum_hold_time,1000,Step_timer.PRE) ,GE(Pulse_counter,3) MUL(Run.Prec_1_3rd_vacuum_hold_time,1000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[S9 Vacuum hold
Set step timer preset values from cycle parameters]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Prec_status,2)[EQ(Pulse_counter,1) MUL(Run.Prec_2_1st_vacuum_hold_time,1000,Step_timer.PRE) ,EQ(Pulse_counter,2) MUL(Run.Prec_2_2nd_vacuum_hold_time,1000,Step_timer.PRE) ,GE(Pulse_counter,3) MUL(Run.Prec_2_3rd_vacuum_hold_time,1000,Step_timer.PRE) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Program transition from Precond 1 to the Precond 2 step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Process.Prec_status,1)EQ(Pulse_counter,Run.Prec_1_Number_of_air_rem_pulses)[EQ(Run.Precond_2_type,2) [XIO(Run.Prec_2_First_pulse_type) MOVE(8,Process.Step) ,XIC(Run.Prec_2_First_pulse_type) MOVE(10,Process.Step) ,CLR(Pulse_counter) MOVE(2,Process.Prec_status) ] ,EQ(Run.Precond_2_type,1) [MOVE(12,Process.Step) ,CLR(Pulse_counter) MOVE(2,Process.Prec_status) ] ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Program transition to the heating up step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Process.Prec_status,1) EQ(Pulse_counter,Run.Prec_1_Number_of_air_rem_pulses) EQ(Run.Precond_2_type,0) ,EQ(Process.Prec_status,2) EQ(Pulse_counter,Run.Prec_2_Number_of_air_rem_pulses) ]MOVE(13,Process.Step);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Program transition to the pressure pulse step]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ]EQ(Process.Step,9)[EQ(Process.Prec_status,1) LT(Pulse_counter,Run.Prec_1_Number_of_air_rem_pulses) ,EQ(Process.Prec_status,2) LT(Pulse_counter,Run.Prec_2_Number_of_air_rem_pulses) ]MOVE(10,Process.Step);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Add pulse counter value]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_timer.DN) ,XIC(Process.Step_pressed) ][EQ(Process.Prec_status,1) XIC(Run.Prec_1_First_pulse_type) ,EQ(Process.Prec_status,2) XIC(Run.Prec_2_First_pulse_type) ]ADD(Pulse_counter,1,Pulse_counter);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Service_cycles" Type="RLL">
<Description>
<![CDATA[Control for Service Cycles]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Service Cycle 1: Enable both doors]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Service_Cycle,1)XIC(HMI.Start_service)XIC(Step_bit[0].2)XIO(Vac_pump_tank_draining_active)[MOVE(1,Process.Service_cycle) ,XIC(DIG_IN[1].18) OTL(Process.Pull_gasket) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Service Cycle 2: Chamber pressure test]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Service_Cycle,2)XIO(Vac_pump_tank_draining_active)[XIC(HMI.Start_service) XIC(Step_bit[0].2) XIC(DIG_IN[1].0) [XIC(DIG_IN[1].16) ,XIO(Option.Double_door) ] [MOVE(2,Process.Service_cycle) ,MOVE(3,Interlock_type_help) ] ,[XIO(DIG_IN[1].0) ,XIO(DIG_IN[1].16) XIC(Option.Double_door) ] CLR(HMI.Service_Cycle) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[User not possible to select Service cycle if process is running]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Running) ,XIC(Vac_pump_tank_draining_active) ]CLR(HMI.Service_Cycle);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Release service cycle]]>
</Comment>
<Text>
<![CDATA[[XIO(HMI.Start_service) ,EQ(HMI.Service_Cycle,0) ]LIMIT(1,Process.Service_cycle,2)[EQ(Process.Service_cycle,2) MOVE(21,Process.Step) ,CLR(HMI.Service_Cycle) OTU(HMI.Start_service) ,NE(Process.Service_cycle,2) CLR(Process.Service_cycle) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Start_control" Type="RLL">
<Description>
<![CDATA[Starting of cycle]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Reset cycle start command]]>
</Comment>
<Text>
<![CDATA[OTU(Process.Cycle_start);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Cycle start command from panel]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Start)[OTU(HMI.Start) ,[XIC(Step_bit[0].3) ,XIC(Step_bit[0].6) ] OTL(Process.Cycle_start) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Process start command]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_bit[0].3) ,XIC(Step_bit[0].6) ]XIC(Process.Cycle_start)[MOVE(Process.Cycle_number,Process.Started_cycle) ,ADD(1,Cycles.Counter,Cycles.Counter) ,[XIC(Option.Tank_LS896) ,XIC(Option.Vac_Pump_Water_Save) ] ADD(1,Vac_pump_tank_drain_cycle_counter,Vac_pump_tank_drain_cycle_counter) ,OTL(Process.Running) ,OTU(E_Sign_Screen) ,OTU(HMI.E_Sign_Approved) ,OTU(HMI.E_Sign_Rejected) ,OTU(FIT_summary_print) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Create Cycle summary when Start command]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_start)FOR(Summary_Line,Line_pointer,28,0,-1)MOVE(Cycles.Counter,Summary[0].Count)COP(time_date,Summary[0].Time,1)MOVE(Process.Cycle_number,Summary[0].Number)COP(Run.Cycle_name,Summary[0].Name,1)COP(Process.batch_ID,Summary[0].Batch,1)COP(User_name,Summary[0].User,1)COP(Pass_txt,Summary[0].Result,1);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Clear cycle summary]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Clear_summary)FOR(Summary_Line,Line_pointer,28,0,-1)COP(Empty_string,Summary[0].Count,1)COP(Empty_string,Summary[0].Time,1)CLR(Summary[0].Number)COP(Empty_string,Summary[0].Name,1)COP(Empty_string,Summary[0].Batch,1)COP(Empty_string,Summary[0].User,1)COP(Empty_string,Summary[0].Result,1);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Process starting disabled number]]>
</Comment>
<Text>
<![CDATA[[CLR(Process.Start_disabled) ,LIMIT(4,Process.Step,1) LIMIT(7,Process.Step,4) RET() ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[1: Jacket temperature too low]]>
</Comment>
<Text>
<![CDATA[[NE(Run.Exposure_type,0) ,[LIMIT(1,Run.Precycle_type,3) ,EQ(Run.Precycle_type,5) ] ]LT(TE518_Jacket.Temperature,Common_set.Jacket_start_min_limit)MOVE(1,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[2: Wrong interlock type]]>
</Comment>
<Text>
<![CDATA[[[XIC(Step_bit[0].2) ,XIC(Step_bit[0].3) ] GE(Run.Interlock_type,4) ,[XIC(Step_bit[0].5) ,XIC(Step_bit[0].6) ] LT(Run.Interlock_type,4) ]MOVE(2,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[3: Spare]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Start_disabled,3)MOVE(3,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[4: NS door open]]>
</Comment>
<Text>
<![CDATA[[XIO(DIG_IN[1].0) ,XIO(DIG_IN[1].1) ]MOVE(4,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[5: ST door open]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Double_door)[XIO(DIG_IN[1].16) ,XIO(DIG_IN[1].17) ]MOVE(5,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[6: Starting disable alarm is active]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Cycle_aborted) ,NE(Alarm_ON[0],0) ,NE(Alarm_ON[1],0) ,NE(Alarm_ON[2],0) ,EQ(HMI.Alarm_banner,1) ]MOVE(6,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[7: No load probe selected (Fo Exposure)]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Exposure_type,2)XIO(Run.Load_1)XIO(Run.Load_2)XIO(Run.Load_3)XIO(Run.Load_4)MOVE(7,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[8: No load probe selected (Overshoot)]]>
</Comment>
<Text>
<![CDATA[XIC(Run.Overshoot_selected)XIO(Run.Load_1)XIO(Run.Load_2)XIO(Run.Load_3)XIO(Run.Load_4)MOVE(8,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[9: No load probe selected (Slow exhaust)]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Postcond_1_type,4) ,EQ(Run.Postcond_2_type,4) ]XIO(Run.Load_1)XIO(Run.Load_2)XIO(Run.Load_3)XIO(Run.Load_4)MOVE(9,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[10: No load probe selected (Cooling)]]>
</Comment>
<Text>
<![CDATA[[EQ(Run.Postcond_1_type,3) ,EQ(Run.Postcond_1_type,6) ,EQ(Run.Postcond_2_type,3) ]XIO(Run.Load_1)XIO(Run.Load_2)XIO(Run.Load_3)XIO(Run.Load_4)MOVE(10,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[10: No load probe selected 
for 10.4.41 VHP Biodec and 10.4.40 VHP Ports]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.VHP_Ports) EQ(Run.Precycle_type,7) ,XIC(Option.VHP_Biodec) EQ(Run.Precycle_type,6) ]NE(Process.Cycle_number,0)XIO(Run.Load_1)XIO(Run.Load_2)XIO(Run.Load_3)XIO(Run.Load_4)MOVE(11,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[12: Jacket draining time not elapsed]]>
</Comment>
<Text>
<![CDATA[GT(HMI.Jacket_drain,0)MOVE(12,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[13: Pressure not ambient]]>
</Comment>
<Text>
<![CDATA[LIMIT(1150,PT549_Chamber.Pressure_mBar,600)MOVE(13,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[14: Cycle is not selected]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Cycle_number,0)MOVE(14,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[15: Air detection temperature too high]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Air_detector)XIC(Run.Air_detec_select)GT(TE520_Air_detect.Temperature,Run.Air_detec_temperature)MOVE(15,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[16: Service cycle is running]]>
</Comment>
<Text>
<![CDATA[NE(HMI.Service_Cycle,0)MOVE(16,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[18: Chamber temperature too high for VHP]]>
</Comment>
<Text>
<![CDATA[NE(Process.Cycle_number,0)EQ(Run.Precycle_type,4)[GT(Load_temp_max,Run.VHP_Chamber_max_temp) ,GT(TE518_Jacket.Temperature,Run.VHP_Chamber_max_temp) ]MOVE(18,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[19: Chamber temperature out of limits
for 10.4.41 VHP Biodec and 10.4.40 VHP Ports]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.VHP_Biodec) ,XIC(Option.VHP_Ports) ]NE(Process.Cycle_number,0)[EQ(Run.Precycle_type,6) ,EQ(Run.Precycle_type,7) ][GT(Load_temp_max,40) ,LT(Load_temp_min,16) ]MOVE(19,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[20: VHP Generator not ready 10.4.41 VHP Biodec]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Biodec)XIO(DIG_IN[0].11)NE(Process.Cycle_number,0)EQ(Run.Precycle_type,6)MOVE(20,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[21: VHP Hose not connected 10.4.41 VHP Biodec]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Biodec)[XIO(DIG_IN[1].14) ,XIO(DIG_IN[1].23) ]NE(Process.Cycle_number,0)EQ(Run.Precycle_type,6)MOVE(21,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[22: VHP Valve not in proper position 10.4.41 VHP Biodec]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Biodec)[XIC(DIG_IN[1].6) ,XIC(DIG_IN[1].22) ,XIO(DIG_IN[1].21) ]NE(Process.Cycle_number,0)EQ(Run.Precycle_type,6)MOVE(22,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[23: Vacuum pump circulation tank draining active]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Tank_LS896) ,XIC(Option.Vac_Pump_Water_Save) ]XIC(Vac_pump_tank_draining_active)MOVE(23,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Comment>
<![CDATA[24: Door unsealing active]]>
</Comment>
<Text>
<![CDATA[XIO(Vac_pump_tank_draining_active)XIC(Process.Pull_gasket)MOVE(24,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Comment>
<![CDATA[26. EN285 Recorder not connected]]>
</Comment>
<Text>
<![CDATA[XIC(Option.EN285_monitoring)NE(\IO_Control.Recorder_status,16384)MOVE(26,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Comment>
<![CDATA[27: Service HMI enabled]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.ServiceHMI)MOVE(27,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Comment>
<![CDATA[28: Surrounding temperature too high for FIT]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,10)[GT(TE1018_Filter_FIT.Temperature,Common_set.FIT_Max_surround_temp) ,GT(TE517_Chamber.Temperature,Common_set.FIT_Max_surround_temp) ,GT(TE518_Jacket.Temperature,Common_set.FIT_Max_surround_temp) ]MOVE(28,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Comment>
<![CDATA[29: Temperature of test water too low for FIT]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,10)LT(TE1018_2_FIT_Water_Tank.Temperature,Common_set.FIT_Min_test_water_temp)MOVE(29,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Comment>
<![CDATA[30: Temperature of test water too high for FIT]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,10)GT(TE1018_2_FIT_Water_Tank.Temperature,Common_set.FIT_Max_test_water_temp)MOVE(30,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Comment>
<![CDATA[31: FIT Water draining]]>
</Comment>
<Text>
<![CDATA[XIC(Process.FIT_manual_tank_drain)MOVE(31,Process.Start_disabled);]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Comment>
<![CDATA[Move disable reason number for panel variable]]>
</Comment>
<Text>
<![CDATA[MOVE(Process.Start_disabled,HMI.Start_disable);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_Phase_status" Type="RLL">
<Description>
<![CDATA[Step bits convert
and phase number]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set phase number according current step]]>
</Comment>
<Text>
<![CDATA[[LT(Process.Step,33) MOVE(Phase_table[Process.Step],Process.Phase_number) ,EQ(Process.Prec_status,1) GT(Process.Step,1) MOVE(5,Process.Phase_number) ,EQ(Process.Prec_status,2) GT(Process.Step,1) MOVE(6,Process.Phase_number) ,EQ(Process.Step,82) MOVE(8,Process.Phase_number) ,EQ(Process.Postc_status,1) GT(Process.Step,1) MOVE(9,Process.Phase_number) ,EQ(Process.Postc_status,2) GT(Process.Step,1) MOVE(10,Process.Phase_number) ,LIMIT(33,Process.Step,35) EQ(Run.Precycle_type,2) MOVE(13,Process.Phase_number) ,LIMIT(33,Process.Step,35) EQ(Run.Precycle_type,1) MOVE(14,Process.Phase_number) ,LIMIT(40,Process.Step,42) EQ(Run.Precycle_type,3) MOVE(15,Process.Phase_number) ,XIC(Process.B_cycle_abort) MOVE(16,Process.Phase_number) ,EQ(Run.Exposure_type,4) [EQ(Process.Step,14) MOVE(17,Process.Phase_number) ,EQ(Process.Step,15) MOVE(18,Process.Phase_number) ] ,XIC(Step_bit[1].12) MOVE(19,Process.Phase_number) ,LIMIT(60,Process.Step,63) MOVE(20,Process.Phase_number) ,EQ(Process.Step,64) MOVE(21,Process.Phase_number) ,EQ(Process.Step,65) MOVE(22,Process.Phase_number) ,[EQ(Process.Step,66) ,EQ(Process.Step,68) ] MOVE(23,Process.Phase_number) ,EQ(Process.Step,67) MOVE(24,Process.Phase_number) ,XIC(Option.FIT_Test) LIMIT(94,Process.Step,98) MOVE(25,Process.Phase_number) ,XIC(Option.FIT_Test) LIMIT(89,Process.Step,90) MOVE(26,Process.Phase_number) ,XIC(Option.FIT_Test) LIMIT(91,Process.Step,92) MOVE(27,Process.Phase_number) ,MOVE(Process.Phase_number,HMI.Phase) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Step to bit]]>
</Comment>
<Text>
<![CDATA[[LE(Process.Step,31) [LE(Process.Step,30) CPT(Step_bit[0],2**Process.Step) ,EQ(Process.Step,31) MOVE(-2147483648,Step_bit[0]) ,FLL(0,Step_bit[1],3) ] ,LIMIT(32,Process.Step,63) [LE(Process.Step,62) CPT(Step_bit[1],2**(Process.Step-32)) ,EQ(Process.Step,63) MOVE(-2147483648,Step_bit[1]) ,CLR(Step_bit[0]) CLR(Step_bit[2]) CLR(Step_bit[3]) ] ,LIMIT(64,Process.Step,95) [LE(Process.Step,95) CPT(Step_bit[2],2**(Process.Step-64)) ,EQ(Process.Step,95) MOVE(-2147483648,Step_bit[2]) ,FLL(0,Step_bit[0],2) CLR(Step_bit[3]) ] ,LIMIT(96,Process.Step,127) [[NE(Process.Step,127) CPT(Step_bit[3],2**(Process.Step-96)) ,EQ(Process.Step,127) MOVE(-2147483648,Step_bit[3]) ] ,FLL(0,Step_bit[0],3) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Summary_Line" Type="RLL">
<Description>
<![CDATA[Cycle summary data]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Move summary data forward and make space for new data]]>
</Comment>
<Text>
<![CDATA[SBR()[ADD(Line_pointer,1,Next_line) COP(Summary[Line_pointer],Summary[Next_line],1) ,RET() ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Time_control" Type="RLL">
<Description>
<![CDATA[Time control]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set time from Service screen]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Set_time)[MOVE(HMI.Set_Year,Date_time[0]) ,MOVE(HMI.Set_Month,Date_time[1]) ,MOVE(HMI.Set_Day,Date_time[2]) ,MOVE(HMI.Set_Hour,Date_time[3]) ,MOVE(HMI.Set_Minute,Date_time[4]) ,MOVE(HMI.Set_Second,Date_time[5]) ,SSV(WallClockTime,,LocalDateTime,Date_time[0]) ,OTU(HMI.Set_time) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Read time from CPU system clock]]>
</Comment>
<Text>
<![CDATA[XIO(HMI.Set_time)GSV(WallClockTime,,LocalDateTime,Date_time[0]);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Leap year check]]>
</Comment>
<Text>
<![CDATA[[MOD(Date_time[0],4,YearChk[0]) ,MOD(Date_time[0],100,YearChk[1]) ,MOD(Date_time[0],400,YearChk[2]) ]EQ(YearChk[0],0)[NE(YearChk[1],0) ,EQ(YearChk[2],0) ]OTE(YearChk[3].0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Calculate number of days from beginning of the year]]>
</Comment>
<Text>
<![CDATA[MOVE(Date_time[1],Month)MOVE(Month_Days[Month],Month_Days[0])[ADD(Month_Days[0],Date_time[2],Month_Days[0]) ,XIC(YearChk[3].0) ADD(Month_Days[0],1,Month_Days[0]) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Calculate seconds from beginning of the year]]>
</Comment>
<Text>
<![CDATA[CPT(Current_time,Date_time[5]+(Date_time[4]*60)+(Date_time[3]*3600)+(Month_Days[0]*86400));]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Copy time for power brake time calculation]]>
</Comment>
<Text>
<![CDATA[XIO(S:FS)EQ(Process.Power_brake_status,0)MOVE(Current_time,Date_Time_memory);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[1 sec pulse for calculations]]>
</Comment>
<Text>
<![CDATA[NE(Date_time[5],S_pulse_help)[OTE(Process.S_pulse) ,MOVE(Date_time[5],S_pulse_help) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Disclaimer - All information provided  -- No warranty or implied merchantability.
Refer to the RSLogix 5000 End User License Agreement (EULA) in the Release Notes.

This AOI_SNTP_QUERY instruction retrieves the current time from a NTP (Network Time Protocol) server and returns the date to SNTP_Time_Retrieved and optionally the controller's clock as well.

Update "SNTP_SERVER_ADDRESS" tag with <IP address> or <Hostname> of the NTP server.
Examples "2.pool.ntp.org" , "192.168.1.1"

Fill in Query_Interval_in_Min with the number of minutes to periodocally update between successful queries. 0 disables query.
Fill in Query_Error_in_Min with the number fo minutes to retry after an error.
Fill in the Sync_Controller_Clock with a 1 to automatically update controller clock, 0 otherwise.
Next_Query_in_Min will display minutes remaining before the next update.


IMPORTANT! Set the Enable instruction to a 1 to enable the instruction. Set Trigger Update Now if an immediate update is desired (Enable_Instruction must also be set).
Set Sync controller clock to have the controllers clock updated by the instruction at the time of a query.

Note: 1440 minutes = 1 day.]]>
</Comment>
<Text>
<![CDATA[XIO(Process.Running)AOI_SNTP_QUERY(SNTP_AOI_TAG,SNTP_TIME_RETRIEVED,SNTP_SERVER_ADDRESS,SNTP_MSG_DATA,SNTP_MSG_CREATE,SNTP_MSG_OPEN,SNTP_MSG_WRITE,SNTP_MSG_READ,SNTP_MSG_DELETE);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[============================================================
T_DST:  TIME -- DAYLIGHT SAVING TIME
============================================================
Revision 1.0-00 - Release: 2009-09-04
Initial Release
============================================================
This instruction manages Daylight Saving Time.  It uses a number of configuration
values to allow handling a wide variety of national and regional rules for
when to start and end Daylight Saving Time (or "Summer Time").
For use with HMI, it also provides Values for display of the Month/Day
and Hour:Minute of the points in time when DST starts and ends.
Plus, for logging logic, it provides bits to indicate when timestamps might
have an Overlap (1:30 a.m. happens twice) or there is a Gap (one-shot).

For best results:
1.  Clear  Cfg_Enable  to 0.
2.  Open the Controller Properties, clear the DST checkbox
and set the clock to local STANDARD time
3.  Configure the T_DST instruction per the items below.
4.  Set the  Cfg_Enable  bit to 1.
The clock will be switched to DST based on the rules entered
if DST is currently in effect for your location.

Configuration:
Cfg_FwdMo: Month specified in rule for Date at which to spring forward (1..12)	
Cfg_FwdOccur: Occurence of Day of Week to spring forward 1=1st, 2=2nd, .. 5=last	
Cfg_FwdDoW: Day of the week on which to spring forward (0=Sun..6=Sat)	
Cfg_FwdDoM: Day of month for spring forward if on a fixed date (1..31)	
Cfg_FwdDoWBefore: Day of the week BEFORE the 1st..last Day of Week or Date (0=Sun..6=Sat)	
Cfg_FwdHr: Hour (LOCAL) at which to spring forward (0..23)	
Cfg_FwdMin: Minute (LOCAL) at which to spring forward (0..59)	
Cfg_FwdFixedDate: 1=Spring forward on fixed date, 0=on occurrence of Day of Week
Cfg_FwdUseBefore: 1=Spring forward on Day of Week BEFORE date or day of week	

Cfg_BackMo: Month specified in rule for Date at which to fall back (1..12)	
Cfg_BackOccur: Occurence of Day of Week to fall back 1=1st, 2=2nd, .. 5=last	
Cfg_BackDoW: Day of the week on which to fall bacj (0=Sun..6=Sat)	
Cfg_BackDoM: Day of month for fall back if on a fixed date (1..31)	
Cfg_BackDoWBefore: Day of the week BEFORE the 1st..last Day of Week or Date (0=Sun..6=Sat)	
Cfg_BackHr: Hour (LOCAL) at which to fall back (0..23)	
Cfg_BackMin: Minute (LOCAL) at which to fall back (0..59)	
Cfg_BackFixedDate: 1=Fall back on fixed date, 0=on occurrence of Day of Week
Cfg_BackUseBefore: 1=Fall back on Day of Week BEFORE date or day of week	

Cfg_Offset: Number of minutes to spring forward or fall back (0..1439, def=60)	
Cfg_EnableDSTL 1=Automatically adjust clock for DST, 0=Always Standard Time, no DST
============================================================
POWERUP / INVALID STATE HANDLING
============================================================
None required.  This instruction calculates whether we are in DST
each scan based on current clock and ruleset.
(The only time this doesn't work is during the overlap at the
fall back to Standard Time.)

============================================================
CHECK CONFIGURATION DATA FOR ERRORS
============================================================
This rung checks the configuration data for validity based on the
ranges shown in the summary above.

If any configuration item is not valid, skip the rest of the logic and exit
showing the bad config status.]]>
</Comment>
<Text>
<![CDATA[T_DST(DST_AOI_TAG);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Tmin_Tmax" Type="RLL">
<Description>
<![CDATA[Load temp min and max]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Load temperature min and max calculation]]>
</Comment>
<Text>
<![CDATA[[CLR(Load_temp_max) ,MOVE(150,Load_temp_min) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Load 1 compare]]>
</Comment>
<Text>
<![CDATA[XIC(Run.Load_1)XIO(TE788_1_Load1.out_of_range)[LE(TE788_1_Load1.Temperature,Load_temp_min) MOVE(TE788_1_Load1.Temperature,Load_temp_min) ,GE(TE788_1_Load1.Temperature,Load_temp_max) MOVE(TE788_1_Load1.Temperature,Load_temp_max) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Load 2 compare]]>
</Comment>
<Text>
<![CDATA[XIC(Run.Load_2)XIO(TE788_2_Load2.out_of_range)[LE(TE788_2_Load2.Temperature,Load_temp_min) MOVE(TE788_2_Load2.Temperature,Load_temp_min) ,GE(TE788_2_Load2.Temperature,Load_temp_max) MOVE(TE788_2_Load2.Temperature,Load_temp_max) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Load 3 compare]]>
</Comment>
<Text>
<![CDATA[XIC(Run.Load_3)XIO(TE788_3_Load3.out_of_range)[LE(TE788_3_Load3.Temperature,Load_temp_min) MOVE(TE788_3_Load3.Temperature,Load_temp_min) ,GE(TE788_3_Load3.Temperature,Load_temp_max) MOVE(TE788_3_Load3.Temperature,Load_temp_max) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Load 4 compare]]>
</Comment>
<Text>
<![CDATA[XIC(Run.Load_4)XIO(TE788_4_Load4.out_of_range)[LE(TE788_4_Load4.Temperature,Load_temp_min) MOVE(TE788_4_Load4.Temperature,Load_temp_min) ,GE(TE788_4_Load4.Temperature,Load_temp_max) MOVE(TE788_4_Load4.Temperature,Load_temp_max) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[All load probes out-of-range or not valid]]>
</Comment>
<Text>
<![CDATA[[XIC(TE788_1_Load1.out_of_range) ,XIO(Run.Load_1) ][XIC(TE788_2_Load2.out_of_range) ,XIO(Run.Load_2) ][XIC(TE788_3_Load3.out_of_range) ,XIO(Run.Load_3) ][XIC(TE788_4_Load4.out_of_range) ,XIO(Run.Load_4) ][LIMIT(25,Process.Step,21) [MOVE(TE517_Chamber.Temperature,Load_temp_min) ,MOVE(TE517_Chamber.Temperature,Load_temp_max) ] ,EQ(Run.Precond_1_type,3) [XIO(Option.DecV_process) [MOVE(TE517_2_DEC.Temperature,Load_temp_min) ,MOVE(TE517_2_DEC.Temperature,Load_temp_max) ] ,XIC(Option.DecV_process) [MOVE(TE517_Chamber.Temperature,Load_temp_min) ,MOVE(TE517_Chamber.Temperature,Load_temp_max) ] ] ,[EQ(Run.Precond_1_type,4) ,EQ(Run.Postcond_1_type,6) ] [MOVE(SAMX_Control_temperature,Load_temp_min) ,MOVE(SAMX_Control_temperature,Load_temp_max) ] ,OTE(Process.Probes_fail) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Move values for PID process control]]>
</Comment>
<Text>
<![CDATA[MOVE(Load_temp_min,Load_temp_min_PID)MOVE(Load_temp_max,Load_temp_max_PID);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
