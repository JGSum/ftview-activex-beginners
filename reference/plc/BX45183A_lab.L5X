<Routine Name="HMI_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[JSR(Screen_control,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[JSR(View_Cycle,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Screen_control" Type="RLL">
<Description>
<![CDATA[Screen changes from PLC
and button control]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Step button visible control]]>
</Comment>
<Text>
<![CDATA[[LIMIT(8,Process.Step,19) ,LIMIT(33,Process.Step,38) ,LIMIT(40,Process.Step,41) ,EQ(Process.Step,44) ,LIMIT(54,Process.Step,57) ,LIMIT(81,Process.Step,82) ,LIMIT(60,Process.Step,65) ,EQ(Process.Step,68) ,LIMIT(89,Process.Step,97) ]OTE(HMI.Step_active);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[When step button is pressed make trigger for step transition]]>
</Comment>
<Text>
<![CDATA[[OTU(Process.Step_pressed) ,XIO(Step_Button_timer.TT) XIC(HMI.Step_pressed) [OTL(Process.Step_pressed) ,TOF(Step_Button_timer,?,?) ] ,OTU(HMI.Step_pressed) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Alarm banner control bit for panel]]>
</Comment>
<Text>
<![CDATA[EQ(Alarm_ACT[0],0)EQ(Alarm_ACT[1],0)EQ(Alarm_ACT[2],0)EQ(Process.Power_brake_status,0)[EQ(HMI.Alarm_banner,1) ,EQ(HMI.Alarm_banner,2) ]CLR(HMI.Alarm_banner);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Change Run Mode and screen 10 if Power failure alarm is activated]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Power_brake_status,2)[MOVE(10,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[When power brake is between 60 s and 30 min wait user response]]>
</Comment>
<Text>
<![CDATA[[EQ(Process.Power_brake_status,2) ,XIC(Process.Running_and_estop_released) ][XIC(HMI.Abort) OTL(Process.Cycle_aborted) ,XIC(HMI.Continue) ,XIC(E_Sign_Screen) ][MOVE(Process.Step_memory,Process.Step) ,CLR(Process.Power_brake_status) ,[[EQ(Process.Step,26) XIC(DIG_IN[1].16) ,EQ(Process.Step,30) XIC(DIG_IN[1].0) ] XIO(Process.Pull_gasket) OTL(Process.Pull_gasket) ,OTU(Process.Running_and_estop_released) ] ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Force E-signatue screen after cycle]]>
</Comment>
<Text>
<![CDATA[[[EQ(Process.Step,30) ,EQ(Process.Step,26) ] XIC(DIG_IN[0].2) XIO(HMI.E_Sign_Approved) XIO(HMI.E_Sign_Rejected) XIO(E_Sign_Screen) OTL(E_Sign_Screen) ,XIO(HMI.E_Sign_Approved) XIO(HMI.E_Sign_Rejected) XIC(E_Sign_Screen) XIC(DIG_IN[0].2) [MOVE(100,HMI.Force_NS) ,OTL(HMI.Force_On_NS) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="View_Cycle" Type="RLL">
<Description>
<![CDATA[Screen control
when phase button pressed]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[View parameters from run mode]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.View_Precycle)[EQ(Run.Precycle_type,1) MOVE(500,HMI.Force_NS) ,EQ(Run.Precycle_type,2) [MOVE(502,HMI.Force_NS) ,XIC(Option.Press_unit) CLR(HMI.View_LRT_help) ,XIO(Option.Press_unit) MOVE(1,HMI.View_LRT_help) ] ,EQ(Run.Precycle_type,3) MOVE(506,HMI.Force_NS) ,EQ(Run.Precycle_type,4) MOVE(503,HMI.Force_NS) ,EQ(Run.Precycle_type,5) MOVE(504,HMI.Force_NS) ,EQ(Run.Precycle_type,6) MOVE(505,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[View parameters from run mode]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.View_Precond1)[EQ(Run.Precond_1_type,1) MOVE(510,HMI.Force_NS) ,EQ(Run.Precond_1_type,2) MOVE(511,HMI.Force_NS) ,EQ(Run.Precond_1_type,3) [XIO(Option.DecV_process) MOVE(512,HMI.Force_NS) ,XIC(Option.DecV_process) MOVE(514,HMI.Force_NS) ] ,EQ(Run.Precond_1_type,4) [XIC(Option.Press_unit) MOVE(513,HMI.Force_NS) ,XIO(Option.Press_unit) MOVE(5130,HMI.Force_NS) ] ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[View parameters from run mode]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.View_Precond2)[EQ(Run.Precond_2_type,1) MOVE(510,HMI.Force_NS) ,EQ(Run.Precond_2_type,2) MOVE(521,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[View parameters from run mode]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.View_Exposure)[EQ(Run.Exposure_type,1) MOVE(540,HMI.Force_NS) ,EQ(Run.Exposure_type,2) MOVE(541,HMI.Force_NS) ,EQ(Run.Exposure_type,4) MOVE(543,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[View parameters from run mode]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.View_Postcond1)[EQ(Run.Postcond_1_type,1) MOVE(550,HMI.Force_NS) ,EQ(Run.Postcond_1_type,2) MOVE(551,HMI.Force_NS) ,EQ(Run.Postcond_1_type,3) MOVE(552,HMI.Force_NS) ,EQ(Run.Postcond_1_type,4) MOVE(553,HMI.Force_NS) ,EQ(Run.Postcond_1_type,5) MOVE(551,HMI.Force_NS) ,EQ(Run.Postcond_1_type,6) MOVE(5542,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[View SAMX cooling curve parameters from run mode when Cooling Curve button is pressed in screen 5542 SAMX Cooling]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Sel_SAMX_Cooling_Curve)[XIC(Option.Press_unit) MOVE(5540,HMI.Force_NS) ,XIO(Option.Press_unit) MOVE(5541,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[View parameters from run mode]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.View_Postcond2)[EQ(Run.Postcond_2_type,1) MOVE(560,HMI.Force_NS) ,EQ(Run.Postcond_2_type,2) MOVE(561,HMI.Force_NS) ,EQ(Run.Postcond_2_type,3) MOVE(552,HMI.Force_NS) ,EQ(Run.Postcond_2_type,5) MOVE(561,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Previous from view Slow Exhaust or Cooling screen]]>
</Comment>
<Text>
<![CDATA[[XIC(HMI.Previous552) ,XIC(HMI.Previous553) ]MOVE(45,HMI.Force_NS);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
