<Routines>
<Routine Name="Comm_WatchDog" Type="RLL">
<Description>
<![CDATA[SCADA Handshake]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[SCADA handshake timer]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SCADA_Handshake)XIC(Common_set.SCADA_handshake)GT(Process.Step,1)EQ(DINT_from_SCADA[8],0)[EQ(DINT_from_SCADA[8],Heartbeat_last_second) TON(Comm_timer,?,?) ,MOVE(DINT_from_SCADA[8],Heartbeat_last_second) ,XIC(Comm_timer.DN) OTE(Process.SCADA_alarm) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[NE(DINT_from_SCADA[8],0)CLR(DINT_from_SCADA[8]);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Data_from_SCADA" Type="RLL">
<Description>
<![CDATA[Data from SCADA system]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set time from SCADA]]>
</Comment>
<Text>
<![CDATA[XIC(DINT_from_SCADA[7].0)[COP(DINT_from_SCADA[0],Date_time[0],6) ,SSV(WallClockTime,?,DateTime,Date_time[0]) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Data_to_SCADA" Type="RLL">
<Description>
<![CDATA[Data to SCADA system]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Date and time for SCADA]]>
</Comment>
<Text>
<![CDATA[COP(Date_time[0],DINT_to_SCADA[0],6);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Digital IO-data for SCADA]]>
</Comment>
<Text>
<![CDATA[[COP(DIG_IN[0],DINT_to_SCADA[8],2) ,COP(DIG_OUT[0],DINT_to_SCADA[10],2) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Cycle status bits for SCADA]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Running) OTE(DINT_to_SCADA[15].0) ,XIC(DIG_IN[1].0) OTE(DINT_to_SCADA[15].1) ,XIC(DIG_IN[1].1) OTE(DINT_to_SCADA[15].2) ,XIC(DIG_IN[1].2) OTE(DINT_to_SCADA[15].3) ,XIC(Option.Double_door) XIC(DIG_IN[1].16) OTE(DINT_to_SCADA[15].4) ,XIC(Option.Double_door) XIC(DIG_IN[1].17) OTE(DINT_to_SCADA[15].5) ,XIC(Option.Double_door) XIC(DIG_IN[1].18) OTE(DINT_to_SCADA[15].6) ,XIC(Process.Doors_locked) OTE(DINT_to_SCADA[15].7) ,XIC(DIG_OUT[0].3) OTE(DINT_to_SCADA[15].8) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Cycle number for SCADA]]>
</Comment>
<Text>
<![CDATA[MOVE(Process.Cycle_number,DINT_to_SCADA[16]);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Cycle step for SCADA]]>
</Comment>
<Text>
<![CDATA[MOVE(Process.Step,DINT_to_SCADA[17]);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Remaining step time for SCADA]]>
</Comment>
<Text>
<![CDATA[[MOVE(Process.Remaining_minutes,DINT_to_SCADA[18]) ,MOVE(Process.Remaining_seconds,DINT_to_SCADA[19]) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Alarms for SCADA]]>
</Comment>
<Text>
<![CDATA[COP(Alarm_ACT[0],DINT_to_SCADA[20],3);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[AI Measurement data for SCADA]]>
</Comment>
<Text>
<![CDATA[[MOVE(PT549_Chamber.Pressure_mBar,REAL_to_SCADA[0]) ,MOVE(PT549_Chamber_Pressure_Psia,REAL_to_SCADA[1]) ,MOVE(TE517_Chamber.Temperature,REAL_to_SCADA[2]) ,MOVE(TE518_Jacket.Temperature,REAL_to_SCADA[3]) ,XIC(Option.Filter_ster) MOVE(TE517_1_Filter.Temperature,REAL_to_SCADA[4]) ,XIC(Option.Load_1) MOVE(TE788_1_Load1.Temperature,REAL_to_SCADA[5]) ,XIC(Option.Load_2) MOVE(TE788_2_Load2.Temperature,REAL_to_SCADA[6]) ,XIC(Option.Load_3) MOVE(TE788_3_Load3.Temperature,REAL_to_SCADA[7]) ,XIC(Option.Load_4) MOVE(TE788_4_Load4.Temperature,REAL_to_SCADA[8]) ,XIC(Option.Air_detector) MOVE(TE520_Air_detect.Temperature,REAL_to_SCADA[9]) ,XIC(Option.DEC_process) [XIO(Option.DecV_process) MOVE(TE517_2_DEC.Temperature,REAL_to_SCADA[10]) ,XIC(Option.DecV_process) MOVE(VIRASURE_Temperature,REAL_to_SCADA[10]) ] ,XIC(Option.SAMX_process) MOVE(TE517_3_Chamber.Temperature,REAL_to_SCADA[17]) ,XIC(Option.SAMX_process) MOVE(TE517_4_Chamber.Temperature,REAL_to_SCADA[18]) ,XIC(Option.Vac_Pump_Water_Save) MOVE(TE525_Water_tank.Temperature,REAL_to_SCADA[19]) ,XIC(Option.SAMX_process) MOVE(PCV119_Out,REAL_to_SCADA[20]) ,XIC(Option.DecV_process) MOVE(TE527_2_VIRASURE.Temperature,REAL_to_SCADA[21]) ,XIC(Option.DecV_process) MOVE(TE527_3_VIRASURE.Temperature,REAL_to_SCADA[22]) ,XIC(Option.EN285_monitoring) [MOVE(PT550_pressure_mbar,REAL_to_SCADA[23]) ,MOVE(PT550_pressure_psia,REAL_to_SCADA[24]) ,MOVE(EN285_press_diff_mbar,REAL_to_SCADA[25]) ,MOVE(EN285_press_diff_psia,REAL_to_SCADA[26]) ,MOVE(TE798_1_temperature,REAL_to_SCADA[27]) ,MOVE(EN285_temp_diff,REAL_to_SCADA[28]) ] ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Process setpoints for SCADA]]>
</Comment>
<Text>
<![CDATA[[MOVE(Step_pressure_setpoint,REAL_to_SCADA[11]) ,MOVE(Step_temperature_setpoint,REAL_to_SCADA[12]) ,MUL(Step_pressure_setpoint,0.145,REAL_to_SCADA[13]) ,MOVE(FO_value[7],REAL_to_SCADA[14]) ,MOVE(FO_value[6],REAL_to_SCADA[15]) ,MOVE(FO_value[0],REAL_to_SCADA[16]) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Common text data for SCADA]]>
</Comment>
<Text>
<![CDATA[[COP(Common_set.Customer,TEXT_to_SCADA[0],1) ,COP(Common_set.Model,TEXT_to_SCADA[1],1) ,COP(Common_set.Serial_Number,TEXT_to_SCADA[2],1) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[User data for SCADA]]>
</Comment>
<Text>
<![CDATA[COP(User_name,TEXT_to_SCADA[3],1);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Cycle data for SCADA]]>
</Comment>
<Text>
<![CDATA[[COP(Run.Cycle_name,TEXT_to_SCADA[4],1) ,COP(Process.batch_ID,TEXT_to_SCADA[5],1) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Scada_main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[JSR(Data_from_SCADA,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
