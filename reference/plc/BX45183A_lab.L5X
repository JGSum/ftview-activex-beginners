<Rung Number="0" Type="N">
<Comment>
<![CDATA[Chamber Pressure PT549]]>
</Comment>
<Text>
<![CDATA[[BTD(U784:I.Data[2],0,A_In_Raw[0],0,8) BTD(U784:I.Data[3],0,A_In_Raw[0],8,8) MOVE(A_In_Raw[0],PT549_Chamber.Input_raw) DIV(A_In_Raw[0],1000,PT549_Scaled_mA) ,XIO(Option.Test_AI) XIO(PT549_Chamber.out_of_range) JSR(AI_scaling,5,PT549_Chamber.Input_raw,PT549_Chamber.In_raw_min,PT549_Chamber.In_raw_max,PT549_Chamber.Scale_value_min,PT549_Chamber.Scale_value_max,PT549_Chamber.Pressure_mBar) ,XIO(Option.Test_AI) LIMIT(20000,PT549_Chamber.Input_raw,4000) OTE(PT549_Chamber.out_of_range) ,MUL(PT549_Chamber.Pressure_mBar,0.0145,PT549_Chamber_Pressure_Psia) ,[XIO(Option.Press_unit) XIO(PT549_Chamber.out_of_range) MOVE(0,HMI.PT549_Control) ,XIC(Option.Press_unit) XIO(PT549_Chamber.out_of_range) MOVE(1,HMI.PT549_Control) ,XIC(PT549_Chamber.out_of_range) MOVE(3,HMI.PT549_Control) ] ];]]>
</Text>
