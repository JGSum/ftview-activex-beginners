</Comment>
<Text>
<![CDATA[XIC(Option.Vac_Pump_Water_Save)XIO(Option.Load_2)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[13],Text.low_point,TE525_Water_tank.Calib_low_time,TE525_Water_tank.Calib_low_user,TE525_Water_tank.Scale_value_min,TE525_Water_tank.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE525_Water_tank.Calib_high_time,TE525_Water_tank.Calib_high_user,TE525_Water_tank.Scale_value_max,TE525_Water_tank.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Load 3 temperature calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Load_3)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[6],Text.low_point,TE788_3_Load3.Calib_low_time,TE788_3_Load3.Calib_low_user,TE788_3_Load3.Scale_value_min,TE788_3_Load3.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE788_3_Load3.Calib_high_time,TE788_3_Load3.Calib_high_user,TE788_3_Load3.Scale_value_max,TE788_3_Load3.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Load 4 temperature calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Load_4)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[7],Text.low_point,TE788_4_Load4.Calib_low_time,TE788_4_Load4.Calib_low_user,TE788_4_Load4.Scale_value_min,TE788_4_Load4.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE788_4_Load4.Calib_high_time,TE788_4_Load4.Calib_high_user,TE788_4_Load4.Scale_value_max,TE788_4_Load4.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[DEC filter temperature calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DEC_process)XIO(Option.DecV_process)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[9],Text.low_point,TE517_2_DEC.Calib_low_time,TE517_2_DEC.Calib_low_user,TE517_2_DEC.Scale_value_min,TE517_2_DEC.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE517_2_DEC.Calib_high_time,TE517_2_DEC.Calib_high_user,TE517_2_DEC.Scale_value_max,TE517_2_DEC.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[Air detection temperature calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Air_detector)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[10],Text.low_point,TE520_Air_detect.Calib_low_time,TE520_Air_detect.Calib_low_user,TE520_Air_detect.Scale_value_min,TE520_Air_detect.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE520_Air_detect.Calib_high_time,TE520_Air_detect.Calib_high_user,TE520_Air_detect.Scale_value_max,TE520_Air_detect.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[FIT Water Tank Sanitization temperature]]>
</Comment>
<Text>
<![CDATA[ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[11],Text.low_point,TE1018_2_FIT_Water_Tank.Calib_low_time,TE1018_2_FIT_Water_Tank.Calib_low_user,TE1018_2_FIT_Water_Tank.Scale_value_min,TE1018_2_FIT_Water_Tank.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE1018_2_FIT_Water_Tank.Calib_high_time,TE1018_2_FIT_Water_Tank.Calib_high_user,TE1018_2_FIT_Water_Tank.Scale_value_max,TE1018_2_FIT_Water_Tank.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[Air Filter Assembly Temperature]]>
</Comment>
<Text>
<![CDATA[ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[12],Text.low_point,TE1018_Filter_FIT.Calib_low_time,TE1018_Filter_FIT.Calib_low_user,TE1018_Filter_FIT.Scale_value_min,TE1018_Filter_FIT.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE1018_Filter_FIT.Calib_high_time,TE1018_Filter_FIT.Calib_high_user,TE1018_Filter_FIT.Scale_value_max,TE1018_Filter_FIT.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[FIT Water Tank Sanitization temperature]]>
</Comment>
<Text>
<![CDATA[ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[13],Text.low_point,TE517_5_FIT_Sanitization.Calib_low_time,TE517_5_FIT_Sanitization.Calib_low_user,TE517_5_FIT_Sanitization.Scale_value_min,TE517_5_FIT_Sanitization.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE517_5_FIT_Sanitization.Calib_high_time,TE517_5_FIT_Sanitization.Calib_high_user,TE517_5_FIT_Sanitization.Scale_value_max,TE517_5_FIT_Sanitization.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[DEC VIRASURE temperature 1 calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DecV_process)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[14],Text.low_point,TE527_2_VIRASURE.Calib_low_time,TE527_2_VIRASURE.Calib_low_user,TE527_2_VIRASURE.Scale_value_min,TE527_2_VIRASURE.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE527_2_VIRASURE.Calib_high_time,TE527_2_VIRASURE.Calib_high_user,TE527_2_VIRASURE.Scale_value_max,TE527_2_VIRASURE.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[DEC VIRASURE temperature 2 calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DecV_process)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[15],Text.low_point,TE527_3_VIRASURE.Calib_low_time,TE527_3_VIRASURE.Calib_low_user,TE527_3_VIRASURE.Scale_value_min,TE527_3_VIRASURE.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE527_3_VIRASURE.Calib_high_time,TE527_3_VIRASURE.Calib_high_user,TE527_3_VIRASURE.Scale_value_max,TE527_3_VIRASURE.Previous_calib_max) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Pressure_table" Type="RLL">
<Description>
<![CDATA[SAMX heating / cooling table]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[SAMX temp / pressure table
Point number: xx]]>
</Comment>
<Text>
<![CDATA[SBR()DTOS(Point,prm_string)CONCAT(prm_string,Help_char[0],Prm_text);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[SAMX  temp / pressure table
Temperature: xx]]>
</Comment>
<Text>
<![CDATA[CONCAT(Prm_text,Text.AC_temp,Prm_text)[XIC(AC_precond) MOVE(Run.Precond_temp[Point],prm_real) ,XIO(AC_precond) MOVE(Run.Postcond_temp[Point],prm_real) ]JSR(Real_to_String,3,1,Prm_text,prm_real);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[SAMX temp / pressure table
Pressure (kPa) : xx]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Press_unit)DTOS(Point,prm_string)CONCAT(prm_string,Help_char[0],Prm_text)CONCAT(Prm_text,Text.AC_press,Prm_text)[XIC(AC_precond) MOVE(Run.Precond_press[Point],prm_real) ,XIO(AC_precond) MOVE(Run.Postcond_press[Point],prm_real) ]JSR(Real_to_String,3,2,Prm_text,prm_real);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[SAMX temp / pressure table
Pressure  (Psia) : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Press_unit)DTOS(Point,prm_string)CONCAT(prm_string,Help_char[0],Prm_text)CONCAT(Prm_text,Text.AC_press,Prm_text)[XIC(AC_precond) MOVE(Run.Precond_press[Point],prm_real) ,XIO(AC_precond) MOVE(Run.Postcond_press[Point],prm_real) ]JSR(Real_to_String,3,2,Prm_text,prm_real);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Print_main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Print control main program
Language and pressure unit setting]]>
</Comment>
<Text>
<![CDATA[[[XIC(Option.Language.1) EQ(HMI.Language,1) COP(TextEN,Text,1) ,XIC(Option.Language.4) EQ(HMI.Language,4) COP(TextSP,Text,1) ,XIC(Option.Language.5) EQ(HMI.Language,5) COP(TextFR,Text,1) ] ,XIC(Option.Press_unit) COP(Help_char[18],Press_unit,1) ,XIO(Option.Press_unit) COP(Help_char[19],Press_unit,1) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Print header
]]>
</Comment>
<Text>
<![CDATA[[COP(Text.Header,HDR_Buffer[3],1) ,NE(Option.Printer_type,0) EQ(Option.Printer_type,0) CONCAT(Help_char[12],Text.Header,HDR_Buffer[3]) ,CONCAT(Text.Model,Common_set.Model,HDR_Buffer[4]) CONCAT(Text.Customer,Common_set.Customer,HDR_Buffer[5]) CONCAT(Text.Serial,Common_set.Serial_Number,HDR_Buffer[6]) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Create string for print time]]>
</Comment>
<Text>
<![CDATA[JSR(Print_time,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Print command 1: Parameters]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Cycle_start) CLR(End_line) OTL(Data_save) ,XIC(HMI.Print_prm) EQ(P_comm,0) XIO(Process.Running) NE(Process.Cycle_number,0) ]MOVE(1,P_comm)OTU(HMI.Print_prm);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Print command 1: Parameters]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,1)[FOR(Reset_PRT_Buffer,BufferIX,0,219,1) ,XIC(Data_save) FOR(Reset_Last_Cycle,ResetLastIX,0,2499,1) ,JSR(P1_Precycle,0) ,[XIC(Run.Print_type) ,XIO(Process.Running) ] [JSR(P1_Precondition,0) ,JSR(P1_Exposure,0) ,JSR(P1_Postcondition,0) ,JSR(P1_Other_parameters,0) ] ,XIC(Data_save) JSR(P1_StartHeader,0) ,XIC(Data_save) FOR(PRM_Copy,BufferIX,0,ROW_NR,1) ,XIC(Data_save) MOVE(ROW_NR,S_Pointer) CLR(P_Pointer) ,XIO(Data_save) CLR(PRT_ROW) CLR(P_comm) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Print command 2: Phase]]>
</Comment>
<Text>
<![CDATA[NE(Process.Phase_number,Print_phase)XIC(Data_save)XIC(Step_print_delay.DN)MOVE(Process.Phase_number,Print_phase)[JSR(P2_Phase,0) ,NE(P_comm,6) CLR(P_comm) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Print command 3: Measurement when step changes or alarm event occurs]]>
</Comment>
<Text>
<![CDATA[[NE(Process.Step,Print_step) ,GT(A_pointer,0) ][[EQ(Process.Step,4) ,LIMIT(7,Process.Step,24) ,EQ(Process.Step,29) ,LIMIT(33,Process.Step,45) ,LIMIT(50,Process.Step,57) ,LIMIT(60,Process.Step,68) ,LIMIT(81,Process.Step,84) ,LIMIT(89,Process.Step,98) ] XIO(Step_print_delay.TT) JSR(P3_Measurements,0) ,TON(Step_print_delay,?,?) XIC(Step_print_delay.DN) MOVE(Process.Step,Print_step) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Print command 3: Measurement when print interval time is done]]>
</Comment>
<Text>
<![CDATA[[XIC(Data_save) [XIO(Step_bit[0].15) XIO(Step_bit[2].1) MUL(Run.Print_interval,1000,Interval_print.PRE) ,[XIC(Step_bit[0].15) ,XIC(Step_bit[2].1) ] MUL(Run.Exposure_print_interval,1000,Interval_print.PRE) ,LIMIT(33,Process.Step,24) TON(Interval_print,?,?) ] ,XIC(Interval_print.DN) [XIC(Run.Print_type) ,XIC(Step_bit[0].15) ,XIC(Step_bit[2].1) ] [JSR(P3_Measurements,0) ,RES(Interval_print) ] ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Print command 3: Current measurement values from panel]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Print_meas)ONS(meas_ons)[JSR(P3_Measurements,0) ,XIO(Data_save) CLR(P_comm) CLR(PRT_ROW) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Print command 3: Current measurement values when air detector cycle is running]]>
</Comment>
<Text>
<![CDATA[XIC(Run.Air_detec_select)[EQ(Run.Precond_1_type,2) ,EQ(Run.Precond_2_type,2) ][XIC(Step_bit[0].13) ,XIC(Step_bit[0].14) ]GT(PT549_Chamber.Pressure_mBar,Run.Air_detec_pressure)ONS(air_detect_ons)JSR(P3_Measurements,0);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Print command 4: alarm when alarm event occurs during cycle]]>
</Comment>
<Text>
<![CDATA[[GT(A_pointer,0) ,XIC(Store_Alarms) ]XIC(Data_save)JSR(P4_Alarm,0);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Print command 4: Alarm when cycle is not running]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,0)GT(A_pointer,0)XIO(Data_save)[NE(Option.Printer_type,2) [FOR(Reset_PRT_Buffer,BufferIX,0,219,1) CLR(PRT_ROW) ,JSR(P4_Alarm,0) ] ,EQ(Option.Printer_type,2) SUB(A_pointer,1,A_pointer) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Print command 5: Number of given last alarms ]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,0)GT(HMI.Print_alarms,0)[COP(Alarm_stack[0],PRT_Buffer[0],HMI.Print_alarms) ,MOVE(HMI.Print_alarms,ROW_NR) ,CLR(PRT_ROW) ,CLR(HMI.Print_alarms) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Check that HMI is ready to receive printing]]>
</Comment>
<Text>
<![CDATA[XIO(PrintingACT)JMP(jump);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Print command 6: Cycle data]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,0)LT(P_Pointer,S_Pointer)[MOVE(6,P_comm) ,XIO(ReadyToPrint) XIO(Print_delay.TT) COP(LastCycle[P_Pointer],Data_print,1) ,XIO(ReadyToPrint) XIO(Print_delay.TT) LT(P_Pointer,2499) ADD(P_Pointer,1,P_Pointer) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Continue printing when reprint memory is full]]>
</Comment>
<Text>
<![CDATA[EQ(P_Pointer,2499)MOVE(2498,S_Pointer)MOVE(2498,P_Pointer);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[Print command 6: Cycle data]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,6)JSR(P6_Cycle_data,0);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[LBL(jump)NOP();]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[Print command 7: PID values]]>
</Comment>
<Text>
<![CDATA[[XIC(HMI.Print_pid) EQ(P_comm,0) XIO(Process.Running) MOVE(7,P_comm) OTU(HMI.Print_pid) ,EQ(P_comm,7) [FOR(Reset_PRT_Buffer,BufferIX,0,219,1) ,JSR(P7_PID_Values,0) ,CLR(P_comm) CLR(PRT_ROW) ] ];]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[Print command 8: Calibration values]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,0)[XIC(HMI.Print_calib) XIO(Process.Running) MOVE(8,P_comm) OTU(HMI.Print_calib) ,EQ(P_comm,8) [FOR(Reset_PRT_Buffer,BufferIX,0,219,1) ,JSR(P8_Calibrations,0) ,CLR(PRT_ROW) CLR(P_comm) ] ];]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[Print command 9: Last cycle data]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Print_cycle)XIO(Process.Running)EQ(P_Pointer,S_Pointer)CLR(P_Pointer);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[Print command 10: Print login data]]>
</Comment>
<Text>
<![CDATA[[NE(User_name_full,User_name_reset) GT(Password_level,0) [NE(Password_level,Print_login_help) [JSR(Separate_domain_username,0) ,XIC(Data_save) JSR(P10_Login_Step_Wait,0) ] ,MOVE(Password_level,Print_login_help) ] ,EQ(Password_level,0) MOVE(0,Print_login_help) ];]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[Print command 10: Step or Wait pressed]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Step_pressed) ,XIC(HMI.Wait_pressed) EQ(Wait_press_status,0) ,XIO(HMI.Wait_pressed) EQ(Wait_press_status,1) ]XIC(Data_save)JSR(P10_Login_Step_Wait,0);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[Print command 11: Common Settings]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,0)[XIC(HMI.Print_common) XIO(Data_save) MOVE(11,P_comm) OTU(HMI.Print_common) ,EQ(P_comm,11) [FOR(Reset_PRT_Buffer,BufferIX,0,219,1) ,JSR(P11_Common_settings,0) ,CLR(PRT_ROW) CLR(P_comm) ] ];]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[Cycle Summary]]>
</Comment>
<Text>
<![CDATA[XIC(Data_save)EQ(Run.Precycle_type,10)EQ(Process.Phase_number,Print_phase)EQ(Process.Phase_number,12)XIO(FIT_summary_print)[JSR(Cycle_Summary,0) ,OTL(FIT_summary_print) ];]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[End cycle data save]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)XIC(E_Sign_Screen)XIO(HMI.E_Sign_Approved)XIO(HMI.E_Sign_Rejected)XIC(Printing_cmd_inactive)OTU(Store_prm)OTU(Data_save)MOVE(ROW_NR,PRT_ROW);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[End cycle data save after delay information for common use, controller tag]]>
</Comment>
<Text>
<![CDATA[[XIC(Data_save) XIO(Data_save_controller) OTL(Data_save_controller) ,XIO(Data_save) XIC(Data_save_controller) OTU(Data_save_controller) ];]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[Print command 13: Print Leak Rate Test result]]>
</Comment>
<Text>
<![CDATA[LIMIT(1,Run.Precycle_type,3)[[XIC(Step_bit[1].3) ,XIC(Step_bit[1].10) ] OTL(LRT_result) ,XIC(Step_bit[0].21) XIC(LRT_result) [[NE(Run.Precycle_type,3) XIO(Alarm_ACT[0].23) ,EQ(Run.Precycle_type,3) ] JSR(P13_LRT_Result,0) ,OTU(LRT_result) ] ];]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Comment>
<![CDATA[Print command 13: Print Leak Rate Test result]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,8)[XIC(Step_bit[2].26) OTL(FIT_sanitization_result) ,XIC(Step_bit[0].21) XIC(FIT_sanitization_result) [JSR(P14_Sanitiz_Result,0) ,OTU(FIT_sanitization_result) ] ];]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Comment>
<![CDATA[Printing command is inactive]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,0)[TON(Printing_cmd_inact_delay,?,?) ,XIC(Printing_cmd_inact_delay.DN) OTE(Printing_cmd_inactive) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Print_time" Type="RLL">
<Description>
<![CDATA[Create string for print time]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Create date to string]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Date)DTOS(Date_time[1],Print_date[1])CONCAT(Print_date[1],Help_char[5],Print_date[1])DTOS(Date_time[2],Print_date[2])CONCAT(Print_date[2],Help_char[5],Print_date[2])DTOS(Date_time[0],Print_date[0])CONCAT(Print_date[1],Print_date[2],Print_date[3])CONCAT(Print_date[3],Print_date[0],Print_date[3]);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Create date to string]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Date)DTOS(Date_time[2],Print_date[1])CONCAT(Print_date[1],Help_char[1],Print_date[1])DTOS(Date_time[1],Print_date[2])CONCAT(Print_date[2],Help_char[1],Print_date[2])DTOS(Date_time[0],Print_date[0])CONCAT(Print_date[1],Print_date[2],Print_date[3])CONCAT(Print_date[3],Print_date[0],Print_date[3]);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Make time to string and add character if value < 10]]>
</Comment>
<Text>
<![CDATA[[DTOS(Date_time[3],Print_time[0]) EQ(Print_time[0].LEN,1) INSERT(Print_time[0],Help_char[4],1,Print_time[0]) ,DTOS(Date_time[4],Print_time[1]) EQ(Print_time[1].LEN,1) INSERT(Print_time[1],Help_char[4],1,Print_time[1]) ,DTOS(Date_time[5],Print_time[2]) EQ(Print_time[2].LEN,1) INSERT(Print_time[2],Help_char[4],1,Print_time[2]) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Create printout time string]]>
</Comment>
<Text>
<![CDATA[INSERT(Print_time[0],Help_char[0],3,Print_time[0])INSERT(Print_time[1],Help_char[0],3,Print_time[1])CONCAT(Print_time[0],Print_time[1],Print_time[3])CONCAT(Print_time[3],Print_time[2],Print_time[3]);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Copy time and date for other task usage]]>
</Comment>
<Text>
<![CDATA[CLR(time_date.LEN)FLL(0,time_date.DATA[0],42)COP(Print_time[3],time,1)CONCAT(Print_time[3],Help_char[3],time_date)CONCAT(time_date,Print_date[3],time_date);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(Option.USB_Batch_data)RET();]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Filename. Create Date & Time string for USB file printing. String is used by PanelView+6 to create file.]]>
</Comment>
<Text>
<![CDATA[DTOS(Date_time[0],Print_time_USB[0])DTOS(Date_time[1],Print_time_USB[1])DTOS(Date_time[2],Print_time_USB[2])DTOS(Date_time[3],Print_time_USB[3])DTOS(Date_time[4],Print_time_USB[4])DTOS(Date_time[5],Print_time_USB[5]);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[CONCAT(Print_time_USB[0],Help_char[22],Print_time_USB[0])[[EQ(Print_time_USB[1].LEN,1) INSERT(Print_time_USB[1],Help_char[4],1,Print_time_USB[1]) ,NE(Print_time_USB[1].LEN,1) ] CONCAT(Print_time_USB[1],Help_char[22],Print_time_USB[1]) ,[EQ(Print_time_USB[2].LEN,1) INSERT(Print_time_USB[2],Help_char[4],1,Print_time_USB[2]) ,NE(Print_time_USB[2].LEN,1) ] CONCAT(Print_time_USB[2],Help_char[21],Print_time_USB[2]) ,[EQ(Print_time_USB[3].LEN,1) INSERT(Print_time_USB[3],Help_char[4],1,Print_time_USB[3]) ,NE(Print_time_USB[3].LEN,1) ] CONCAT(Print_time_USB[3],Help_char[22],Print_time_USB[3]) ,[EQ(Print_time_USB[4].LEN,1) INSERT(Print_time_USB[4],Help_char[4],1,Print_time_USB[4]) ,NE(Print_time_USB[4].LEN,1) ] CONCAT(Print_time_USB[4],Help_char[22],Print_time_USB[4]) ,EQ(Print_time_USB[5].LEN,1) INSERT(Print_time_USB[5],Help_char[4],1,Print_time_USB[5]) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(HMI.Start)ONS(Start_TimeDate_For_USB)CONCAT(Help_char[23],Print_time_USB[0],Print_time_USB[6])CONCAT(Print_time_USB[6],Print_time_USB[1],Print_time_USB[6])CONCAT(Print_time_USB[6],Print_time_USB[2],Print_time_USB[6])CONCAT(Print_time_USB[6],Print_time_USB[3],Print_time_USB[6])CONCAT(Print_time_USB[6],Print_time_USB[4],Print_time_USB[6])CONCAT(Print_time_USB[6],Print_time_USB[5],Print_time_USB[6])CONCAT(Print_time_USB[6],Help_char[24],Print_time_USB[6])COP(Print_time_USB[6],Print_Start_Date_Time,1);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Activate printing to USB storage]]>
</Comment>
<Text>
<![CDATA[[[XIC(Process.Running) ,LT(P_Pointer,S_Pointer) ] OTL(Print_USB_batch_file) ,XIO(Process.Running) XIO(Data_save_delay.TT) XIO(ReadyToPrint) OTU(Print_USB_batch_file) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
