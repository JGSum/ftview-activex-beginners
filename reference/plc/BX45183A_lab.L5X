<DataValueMember Name="Mo" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="Da" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="Hr" DataType="DINT" Radix="Decimal" Value="0"/>
