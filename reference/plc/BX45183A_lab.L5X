</Comment>
<Text>
<![CDATA[[NE(Run.Precycle_type,3) CONCAT(time,Text.LRT_result_pass,meas_text) ,EQ(Run.Precycle_type,3) [XIO(Alarm_ACT[1].31) CONCAT(time,Text.VS_flow_result_pass,meas_text) ,XIC(Alarm_ACT[1].31) CONCAT(time,Text.VS_flow_result_failed,meas_text) ] DTOS(VS_test_time_value,prm_string) CONCAT(meas_text,prm_string,meas_text) CONCAT(meas_text,Text.Sec,meas_text) ]CONCAT(meas_text,Press_unit,meas_text)OTL(Meas)JSR(Real_to_String,3,2,P13_text,LRT_leak_value)OTU(Meas);]]>
