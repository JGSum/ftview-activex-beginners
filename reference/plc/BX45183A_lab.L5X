</Comment>
<Text>
<![CDATA[[XIC(HMI.Calib_done) XIC(Calib_HIGH_LOW) XIO(HMI.Calib_failed) ,[EQ(HMI.Calib_select,0) ,XIC(Process.Running) ] ][OTU(PT549_Chamber.Probe_selected) ,OTU(PT1004_Filter_FIT.Probe_selected) ,OTU(HMI.Calib_One_point) ,OTU(TE517_Chamber.Probe_selected) ,OTU(TE518_Jacket.Probe_selected) ,OTU(TE788_1_Load1.Probe_selected) ,OTU(TE788_2_Load2.Probe_selected) ,OTU(TE525_Water_tank.Probe_selected) ,OTU(TE788_3_Load3.Probe_selected) ,OTU(TE788_4_Load4.Probe_selected) ,OTU(TE517_1_Filter.Probe_selected) ,OTU(TE517_2_DEC.Probe_selected) ,OTU(TE520_Air_detect.Probe_selected) ,OTU(TE517_3_Chamber.Probe_selected) ,OTU(TE517_4_Chamber.Probe_selected) ,OTU(TE1018_Filter_FIT.Probe_selected) ,OTU(TE1018_2_FIT_Water_Tank.Probe_selected) ,OTU(TE517_5_FIT_Sanitization.Probe_selected) ,OTU(Calib_HIGH_LOW) ,MOVE(90,HMI.Calib_temp_value) ];]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[If no probes selected, change sensor type for calibration to 0]]>
</Comment>
<Text>
<![CDATA[XIO(PT549_Chamber.Probe_selected)XIO(PT1004_Filter_FIT.Probe_selected)XIO(TE517_Chamber.Probe_selected)XIO(TE518_Jacket.Probe_selected)XIO(TE788_1_Load1.Probe_selected)XIO(TE788_2_Load2.Probe_selected)XIO(TE525_Water_tank.Probe_selected)XIO(TE788_3_Load3.Probe_selected)XIO(TE788_4_Load4.Probe_selected)XIO(TE517_1_Filter.Probe_selected)XIO(TE517_2_DEC.Probe_selected)XIO(TE520_Air_detect.Probe_selected)XIO(TE517_3_Chamber.Probe_selected)XIO(TE1018_Filter_FIT.Probe_selected)XIO(TE1018_2_FIT_Water_Tank.Probe_selected)XIO(TE517_5_FIT_Sanitization.Probe_selected)MOVE(0,HMI.Calib_select);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="AI_scaling" Type="RLL">
<Description>
<![CDATA[Analog input scaling]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Scale measurement data according calibration values]]>
</Comment>
<Text>
<![CDATA[SBR(In_raw,In_min,In_max,Scale_min,Scale_max)[CPT(AI_scaled,(In_raw-In_min)*(Scale_max-Scale_min)/(In_max-In_min)+Scale_min) ,RET(AI_scaled) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="AO_0_PY1012" Type="RLL">
<Description>
<![CDATA[FIT filter pressure control
Analog output 4 - 20mA  0 - 4000 mbar]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Increase FIT pressure
Step 94 Fill = 5 mbar/s
Step 95 Pressurize = 10 mbar/s]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.FIT_PY1012_Man_Auto)XIC(Process.S_pulse)[[EQ(Process.Step,94) ,EQ(Process.Step,95) ] LT(Process.FIT_pressure_to_filter_help,4000) ADD(4000,Process.FIT_pressure_to_filter_help,Process.FIT_pressure_to_filter_help) ,EQ(Process.Step,94) LT(Process.FIT_PY1012_analog_out,8000) ADD(Process.FIT_pressure_to_filter_help,20,Process.FIT_pressure_to_filter_help) ,EQ(Process.Step,95) ADD(Process.FIT_pressure_to_filter_help,40,Process.FIT_pressure_to_filter_help) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Step 94 Fill 
Limit output to 500 mbar]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.FIT_PY1012_Man_Auto)[EQ(Process.Step,94) GT(Process.FIT_PY1012_analog_out,8000) ,XIC(Process.FIT_manual_tank_drain) XIO(DIG_IN[1].23) XIO(FIT_water_tank_drain_low_delay.EN) ]MOVE(8000,Process.FIT_pressure_to_filter_help);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Set output  0 % (= 4000)]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.FIT_PY1012_Man_Auto)[XIO(Process.FIT_manual_tank_drain) NE(Process.Step,94) NE(Process.Step,95) ,XIC(Process.FIT_manual_tank_drain) [XIC(DIG_IN[1].23) ,XIC(FIT_water_tank_drain_low_delay.EN) ] ]MOVE(4000,Process.FIT_pressure_to_filter_help);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(HMI.FIT_PY1012_Man_Auto)CLR(HMI.FIT_PY1012_Man_out_value);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIO(HMI.FIT_PY1012_Man_Auto)[CPT(HMI.FIT_PY1012_Man_out_value_help,HMI.FIT_PY1012_Man_out_value*160+4000.0) ,LE(HMI.FIT_PY1012_Man_out_value_help,4000) MOVE(4000,HMI.FIT_PY1012_Man_out_value_help) ,MOVE(HMI.FIT_PY1012_Man_out_value_help,Process.FIT_pressure_to_filter_help) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[GT(Process.FIT_pressure_to_filter_help,20000)MOVE(20000,Process.FIT_pressure_to_filter_help);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[0 - 100 % output value for panel]]>
</Comment>
<Text>
<![CDATA[[MOVE(Process.FIT_pressure_to_filter_help,Process.FIT_PY1012_analog_out) ,LE(Process.FIT_PY1012_analog_out,4000) [MOVE(0,HMI.FIT_PY1012_Out_HMI) ,MOVE(4000,Process.FIT_PY1012_analog_out) ] ,GT(Process.FIT_PY1012_analog_out,4000) CPT(HMI.FIT_PY1012_Out_HMI,(Process.FIT_PY1012_analog_out-4000.0)/160) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Move PY1012 output value to analog output module word.]]>
</Comment>
<Text>
<![CDATA[[MOVE(Process.FIT_PY1012_analog_out,FIT_PY1012_analog_out_Dint) ,BTD(FIT_PY1012_analog_out_Dint,0,U784:O.Data[4],0,8) BTD(FIT_PY1012_analog_out_Dint,8,U784:O.Data[5],0,8) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Calc_Rates" Type="RLL">
<Description>
<![CDATA[Pressure rate value calculation]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Rates calculation
Return if rate calculation is not active]]>
</Comment>
<Text>
<![CDATA[[LIMIT(14,Process.Step,7) LIMIT(23,Process.Step,15) ,XIO(Run.Rates_selected) XIO(Step_bit[0].20) ,EQ(Process.Service_cycle,2) ][MOVE(6001,Rate_time.ACC) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Move precond rate values for calculation variables]]>
</Comment>
<Text>
<![CDATA[LE(Process.Step,12)NE(Prev_step_rate,Process.Step)[NE(Run.Precond_vacuum_rate,0) DIV(Run.Precond_vacuum_rate,10.0,Vacuum_rate) ,NE(Run.Precond_press_rate,0) DIV(Run.Precond_press_rate,10.0,Pressure_rate) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Move Slow Exhaust rate values for calculation variables]]>
</Comment>
<Text>
<![CDATA[XIC(Step_bit[0].20)[DIV(Run.Rates_slow_exhaust,10.0,Vacuum_rate) ,MOVE(Vacuum_rate,Pressure_rate) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Move postcond rate values for calculation variables]]>
</Comment>
<Text>
<![CDATA[XIO(Step_bit[0].20)GE(Process.Step,16)NE(Prev_step_rate,Process.Step)[NE(Run.Postcond_vacuum_rate,0) DIV(Run.Postcond_vacuum_rate,10.0,Vacuum_rate) ,NE(Run.Postcond_press_rate,0) DIV(Run.Postcond_press_rate,10.0,Pressure_rate) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Increment rate value ]]>
</Comment>
<Text>
<![CDATA[XIC(Rate_time.DN)NE(Step_pressure_setpoint,0)[LT(Vacuum_rate_reg,5000.0) ADD(Vacuum_rate,Vacuum_rate_reg,Vacuum_rate_reg) ,LT(Press_rate_reg,5000.0) ADD(Pressure_rate,Press_rate_reg,Press_rate_reg) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Rates calculation timer]]>
</Comment>
<Text>
<![CDATA[XIO(Rate_time.DN)TON(Rate_time,?,?);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Initialize rate value]]>
</Comment>
<Text>
<![CDATA[[LIMIT(2,Process.Step,7) MOVE(Process.ATM_pressure,Rate_value) ,EQ(Process.Step,20) XIC(PT549_Chamber.out_of_range) [XIC(DIG_IN[0].0) MOVE(2500,Rate_value) ,XIO(DIG_IN[0].0) CLR(Rate_value) ] ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Start rate calculation when step changes]]>
</Comment>
<Text>
<![CDATA[GT(Process.Step,1)NE(Prev_step_rate,Process.Step)[XIO(PT549_Chamber.out_of_range) MOVE(PT549_Chamber.Pressure_mBar,Rate_value) ,MOVE(Process.Step,Prev_step_rate) ,CLR(Press_rate_reg) ,CLR(Vacuum_rate_reg) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Rate value for the valve control]]>
</Comment>
<Text>
<![CDATA[[LT(Step_pressure_setpoint,Rate_value) [SUB(Rate_value,Vacuum_rate_reg,Process.Rate_value) ,LE(Process.Rate_value,0) CLR(Process.Rate_value) ] ,GT(Step_pressure_setpoint,Rate_value) ADD(Rate_value,Press_rate_reg,Process.Rate_value) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Controller" Type="RLL">
<Description>
<![CDATA[CPU status and fault  detection]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Get CPU data from controller]]>
</Comment>
<Text>
<![CDATA[XIC(S:FS)[GSV(ControllerDevice,?,DeviceName,CPU.Type.DATA[0]) GSV(ControllerDevice,?,ProductRev,CPU.OS_Revision) GSV(ControllerDevice,?,SerialNumber,CPU.SN) ,AND(CPU.OS_Revision,255,CPU.OS_major) SWPB(CPU.OS_Revision,HIGH/LOW,CPU_OS_swp) AND(CPU_OS_swp,255,CPU.OS_minor) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Get processor name from controller]]>
</Comment>
<Text>
<![CDATA[XIC(S:FS)[XIO(CPU_Name_call.EN) MSG(CPU_Name_call) ,COP(CPU_name[2],CPU.Name.DATA[0],8) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Get CPU status from controller]]>
</Comment>
<Text>
<![CDATA[GSV(ControllerDevice,?,Status,CPU.Status)GSV(FaultLog,?,MinorEvents,CPU.Minor_events)GSV(FaultLog,?,MinorFaultBits,CPU.Minor_fault)GSV(Program,IO_Control,MINORFAULTRECORD,CPU.Minor_log[0]);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Clear fault data information from Service / System Status display]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Clear_major_fault_data)CLR(CPU.Major_type);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Counters" Type="RLL">
<Description>
<![CDATA[Counters]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Digital output counter add]]>
</Comment>
<Text>
<![CDATA[FOR(Counter_add,Number,0,30,1);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Vacuum pump running hours and started counter]]>
</Comment>
<Text>
<![CDATA[[XIC(DIG_OUT_View[0].1) [XIC(Process.S_pulse) ADD(1,K962.Seconds,K962.Seconds) ,ONS(K962.ONS) ADD(1,K962.Counter,K962.Counter) ] ,EQ(K962.Seconds,60) [ADD(1,K962.Minutes,K962.Minutes) ,CLR(K962.Seconds) ] ,EQ(K962.Minutes,60) [ADD(1,K962.Hours,K962.Hours) ,CLR(K962.Minutes) ] ,XIC(HMI.Counter_reset) XIC(K962.Counter_Selected) [CLR(K962.Seconds) CLR(K962.Minutes) CLR(K962.Hours) ,OTU(K962.Counter_Selected) ] ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Air Filter counter]]>
</Comment>
<Text>
<![CDATA[[XIC(DIG_OUT_View[1].13) [RTO(Filter.msec,?,?) ,XIC(Filter.msec.DN) RES(Filter.msec) ADD(1,Filter.Seconds,Filter.Seconds) ] ,EQ(Filter.Seconds,60) [ADD(1,Filter.Minutes,Filter.Minutes) ,CLR(Filter.Seconds) ] ,EQ(Filter.Minutes,60) [ADD(1,Filter.Hours,Filter.Hours) ,CLR(Filter.Minutes) ] ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Reset filter counter]]>
</Comment>
<Text>
<![CDATA[[XIC(HMI.Counter_reset) XIC(Filter.Counter_Selected) ,XIC(Process.Step_ready) EQ(Run.Exposure_type,4) XIC(Step_bit[0].15) XIC(Filter_Counter_reset) ][CLR(Filter.Seconds) CLR(Filter.Minutes) CLR(Filter.Hours) ,OTU(Filter.Counter_Selected) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Reset selected Output counter]]>
</Comment>
<Text>
<![CDATA[[XIC(HMI.Counter_reset) ,GT(Pointer,0) ][XIC(Counter_selected[0].[Pointer]) CLR(DIG_OUT_0_Counter[Pointer]) ,XIC(Counter_selected[1].[Pointer]) CLR(DIG_OUT_1_Counter[Pointer]) ,ADD(1,Pointer,Pointer) ,EQ(Pointer,31) [FLL(0,Counter_selected[0],2) ,CLR(Pointer) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Counter_add" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Reset DO Block counter help bit if output is disabled]]>
</Comment>
<Text>
<![CDATA[LT(Number,16)XIO(DIG_OUT_View[0].[Number])XIC(COUNTER_help[0].[Number])OTU(COUNTER_help[0].[Number]);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Add DO Block counter value when output is enabled]]>
</Comment>
<Text>
<![CDATA[LT(Number,16)XIC(DIG_OUT_View[0].[Number])XIO(COUNTER_help[0].[Number])[ADD(1,DIG_OUT_0_Counter[Number],DIG_OUT_0_Counter[Number]) ,OTL(COUNTER_help[0].[Number]) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Reset MPA counter help bit if output is disabled]]>
</Comment>
<Text>
<![CDATA[XIO(DIG_OUT_View[1].[Number])XIC(COUNTER_help[1].[Number])OTU(COUNTER_help[1].[Number]);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Add MPA counter value when output is enabled]]>
</Comment>
<Text>
<![CDATA[XIC(DIG_OUT_View[1].[Number])XIO(COUNTER_help[1].[Number])[ADD(1,DIG_OUT_1_Counter[Number],DIG_OUT_1_Counter[Number]) ,OTL(COUNTER_help[1].[Number]) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DI_move" Type="RLL">
<Description>
<![CDATA[Move digital inputs
to bits]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Copy data from Digital input card
Cabinet 5069-IB16]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Test_DI)COP(Local:1:I,DIG_IN_Help_Array[0],2)COP(DIG_IN_Help_Array[1],DIG_IN[0],1);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Copy data from Digital input card
FESTO CPX 8DE
Location of mapped input word depens on number of AI modules]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Test_DI)[BTD(U784:I.Data[Festo_AI_Index],0,DIG_IN[1],0,8) ,GT(Option.Festo_DI_modules,1) BTD(U784:I.Data[Festo_AI_Index+1],0,DIG_IN[1],8,8) ,GT(Option.Festo_DI_modules,2) BTD(U784:I.Data[Festo_AI_Index+2],0,DIG_IN[1],16,8) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Copy data from test memory when simulator is on
Test word 1: Ready to start = -9
Standby = -16]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Test_DI)MOVE(Input_test[0],DIG_IN[0])MOVE(Input_test[1],DIG_IN[1]);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DO_0_YY670" Type="RLL">
<Description>
<![CDATA[1769-IQ16 Out 0
Enable door control]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[YY670 Enable door control]]>
</Comment>
<Text>
<![CDATA[[LIMIT(2,Process.Step,3) ,LIMIT(5,Process.Step,6) ,LIMIT(26,Process.Step,27) ,LIMIT(30,Process.Step,31) ,LIMIT(51,Process.Step,56) ]LIMIT(Process.ATM_low,PT549_Chamber.Pressure_mBar,Process.ATM_high)OTE(DIG_OUT[0].0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DO_10_H40K400" Type="RLL">
<Description>
<![CDATA[Cycle run light ST-side]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[H40 Cycle Run Light ST side]]>
</Comment>
<Text>
<![CDATA[GT(Process.Step,1)XIC(Process.Running)OTE(DIG_OUT[0].10);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DO_11_H41" Type="RLL">
<Description>
<![CDATA[Alarm light ST-side]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[H41 Alarm ON ST side indicator light]]>
</Comment>
<Text>
<![CDATA[[NE(Alarm_ACT[0],0) ,NE(Alarm_ACT[1],0) ,NE(Alarm_ACT[2],0) ,NE(Process.Power_brake_status,0) ][GT(Process.Step,1) ,XIC(Process.Running) ]OTE(DIG_OUT[0].11);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DO_12_K600" Type="RLL">
<Description>
<![CDATA[ST Door Open relay]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[K600 ST Door Open Relay]]>
</Comment>
<Text>
<![CDATA[[GT(Process.Step,1) ,XIC(Process.Running) ]XIO(DIG_IN[1].16)OTE(DIG_OUT[0].12);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DO_13_K595" Type="RLL">
<Description>
<![CDATA[DecV VIRASURE Heating Control]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[K595 DecV VIRASURE Heating Control]]>
</Comment>
<Text>
<![CDATA[[LIMIT(60,Process.Step,61) [XIC(DIG_OUT[0].1) EQ(Pulse_counter_Controller_Tag,1) ,GT(Pulse_counter_Controller_Tag,1) ] ,[LIMIT(62,Process.Step,63) GT(Pulse_counter_Controller_Tag,1) ,LIMIT(64,Process.Step,68) ] ]XIO(Alarm_ACT[1].27)LT(TE527_2_VIRASURE.Temperature,450)LT(TE527_3_VIRASURE.Temperature,450)XIO(VIRASURE_Control_temp_out_of_range)OTE(VIRASURE_Control_ON);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[CMP(K595_PID.OUTPROSENTTI*50>On_Off_Control_timer.ACC)XIC(VIRASURE_Control_ON)OTE(DIG_OUT[0].13);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[[DIV(HMI.PID_DEC_VS_P,100,K595_PID.P) ,DIV(HMI.PID_DEC_VS_I,100,K595_PID.I) ,DIV(HMI.PID_DEC_VS_D,100,K595_PID.D) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[[LIMIT(60,Process.Step,61) [EQ(Pulse_counter_Controller_Tag,1) MOVE(350,K595_PID.SetPoint) MOVE(VIRASURE_Temperature,VIRASURE_Control_Temperature) ,GT(Pulse_counter_Controller_Tag,1) MOVE(170.0,K595_PID.SetPoint) MOVE(VIRASURE_Min_Temp,VIRASURE_Control_Temperature) ] ,[LIMIT(62,Process.Step,63) [XIC(Run.Prec_1_First_pulse_type) GT(Pulse_counter_Controller_Tag,1) ,XIO(Run.Prec_1_First_pulse_type) ] ,LIMIT(64,Process.Step,68) ] MOVE(170.0,K595_PID.SetPoint) MOVE(VIRASURE_Min_Temp,VIRASURE_Control_Temperature) ,LIMIT(69,Process.Step,59) MOVE(0,K595_PID.SetPoint) ]PI_Saadin_JaP(K595_PID,VIRASURE_Control_Temperature);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(Process.Running)GT(VIRASURE_Temperature,350)GT(TE527_2_VIRASURE.Temperature,300)GT(TE527_3_VIRASURE.Temperature,300)OTL(VIRASURE_Temperature_Reached);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Copy controller values for external use]]>
</Comment>
<Text>
<![CDATA[[MOVE(K595_PID.SetPoint,VS_PID_setpoint) ,MOVE(K595_PID.OUTPROSENTTI,VS_PID_output) ,LIMIT(69,Process.Step,59) MOVE(0,VS_PID_output) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="DO_1_K962" Type="RLL">
<Description>
<![CDATA[Vacuum pump motor]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[K962 Vacuum pump motor]]>
</Comment>
<Text>
<![CDATA[[[[LIMIT(2,Process.Step,6) ,XIC(Step_bit[0].26) ,XIC(Step_bit[0].30) ,EQ(Process.Service_cycle,1) ] XIC(Process.Pull_gasket) XIO(Vac_pump_tank_draining_active) ,XIC(Step_bit[0].8) ,XIC(Step_bit[0].9) ,XIC(Step_bit[0].12) ,XIC(Step_bit[0].16) ,XIC(Step_bit[0].17) ,XIC(Step_bit[0].19) LT(Step_pressure_setpoint,Process.ATM_pressure) ,XIC(Step_bit[0].21) XIC(Process.Equal_press) ,XIC(Step_bit[0].25) ,XIC(Step_bit[0].29) ,XIC(Step_bit[1].1) ,XIC(Step_bit[1].2) XIC(Run.FA_pump_during_stabil) ,XIC(Step_bit[1].8) ,XIC(Step_bit[1].12) ,XIC(Step_bit[1].18) ,LIMIT(60,Process.Step,61) ,XIC(Step_bit[2].3) [XIO(Process.DEC_condensate_high) XIC(DEC_Condensate_OK_delay.DN) ,XIC(DEC_Condensate_OK_delay.DN) XIC(Process.DEC_step68_completed) XIC(Process.DEC_condensate_high) ] GT(PT549_Chamber.Pressure_mBar,Process.ATM_pressure) ,XIC(Step_bit[2].4) ,XIC(Step_bit[1].4) ,XIC(Step_bit[1].6) ] XIO(Alarm_ACT[0].18) ,XIC(Option.Jacket_closed_loop) [XIC(Step_bit[0].24) ,XIC(Step_bit[2].20) XIC(Run.SAMX_jacket_cooling) ] ]XIO(Alarm_ACT[0].12)XIO(Alarm_ACT[1].2)OTE(DIG_OUT[0].1);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Hold bit for the valve control when chamber pressure is equalized above ATM]]>
</Comment>
<Text>
<![CDATA[[GT(PT549_Chamber.Pressure_mBar,Process.ATM_high) ,XIC(Process.Equal_press) ]GT(PT549_Chamber.Pressure_mBar,Process.ATM_low)OTE(Process.Equal_press);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
