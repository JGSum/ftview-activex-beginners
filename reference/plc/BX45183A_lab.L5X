]]>
</Comment>
<Text>
<![CDATA[NE(Run.Precond_1_type,0)[ADD(ROW_NR,1,ROW_NR) COP(Text.Prec1,PRT_Buffer[ROW_NR],1) ,EQ(Run.Precond_1_type,1) CONCAT(PRT_Buffer[ROW_NR],Text.Forced,PRT_Buffer[ROW_NR]) ,EQ(Run.Precond_1_type,2) CONCAT(PRT_Buffer[ROW_NR],Text.Pulsed,PRT_Buffer[ROW_NR]) ,EQ(Run.Precond_1_type,3) CONCAT(PRT_Buffer[ROW_NR],Text.DEC,PRT_Buffer[ROW_NR]) ,EQ(Run.Precond_1_type,4) CONCAT(PRT_Buffer[ROW_NR],Text.AC_heating,PRT_Buffer[ROW_NR]) ,ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[FORCED AIR REMOVAL 1
Time (min): xx
Temperature (C): xx ]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_1_type,1)[JSR(Dint_to_String,2,Text.Time_min,Run.Forced_air_rem_time) ,JSR(Real_to_String,3,1,Text.Temp,Run.Forced_air_rem_temp) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 1
Number of pulses: xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(2,Run.Precond_1_type,3)JSR(Dint_to_String,2,Text.No_of_pulses,Run.Prec_1_Number_of_air_rem_pulses);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 1
First pulse type: xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(2,Run.Precond_1_type,3)[XIO(Run.Prec_1_First_pulse_type) CONCAT(Text.First_pulse,Text.Vacuum,PRT_Buffer[ROW_NR]) ,XIC(Run.Prec_1_First_pulse_type) CONCAT(Text.First_pulse,Text.Pressure,PRT_Buffer[ROW_NR]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 1
1st vacuum level: xx
1st vacuum hold time: xx
1st pressure level : xx
1st pressure hold time : xx
]]>
</Comment>
<Text>
<![CDATA[LIMIT(2,Run.Precond_1_type,3)[JSR(Real_to_String,3,2,Text.Vacuum_levels[1],Run.Prec_1_1st_vacuum_level) ,JSR(Dint_to_String,2,Text.Vacuum_times[2],Run.Prec_1_1st_vacuum_hold_time) ,JSR(Real_to_String,3,2,Text.Pressure_levels[1],Run.Prec_1_1st_pressure_level) ,JSR(Dint_to_String,2,Text.Pressure_times[1],Run.Prec_1_1st_pressure_hold_time) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 1
2nd vacuum level: xx
2nd vacuum hold time: xx
2nd pressure level : xx
2nd pressure hold time : xx
]]>
</Comment>
<Text>
<![CDATA[LIMIT(2,Run.Precond_1_type,3)[JSR(Real_to_String,3,2,Text.Vacuum_levels[2],Run.Prec_1_2nd_vacuum_level) ,JSR(Dint_to_String,2,Text.Vacuum_times[3],Run.Prec_1_2nd_vacuum_hold_time) ,JSR(Real_to_String,3,2,Text.Pressure_levels[2],Run.Prec_1_2nd_pressure_level) ,JSR(Dint_to_String,2,Text.Pressure_times[2],Run.Prec_1_2nd_pressure_hold_time) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 1
3rd vacuum level: xx
3rd vacuum hold time: xx
3rd pressure level : xx
3rd pressure hold time : xx
]]>
</Comment>
<Text>
<![CDATA[LIMIT(2,Run.Precond_1_type,3)[JSR(Real_to_String,3,2,Text.Vacuum_levels[3],Run.Prec_1_3rd_vacuum_level) ,JSR(Dint_to_String,2,Text.Vacuum_times[4],Run.Prec_1_3rd_vacuum_hold_time) ,JSR(Real_to_String,3,2,Text.Pressure_levels[3],Run.Prec_1_3rd_pressure_level) ,JSR(Dint_to_String,2,Text.Pressure_times[3],Run.Prec_1_3rd_pressure_hold_time) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[PRECONDITION 1:
Decontamination VIRASURE temperature setpoint 1 (C): 350 
Decontamination VIRASURE temperature setpoint 2 (C): 170]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_1_type,3)XIC(Option.DecV_process)[JSR(Real_to_String,3,1,Text.VIRASURE_temp_setpoint,350.0) ,JSR(Real_to_String,3,1,Text.VIRASURE_temp_setpoint_2,170.0) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[PRECONDITION 1:
Jacket heating during precondition: xx]]>
</Comment>
<Text>
<![CDATA[NE(Run.Precond_1_type,0)[XIO(Run.Prec_1_jacket_heat) CONCAT(Text.Jacket_heat_precond,Text.off,PRT_Buffer[ROW_NR]) ,XIC(Run.Prec_1_jacket_heat) CONCAT(Text.Jacket_heat_precond,Text.on,PRT_Buffer[ROW_NR]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[PRECONDITION 1:
SAMX HEATING UP
Temp/pressure table: xx C xx Psia/kPa]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_1_type,4)OTL(AC_precond)DTOS(Run.Number_of_precond_TP_values,prm_string)CONCAT(Text.AC_heat_table,prm_string,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR)[SUB(Run.Number_of_precond_TP_values,1,Last_point) ,FOR(Pressure_table,Point,0,Last_point,1) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[PRECOND 2 PARAMETERS
Air removal type 2: xx
]]>
</Comment>
<Text>
<![CDATA[NE(Run.Precond_2_type,0)[ADD(ROW_NR,1,ROW_NR) COP(Text.Prec2,PRT_Buffer[ROW_NR],1) ,EQ(Run.Precond_2_type,1) CONCAT(PRT_Buffer[ROW_NR],Text.Forced,PRT_Buffer[ROW_NR]) ,EQ(Run.Precond_2_type,2) CONCAT(PRT_Buffer[ROW_NR],Text.Pulsed,PRT_Buffer[ROW_NR]) ,ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[FORCED AIR REMOVAL 2
Time (min): xx
Temperature (C): xx ]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_2_type,1)[JSR(Dint_to_String,2,Text.Time_min,Run.Forced_air_rem_time) ,JSR(Real_to_String,3,1,Text.Temp,Run.Forced_air_rem_temp) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 2
Number of pulses: xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_2_type,2)JSR(Dint_to_String,2,Text.No_of_pulses,Run.Prec_2_Number_of_air_rem_pulses);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 2
First pulse type: xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_2_type,2)[XIO(Run.Prec_2_First_pulse_type) CONCAT(Text.First_pulse,Text.Vacuum,PRT_Buffer[ROW_NR]) ,XIC(Run.Prec_2_First_pulse_type) CONCAT(Text.First_pulse,Text.Pressure,PRT_Buffer[ROW_NR]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 2
1st vacuum level: xx
1st vacuum hold time: xx
1st pressure level : xx
1st pressure hold time : xx
]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_2_type,2)[JSR(Real_to_String,3,2,Text.Vacuum_levels[1],Run.Prec_2_1st_vacuum_level) ,JSR(Dint_to_String,2,Text.Vacuum_times[2],Run.Prec_2_1st_vacuum_hold_time) ,JSR(Real_to_String,3,2,Text.Pressure_levels[1],Run.Prec_2_1st_pressure_level) ,JSR(Dint_to_String,2,Text.Pressure_times[1],Run.Prec_2_1st_pressure_hold_time) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 2
2nd vacuum level: xx
2nd vacuum hold time: xx
2nd pressure level : xx
2nd pressure hold time : xx
]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_2_type,2)[JSR(Real_to_String,3,2,Text.Vacuum_levels[2],Run.Prec_2_2nd_vacuum_level) ,JSR(Dint_to_String,2,Text.Vacuum_times[3],Run.Prec_2_2nd_vacuum_hold_time) ,JSR(Real_to_String,3,2,Text.Pressure_levels[2],Run.Prec_2_2nd_pressure_level) ,JSR(Dint_to_String,2,Text.Pressure_times[2],Run.Prec_2_2nd_pressure_hold_time) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[PULSED AIR REMOVAL 2
3rd vacuum level: xx
3rd vacuum hold time: xx
3rd pressure level : xx
3rd pressure hold time : xx
]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precond_2_type,2)[JSR(Real_to_String,3,2,Text.Vacuum_levels[3],Run.Prec_2_3rd_vacuum_level) ,JSR(Dint_to_String,2,Text.Vacuum_times[4],Run.Prec_2_3rd_vacuum_hold_time) ,JSR(Real_to_String,3,2,Text.Pressure_levels[3],Run.Prec_2_3rd_pressure_level) ,JSR(Dint_to_String,2,Text.Pressure_times[3],Run.Prec_2_3rd_pressure_hold_time) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[PRECONDITION 2:
Jacket heating during precondition: xx]]>
</Comment>
<Text>
<![CDATA[NE(Run.Precond_2_type,0)[XIO(Run.Prec_2_jacket_heat) CONCAT(Text.Jacket_heat_precond,Text.off,PRT_Buffer[ROW_NR]) ,XIC(Run.Prec_2_jacket_heat) CONCAT(Text.Jacket_heat_precond,Text.on,PRT_Buffer[ROW_NR]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P1_Precycle" Type="RLL">
<Description>
<![CDATA[Precycle parameters print]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Print parameters: header]]>
</Comment>
<Text>
<![CDATA[COP(HDR_Buffer[0],PRT_Buffer[0],7)MOVE(8,ROW_NR)COP(Text.Prm_header,PRT_Buffer[ROW_NR],1)ADD(ROW_NR,2,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Cycle number]]>
</Comment>
<Text>
<![CDATA[DTOS(Process.Cycle_number,prm_string)CONCAT(Text.Cycle_number,prm_string,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Cycle Name]]>
</Comment>
<Text>
<![CDATA[CONCAT(Text.Cycle_name,Run.Cycle_name,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Created: date time]]>
</Comment>
<Text>
<![CDATA[CONCAT(Text.Created,Run.Created_time,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Created by: User name]]>
</Comment>
<Text>
<![CDATA[CONCAT(Text.Created_by,Run.Created_by,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Print type: SHORT]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)XIO(Run.Print_type)CONCAT(Text.Print_type,Text.Short,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Return and print header if print type is short ]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)XIO(Run.Print_type)RET();]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[PRETEST PARAMETERS
Pretest type: xx
]]>
</Comment>
<Text>
<![CDATA[NE(Run.Precycle_type,0)[ADD(ROW_NR,1,ROW_NR) COP(Text.PreTest,PRT_Buffer[ROW_NR],1) ,EQ(Run.Precycle_type,1) CONCAT(PRT_Buffer[ROW_NR],Text.FA_test,PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,2) CONCAT(PRT_Buffer[ROW_NR],Text.Din,PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,3) CONCAT(PRT_Buffer[ROW_NR],Text.VIRASURE_Flow_Test,PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,4) CONCAT(PRT_Buffer[ROW_NR],Text.VHP_parameters[0],PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,5) CONCAT(PRT_Buffer[ROW_NR],Text.Preheat,PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,6) CONCAT(PRT_Buffer[ROW_NR],Text.VHP_Biodec_parameters[0],PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,7) CONCAT(PRT_Buffer[ROW_NR],Text.VHP_Biodec_parameters[0],PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,8) CONCAT(PRT_Buffer[ROW_NR],Text.FIT_water_tank_sanitization,PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,9) CONCAT(PRT_Buffer[ROW_NR],Text.FIT_water_tank_filling,PRT_Buffer[ROW_NR]) ,EQ(Run.Precycle_type,10) CONCAT(PRT_Buffer[ROW_NR],Text.Filter_integrity_test,PRT_Buffer[ROW_NR]) ,ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
(also with VIRASURE Flow Test)
initial vacuum level : xx]]>
</Comment>
<Text>
<![CDATA[[LIMIT(1,Run.Precycle_type,2) JSR(Real_to_String,3,2,Text.Initial_vac_level,Run.FA_vacuum_test_level) ,EQ(Run.Precycle_type,3) JSR(Real_to_String,3,2,Text.Initial_vac_level,Run.VS_init_vacuum_level) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
Initial vacuum time (min): xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(1,Run.Precycle_type,2)JSR(Dint_to_String,2,Text.Initial_vac_time,Run.FA_vacuum_init_time);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
stabilization time (min): xx
(also with VIRASURE Flow Test but with seconds)
stabilization time (sec): xx]]>
</Comment>
<Text>
<![CDATA[[LIMIT(1,Run.Precycle_type,2) JSR(Dint_to_String,2,Text.Stabiliz_time,Run.FA_stabilizat_time) ,EQ(Run.Precycle_type,3) JSR(Dint_to_String,2,Text.VS_stabiliz_time,Run.VS_stabilizat_time) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
Vacuum test time (min): xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(1,Run.Precycle_type,2)JSR(Dint_to_String,2,Text.Vacuum_test_time,Run.FA_vacuum_test_time);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
Acceptable max leak (Psia): xx (with FA or DIN test)
Target vacuum level (Psia): xx (with VIRASURE flow test)]]>
</Comment>
<Text>
<![CDATA[[LIMIT(1,Run.Precycle_type,2) JSR(Real_to_String,3,2,Text.Accep_leak_rate,Run.FA_acceptable_leak_rate) ,EQ(Run.Precycle_type,3) JSR(Real_to_String,3,2,Text.VS_target_vac_level,Run.VS_test_target_vacuum_level) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
Pump state during stabilization: xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(1,Run.Precycle_type,2)[XIC(Run.FA_pump_during_stabil) CONCAT(Text.Pump_state,Text.on,PRT_Buffer[ROW_NR]) ,XIO(Run.FA_pump_during_stabil) CONCAT(Text.Pump_state,Text.off,PRT_Buffer[ROW_NR]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
VIRASURE Flow Test
Flow test time minimum (sec): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,3)JSR(Dint_to_String,2,Text.VS_flow_min_time,Run.VS_test_min_time);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[LEAK RATE TEST PARAMETERS
VIRASURE Flow Test
Flow test time maximum (sec): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,3)JSR(Dint_to_String,2,Text.VS_flow_max_time,Run.VS_test_max_time);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[VHP PARAMETERS
Total sterilization time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,4)JSR(Dint_to_String,2,Text.VHP_parameters[1],HMI.VHP_Sterilization_time);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[VHP PARAMETERS
ST door open time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,4)JSR(Dint_to_String,2,Text.VHP_parameters[2],Run.VHP_Door_open_time);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[VHP PARAMETERS
ST door cycling  time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,4)JSR(Dint_to_String,2,Text.VHP_parameters[3],Run.VHP_Door_cycling_time);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[VHP PARAMETERS
ST door sealing  time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,4)JSR(Dint_to_String,2,Text.VHP_parameters[4],Run.VHP_Door_sealing_time);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[VHP PARAMETERS
Chamber max Temperature (C): xx ]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,4)JSR(Real_to_String,3,1,Text.VHP_parameters[5],Run.VHP_Chamber_max_temp);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[VHP BIODEC 10.4.41 PARAMETERS
Dehumidification time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,6)JSR(Dint_to_String,2,Text.VHP_Biodec_parameters[1],Run.VHP_Dehumidification_time);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[VHP BIODEC 10.4.41 PARAMETERS
Aeration time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,6)JSR(Dint_to_String,2,Text.VHP_Biodec_parameters[2],Run.VHP_Aeration_time);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[PREHEATING PARAMETERS
Preheating time (min): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,5)JSR(Dint_to_String,2,Text.Preheat_time,Run.Preheat_time);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[PREHEATING PARAMETERS
Preheating temperature(C): xx]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,5)JSR(Real_to_String,3,1,Text.Preheat_temp,Run.Preheat_temp);]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[FIT WATER TANK SANITIZATION PARAMETERS]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,8)[JSR(Dint_to_String,2,Text.FIT_sanitization_time,Run.FIT_Sanitization_time) ,JSR(Real_to_String,3,1,Text.FIT_sanitization_temp,Run.FIT_Sanitization_temp) ,JSR(Dint_to_String,2,Text.FIT_cooling_time,Run.FIT_Sanitiz_cooling_time) ];]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[FIT TANK FILLING PARAMETERS]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,9)JSR(Dint_to_String,2,Text.FIT_filling_time,Run.FIT_Tank_filling_time);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[FILTER INTEGRITY TEST PARAMETERS]]>
</Comment>
<Text>
<![CDATA[EQ(Run.Precycle_type,10)[JSR(Real_to_String,3,2,Text.FIT_test_pressure,Run.FIT_Test_pressure) ,JSR(Dint_to_String,2,Text.FIT_test_time,Run.FIT_Test_time) ,JSR(Dint_to_String,2,Text.FIT_stabilization_time,Run.FIT_Stabilization_time) ,JSR(Real_to_String,3,1,Text.FIT_max_temp_difference,Run.FIT_Max_temp_difference) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P1_StartHeader" Type="RLL">
<Description>
<![CDATA[Cycle start header]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Start header when cycle is started

Batch number: xx
started: date time
started by: user name]]>
</Comment>
<Text>
<![CDATA[[ADD(ROW_NR,1,ROW_NR) CONCAT(Text.Batch,Process.batch_ID,PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ,CONCAT(Text.Started,time_date,PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ,CONCAT(Text.Started_by,User_name,PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Cycle counter: xx]]>
</Comment>
<Text>
<![CDATA[[DTOS(Cycles.Counter,prm_string) CONCAT(Text.Cycles_started,prm_string,PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ,EQ(Option.Printer_type,2) CONCAT(PRT_Buffer[ROW_NR],Help_char[12],PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Start header when cycle is running
Measurement header]]>
</Comment>
<Text>
<![CDATA[ADD(ROW_NR,1,ROW_NR)COP(Text.Start_header,PRT_Buffer[ROW_NR],1)[XIC(Option.Filter_ster) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tf,PRT_Buffer[ROW_NR]) ,CONCAT(PRT_Buffer[ROW_NR],Help_char[3],PRT_Buffer[ROW_NR]) ,CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tch,PRT_Buffer[ROW_NR]) ,XIC(Option.Load_1) CONCAT(PRT_Buffer[ROW_NR],Text.Start_T1,PRT_Buffer[ROW_NR]) ,XIC(Option.Load_2) CONCAT(PRT_Buffer[ROW_NR],Text.Start_T2,PRT_Buffer[ROW_NR]) ,XIC(Option.Load_3) CONCAT(PRT_Buffer[ROW_NR],Text.Start_T3,PRT_Buffer[ROW_NR]) ,XIC(Option.Load_4) CONCAT(PRT_Buffer[ROW_NR],Text.Start_T4,PRT_Buffer[ROW_NR]) ,XIC(Option.Air_detector) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tad,PRT_Buffer[ROW_NR]) ,XIC(Option.DEC_process) [XIO(Option.DecV_process) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tdc,PRT_Buffer[ROW_NR]) ,XIC(Option.DecV_process) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tvs,PRT_Buffer[ROW_NR]) CONCAT(PRT_Buffer[ROW_NR],Help_char[3],PRT_Buffer[ROW_NR]) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tvs1,PRT_Buffer[ROW_NR]) CONCAT(PRT_Buffer[ROW_NR],Help_char[3],PRT_Buffer[ROW_NR]) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tvs2,PRT_Buffer[ROW_NR]) ] ,XIC(Option.SAMX_process) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tac1,PRT_Buffer[ROW_NR]) ,XIC(Option.SAMX_process) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tac2,PRT_Buffer[ROW_NR]) ,LIMIT(8,Run.Precycle_type,10) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Pf,PRT_Buffer[ROW_NR]) ,LIMIT(8,Run.Precycle_type,10) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tfi,PRT_Buffer[ROW_NR]) ,LIMIT(8,Run.Precycle_type,10) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tw,PRT_Buffer[ROW_NR]) ,LIMIT(8,Run.Precycle_type,10) CONCAT(PRT_Buffer[ROW_NR],Text.Start_Tsa,PRT_Buffer[ROW_NR]) ,ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P2_Phase" Type="RLL">
<Description>
<![CDATA[Phase print]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Phase text according phase number]]>
</Comment>
<Text>
<![CDATA[CONCAT(time,Text.Phase[Process.Phase_number],Phase_text);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Phase text according phase number]]>
</Comment>
<Text>
<![CDATA[XIC(Data_save)[COP(Phase_text,LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P3_Measurements" Type="RLL">
<Description>
<![CDATA[Print process values]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Measurement print time]]>
</Comment>
<Text>
<![CDATA[COP(Empty_line,meas_text,1)CONCAT(time,Help_char[3],meas_text);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Add '**' in front of measurement data when step changes ]]>
</Comment>
<Text>
<![CDATA[[NE(Process.Step,Print_step) CONCAT(meas_text,Help_char[6],meas_text) ,EQ(Process.Step,Print_step) CONCAT(meas_text,Help_char[9],meas_text) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Time ( Total cycle time from start)]]>
</Comment>
<Text>
<![CDATA[[DTOS(Cycle_time_min,prm_string) [EQ(prm_string.LEN,1) INSERT(prm_string,Help_char[7],2,prm_string) ,EQ(prm_string.LEN,2) INSERT(prm_string,Help_char[9],3,prm_string) ,EQ(prm_string.LEN,3) INSERT(prm_string,Help_char[3],4,prm_string) ] ,CONCAT(meas_text,prm_string,meas_text) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[F0mom]]>
</Comment>
<Text>
<![CDATA[MUL(FO_value[0],100,F0_mom)DTOS(F0_mom,prm_string)[EQ(F0_mom,0) INSERT(prm_string,Help_char[15],2,prm_string) ,LIMIT(1,F0_mom,9) INSERT(prm_string,Help_char[11],1,prm_string) ,LIMIT(10,F0_mom,99) INSERT(prm_string,Help_char[2],1,prm_string) ,LIMIT(100,F0_mom,999) INSERT(prm_string,Help_char[1],2,prm_string) ,LIMIT(1000,F0_mom,9999) DIV(F0_mom,10,F0_mom_real) MOVE(F0_mom_real,F0_mom) DTOS(F0_mom,prm_string) INSERT(prm_string,Help_char[1],3,prm_string) ,EQ(prm_string.LEN,3) INSERT(prm_string,Help_char[9],5,prm_string) ,EQ(prm_string.LEN,4) INSERT(prm_string,Help_char[3],5,prm_string) ,CONCAT(meas_text,prm_string,meas_text) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[F0tot]]>
</Comment>
<Text>
<![CDATA[[OTL(Meas) JSR(Real_to_String,3,1,Help_char[3],FO_value[6]) ,XIO(Meas) GE(FO_value[6],100) MOVE(FO_value[6],F0_tot) DTOS(F0_tot,prm_string) ,XIO(Meas) EQ(prm_string.LEN,3) EQ(prm_string.LEN,2) INSERT(prm_string,Help_char[3],4,prm_string) ,XIO(Meas) EQ(prm_string.LEN,4) EQ(prm_string.LEN,2) INSERT(prm_string,Help_char[3],5,prm_string) ,XIO(Meas) CONCAT(meas_text,prm_string,meas_text) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Chamber pressure ( ): xx]]>
</Comment>
<Text>
<![CDATA[JSR(Real_to_String,3,2,Empty_line,PT549_Chamber.Pressure_mBar);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[jacket temperature : xx]]>
</Comment>
<Text>
<![CDATA[JSR(Real_to_String,3,1,Help_char[3],TE518_Jacket.Temperature);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Filter temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Filter_ster)JSR(Real_to_String,3,1,Help_char[3],TE517_1_Filter.Temperature);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Force line feed if alfapanel is selected]]>
</Comment>
<Text>
<![CDATA[EQ(Option.Printer_type,0)[XIC(Data_save) COP(PRT_Buffer[ROW_NR],LastCycle[S_Pointer],1) ,XIO(Data_save) ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Chamber temperature : xx]]>
</Comment>
<Text>
<![CDATA[JSR(Real_to_String,3,1,Help_char[3],TE517_Chamber.Temperature);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Load 1 temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Load_1)[XIC(Run.Load_1) JSR(Real_to_String,3,1,Help_char[3],TE788_1_Load1.Temperature) ,XIO(Run.Load_1) CONCAT(meas_text,Help_char[13],meas_text) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Load 2 temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Load_2)[XIC(Run.Load_2) JSR(Real_to_String,3,1,Help_char[3],TE788_2_Load2.Temperature) ,XIO(Run.Load_2) CONCAT(meas_text,Help_char[13],meas_text) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Load 3 temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Load_3)[XIC(Run.Load_3) JSR(Real_to_String,3,1,Help_char[3],TE788_3_Load3.Temperature) ,XIO(Run.Load_3) CONCAT(meas_text,Help_char[13],meas_text) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Load 4 temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Load_4)[XIC(Run.Load_4) JSR(Real_to_String,3,1,Help_char[3],TE788_4_Load4.Temperature) ,XIO(Run.Load_4) CONCAT(meas_text,Help_char[13],meas_text) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Air detection temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Air_detector)JSR(Real_to_String,3,1,Help_char[3],TE520_Air_detect.Temperature);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[FIT pressure ( ): xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(8,Run.Precycle_type,10)JSR(Real_to_String,3,2,Empty_line,PT1004_Filter_FIT.Pressure_mBar);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[FIT temperature : xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(8,Run.Precycle_type,10)JSR(Real_to_String,3,1,Help_char[3],TE1018_Filter_FIT.Temperature);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[FIT water tank temperature : xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(8,Run.Precycle_type,10)JSR(Real_to_String,3,1,Help_char[3],TE1018_2_FIT_Water_Tank.Temperature);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[FIT water tank sanitization temperature : xx]]>
</Comment>
<Text>
<![CDATA[LIMIT(8,Run.Precycle_type,10)JSR(Real_to_String,3,1,Help_char[3],TE517_5_FIT_Sanitization.Temperature);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[DEC filter temperature or DEC VIRASURE average temperature: xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DEC_process)[XIO(Option.DecV_process) JSR(Real_to_String,3,1,Help_char[3],TE517_2_DEC.Temperature) ,XIC(Option.DecV_process) JSR(Real_to_String,3,1,Help_char[9],VIRASURE_Temperature) ];]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[DEC VIRASURE 1 temperature (TE527.3): xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DEC_process)XIC(Option.DecV_process)JSR(Real_to_String,3,1,Help_char[9],TE527_3_VIRASURE.Temperature);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[DEC VIRASURE 2 temperature (TE527.2): xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DEC_process)XIC(Option.DecV_process)JSR(Real_to_String,3,1,Help_char[3],TE527_2_VIRASURE.Temperature);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[TE517.3 SAMX Ejector temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SAMX_process)JSR(Real_to_String,3,1,Help_char[3],TE517_3_Chamber.Temperature);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[TE517.3 SAMX Ejector temperature : xx]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SAMX_process)JSR(Real_to_String,3,1,Help_char[3],TE517_4_Chamber.Temperature);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[Save measurements for cycle data print]]>
</Comment>
<Text>
<![CDATA[OTU(Meas)[XIC(Data_save) NE(P_comm,3) [COP(meas_text,LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ] ,XIO(Data_save) COP(meas_text,PRT_Buffer[0],1) MOVE(1,ROW_NR) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P4_Alarm" Type="RLL">
<Description>
<![CDATA[Print alarms]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Alarm store pointer]]>
</Comment>
<Text>
<![CDATA[[GT(A_pointer,0) OTL(Store_Alarms) SUB(A_pointer,1,A_pointer) ,EQ(A_pointer,0) OTU(Store_Alarms) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Store alarm text for cycle data print]]>
</Comment>
<Text>
<![CDATA[[XIO(Data_save) COP(Alarm_print[A_pointer],PRT_Buffer[0],1) MOVE(1,ROW_NR) ,XIC(Data_save) [COP(Alarm_print[A_pointer],LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ] ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Store alarm text for print alarm history command]]>
</Comment>
<Text>
<![CDATA[FOR(Alarm_history,A_index,98,0,-1)COP(Alarm_print[A_pointer],Alarm_stack[0],1)CONCAT(Help_char[3],Alarm_stack[0],Alarm_stack[0])CONCAT(Print_date[3],Alarm_stack[0],Alarm_stack[0]);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P6_Cycle_data" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Print cycle data during cycle]]>
</Comment>
<Text>
<![CDATA[EQ(P_comm,6)[XIO(ReadyToPrint) ,XIC(S:FS) ][TON(Print_delay,?,?) ,XIC(Print_delay.DN) ONS(readytoprint_oneshot) OTL(ReadyToPrint) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Clear print command + Handshake with PVplus6]]>
</Comment>
<Text>
<![CDATA[XIC(PrintingDone)[CLR(P_comm) ,OTU(PrintingDone) ,OTU(ReadyToPrint) ,RES(Print_delay) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(ReadyToPrint)[TON(print_error_timer,?,?) ,XIC(print_error_timer.DN) OTL(PrintingDone) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P7_PID_Values" Type="RLL">
<Description>
<![CDATA[Print PID values]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[PRINTOUT OF PID VALUES
Header]]>
</Comment>
<Text>
<![CDATA[COP(HDR_Buffer[0],PRT_Buffer[0],7)MOVE(8,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[PRINTOUT OF PID VALUES
PID header]]>
</Comment>
<Text>
<![CDATA[COP(Text.PID_header,PRT_Buffer[ROW_NR],1)ADD(ROW_NR,2,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Chamber PID loop]]>
</Comment>
<Text>
<![CDATA[[COP(Text.Chamber_PID,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.PID_gain,HMI.PID_chamber_P) ,JSR(Dint_to_String,2,Text.PID_integral,HMI.PID_chamber_I) ,JSR(Dint_to_String,2,Text.PID_deriv,HMI.PID_chamber_D) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Filter PID loop]]>
</Comment>
<Text>
<![CDATA[XIC(Option.Filter_ster)[ADD(ROW_NR,1,ROW_NR) COP(Text.Filter_PID,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.PID_gain,HMI.PID_filter_P) ,JSR(Dint_to_String,2,Text.PID_integral,HMI.PID_filter_I) ,JSR(Dint_to_String,2,Text.PID_deriv,HMI.PID_filter_D) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[DEC Filter PID loop]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DEC_process)[ADD(ROW_NR,1,ROW_NR) COP(Text.DEC_PID,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.PID_gain,HMI.PID_DEC_P) ,JSR(Dint_to_String,2,Text.PID_integral,HMI.PID_DEC_I) ,JSR(Dint_to_String,2,Text.PID_deriv,HMI.PID_DEC_D) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[VIRASURE temperature control PID loop]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DecV_process)[ADD(ROW_NR,1,ROW_NR) COP(Text.VIRASURE_PID,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.PID_gain,HMI.PID_DEC_VS_P) ,JSR(Dint_to_String,2,Text.PID_integral,HMI.PID_DEC_VS_I) ,JSR(Dint_to_String,2,Text.PID_deriv,HMI.PID_DEC_VS_D) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[SAMX PCV119 Bleeder PID loop]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SAMX_process)[ADD(ROW_NR,1,ROW_NR) COP(Text.SAMX_Bleeder_PID,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.PID_gain,HMI.PID_SAMX_pressure_P) ,JSR(Dint_to_String,2,Text.PID_integral,HMI.PID_SAMX_pressure_I) ,JSR(Dint_to_String,2,Text.PID_deriv,HMI.PID_SAMX_pressure_D) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P8_Calibrations" Type="RLL">
<Description>
<![CDATA[Print calibration values]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[CALIBRATION DATAS
Header]]>
</Comment>
<Text>
<![CDATA[COP(HDR_Buffer[0],PRT_Buffer[0],7)MOVE(9,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[PRINTOUT OF CALIBRATION VALUES
Calibration header]]>
</Comment>
<Text>
<![CDATA[COP(Text.Calib_header,PRT_Buffer[ROW_NR],1)ADD(ROW_NR,2,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Chamber Pressure low point text Psia]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Press_unit) MUL(PT549_Chamber.Scale_value_min,0.0145,Press_scale_value) MUL(PT549_Chamber.Previous_calib_min,0.0145,Press_prev_value) ,XIO(Option.Press_unit) DIV(PT549_Chamber.Scale_value_min,10,Press_scale_value) DIV(PT549_Chamber.Previous_calib_min,10,Press_prev_value) ,JSR(Calib_point_text,6,Text.Probes[0],Text.low_point,PT549_Chamber.Calib_low_time,PT549_Chamber.Calib_low_user,Press_scale_value,Press_prev_value) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Chamber Pressure high point text]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Press_unit) MUL(PT549_Chamber.Scale_value_max,0.0145,Press_scale_value) MUL(PT549_Chamber.Previous_calib_max,0.0145,Press_prev_value) ,XIO(Option.Press_unit) DIV(PT549_Chamber.Scale_value_max,10,Press_scale_value) DIV(PT549_Chamber.Previous_calib_max,10,Press_prev_value) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,PT549_Chamber.Calib_high_time,PT549_Chamber.Calib_high_user,Press_scale_value,Press_prev_value) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Filter FIT Pressure low point text Psia]]>
</Comment>
<Text>
<![CDATA[ADD(ROW_NR,2,ROW_NR)[XIC(Option.Press_unit) MUL(PT1004_Filter_FIT.Scale_value_min,0.0145,Press_scale_value) MUL(PT1004_Filter_FIT.Previous_calib_min,0.0145,Press_prev_value) ,XIO(Option.Press_unit) DIV(PT1004_Filter_FIT.Scale_value_min,10,Press_scale_value) DIV(PT1004_Filter_FIT.Previous_calib_min,10,Press_prev_value) ,JSR(Calib_point_text,6,Text.Probes[8],Text.low_point,PT1004_Filter_FIT.Calib_low_time,PT1004_Filter_FIT.Calib_low_user,Press_scale_value,Press_prev_value) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Filter FIT Pressure high point text]]>
</Comment>
<Text>
<![CDATA[[XIC(Option.Press_unit) MUL(PT1004_Filter_FIT.Scale_value_max,0.0145,Press_scale_value) MUL(PT1004_Filter_FIT.Previous_calib_max,0.0145,Press_prev_value) ,XIO(Option.Press_unit) DIV(PT1004_Filter_FIT.Scale_value_max,10,Press_scale_value) DIV(PT1004_Filter_FIT.Previous_calib_max,10,Press_prev_value) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,PT1004_Filter_FIT.Calib_high_time,PT1004_Filter_FIT.Calib_high_user,Press_scale_value,Press_prev_value) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Chamber temperature calibration values]]>
</Comment>
<Text>
<![CDATA[ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[1],Text.low_point,TE517_Chamber.Calib_low_time,TE517_Chamber.Calib_low_user,TE517_Chamber.Scale_value_min,TE517_Chamber.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE517_Chamber.Calib_high_time,TE517_Chamber.Calib_high_user,TE517_Chamber.Scale_value_max,TE517_Chamber.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[AC / SAMX Chamber temperature calibration values]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SAMX_process)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[11],Text.low_point,TE517_3_Chamber.Calib_low_time,TE517_3_Chamber.Calib_low_user,TE517_3_Chamber.Scale_value_min,TE517_3_Chamber.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE517_3_Chamber.Calib_high_time,TE517_3_Chamber.Calib_high_user,TE517_3_Chamber.Scale_value_max,TE517_3_Chamber.Previous_calib_max) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[AC / SAMX Secondary Chamber temperature calibration values]]>
