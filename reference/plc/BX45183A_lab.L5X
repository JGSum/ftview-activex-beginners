<Text>
<![CDATA[XIC(Option.SAMX_process)ADD(ROW_NR,2,ROW_NR)[JSR(Calib_point_text,6,Text.Probes[12],Text.low_point,TE517_4_Chamber.Calib_low_time,TE517_4_Chamber.Calib_low_user,TE517_4_Chamber.Scale_value_min,TE517_4_Chamber.Previous_calib_min) ,JSR(Calib_point_text,6,Empty_line,Text.high_point,TE517_4_Chamber.Calib_high_time,TE517_4_Chamber.Calib_high_user,TE517_4_Chamber.Scale_value_max,TE517_4_Chamber.Previous_calib_max) ];]]>
