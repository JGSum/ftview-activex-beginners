</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[YY663 PV162 PV163 Pressure exhaust ST seal]]>
</Comment>
<Text>
<![CDATA[[LIMIT(5,Process.Step,6) ,LIMIT(25,Process.Step,27) ,LIMIT(50,Process.Step,55) ,XIC(Step_bit[1].24) XIO(DIG_IN[1].16) ,EQ(Process.Service_cycle,1) ]OTE(DIG_OUT[1].9);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Recorder" Type="RLL">
<Description>
<![CDATA[Communication with recorder]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[EN285
Read reference pressure and temperature from recorder

Psia and mbar units are needed for SCADA. 
mbar unit is needed for alarm calculation.]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Test_AI_recorder)[[XIO(Option.Press_unit) MOVE(GX10:I.Data[0],PT550_pressure_kpa) DIV(GX10:I.Data[0],0.145,PT550_pressure_psia) DIV(GX10:I.Data[0],10,PT550_pressure_mbar) ,XIC(Option.Press_unit) MOVE(GX10:I.Data[0],PT550_pressure_psia) MUL(GX10:I.Data[0],6.89476,PT550_pressure_kpa) DIV(PT550_pressure_psia,0.0145,PT550_pressure_mbar) ] ,MOVE(GX10:I.Data[1],TE798_1_temperature) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[EN285
Read pressure and temperature differences from recorder]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Test_AI_recorder)[[XIO(Option.Press_unit) MOVE(GX10:I.Data[2],EN285_press_diff_kpa) DIV(GX10:I.Data[2],0.145,EN285_press_diff_psia) MUL(GX10:I.Data[2],10,EN285_press_diff_mbar) ,XIC(Option.Press_unit) MOVE(GX10:I.Data[2],EN285_press_diff_psia) MUL(GX10:I.Data[2],6.89476,EN285_press_diff_kpa) DIV(GX10:I.Data[2],0.0145,EN285_press_diff_mbar) ] ,MOVE(GX10:I.Data[3],EN285_temp_diff) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[EN285
Send control pressure and temperature measurements to the recorder]]>
</Comment>
<Text>
<![CDATA[[[XIO(Option.Press_unit) DIV(PT549_Chamber.Pressure_mBar,10,GX10:O.Data[0]) ,XIC(Option.Press_unit) MOVE(PT549_Chamber_Pressure_Psia,GX10:O.Data[0]) ] ,MOVE(TE517_Chamber.Temperature,GX10:O.Data[1]) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Reset values if connection is lost]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Test_Recorder_diagnostics)GSV(MODULE,GX10,EntryStatus,Recorder_status)NE(Recorder_status,16384)[MOVE(0,GX10:I.Data[0]) ,MOVE(0,GX10:I.Data[1]) ,MOVE(999,GX10:I.Data[2]) ,MOVE(999,GX10:I.Data[3]) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
