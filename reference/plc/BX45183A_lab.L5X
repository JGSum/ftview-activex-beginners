<Routines>
<Routine Name="Alarm_history" Type="RLL">
<Description>
<![CDATA[Line copy subroutine for alarm history]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Move alarm history data forward and make space for new data]]>
</Comment>
<Text>
<![CDATA[SBR()[ADD(A_index,1,A_line_next) COP(Alarm_stack[A_index],Alarm_stack[A_line_next],1) ,RET() ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Calib_point_text" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Calib probe name]]>
</Comment>
<Text>
<![CDATA[SBR(Probe_name,Point_text,Calib_time,Calib_user,Calib_setpoint,Calib_prev)COP(Probe_name,PRT_Buffer[ROW_NR],1)[EQ(Probe_name,Text.Probes[0]) CONCAT(PRT_Buffer[ROW_NR],Press_unit,PRT_Buffer[ROW_NR]) ,NE(Probe_name,Text.Probes[0]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Calib point time and user]]>
</Comment>
<Text>
<![CDATA[[COP(Point_text,PRT_Buffer[ROW_NR],1) CONCAT(PRT_Buffer[ROW_NR],Calib_time,PRT_Buffer[ROW_NR]) CONCAT(PRT_Buffer[ROW_NR],Help_char[3],PRT_Buffer[ROW_NR]) CONCAT(PRT_Buffer[ROW_NR],Calib_user,PRT_Buffer[ROW_NR]) ,ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Calib point values
SETPOINT: xx]]>
</Comment>
<Text>
<![CDATA[JSR(Real_to_String,3,1,Text.setpoint,Calib_setpoint);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Calib point values
PREV: xx]]>
</Comment>
<Text>
<![CDATA[JSR(Real_to_String,3,1,Text.Previous,Calib_prev);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Calib point values
DIFF: xx]]>
</Comment>
<Text>
<![CDATA[SUB(Calib_setpoint,Calib_prev,Calib_difference)JSR(Real_to_String,3,1,Text.Difference,Calib_difference);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[return calibration point text]]>
</Comment>
<Text>
<![CDATA[RET();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Cycle_Summary" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Cycle Summary

Topic

]]>
</Comment>
<Text>
<![CDATA[OTL(FIT_printing)[LT(S_Pointer,2499) ADD(S_Pointer,2,S_Pointer) ,XIO(Process.Cycle_aborted) XIC(Process.FIT_OK) COP(Text.FIT_result_pass,LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ,[XIC(Process.Cycle_aborted) ,XIO(Process.FIT_OK) ] COP(Text.FIT_result_fail,LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,2,S_Pointer) ,COP(Text.FIT_summary,LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[FIT result printing]]>
</Comment>
<Text>
<![CDATA[[JSR(Real_to_String,3,1,Text.FIT_test_temp,Process.FIT_Test_temperature) ,OTL(FIT_print_2decimal) JSR(Real_to_String,3,1,Text.FIT_max_flow_rate,Process.FIT_Max_Flow_rate) ,JSR(Real_to_String,3,1,Text.FIT_flow_rate_at_end,Process.FIT_Flow_rate_end) ,OTU(FIT_print_2decimal) OTU(FIT_printing) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Dint_to_String" Type="RLL">
<Description>
<![CDATA[Make print text for
time / value]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[This subroutine adds decimal point for value string
Move dinteger value to help string when Psia is selected]]>
</Comment>
<Text>
<![CDATA[SBR(Prm_text,prm_dint)DTOS(prm_dint,prm_string);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Add value string to print buffer]]>
</Comment>
<Text>
<![CDATA[CONCAT(Prm_text,prm_string,PRT_Buffer[ROW_NR])ADD(ROW_NR,1,ROW_NR)RET();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P10_Login_Step_Wait" Type="RLL">
<Description>
<![CDATA[User login print or Step or Wait pressed
or LRT result]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[User login data for print]]>
</Comment>
<Text>
<![CDATA[CONCAT(time,Text.login_by,P10_text)CONCAT(P10_text,User_name,P10_text);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Step pressed by: xxxx]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Step_pressed)CONCAT(time,Text.Step_pressed,P10_text)CONCAT(P10_text,User_name,P10_text);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Wait pressed by: xxxx]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Wait_pressed)EQ(Wait_press_status,0)[CONCAT(time,Text.Wait_pressed,P10_text) CONCAT(P10_text,User_name,P10_text) ,MOVE(1,Wait_press_status) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Wait released by: xxxx]]>
</Comment>
<Text>
<![CDATA[XIO(HMI.Wait_pressed)EQ(Wait_press_status,1)[CONCAT(time,Text.Wait_released,P10_text) CONCAT(P10_text,User_name,P10_text) ,CLR(Wait_press_status) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Save print data for cycle printout]]>
</Comment>
<Text>
<![CDATA[XIC(Data_save)[COP(P10_text,LastCycle[S_Pointer],1) ,LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Move data to to print buffer if cycle is not running]]>
</Comment>
<Text>
<![CDATA[XIO(Data_save)[COP(P10_text,PRT_Buffer[ROW_NR],1) ,ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="P11_Common_settings" Type="RLL">
<Description>
<![CDATA[Print Common Settings]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[PRINTOUT OF COMMON SETTINGS
Header]]>
</Comment>
<Text>
<![CDATA[COP(HDR_Buffer[0],PRT_Buffer[0],7)MOVE(8,ROW_NR)COP(Text.CommonS_header,PRT_Buffer[ROW_NR],1)ADD(ROW_NR,2,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[JACKET CONTROL:
Jacket heating during Standby: xx]]>
</Comment>
<Text>
<![CDATA[COP(Text.Jacket_control,PRT_Buffer[ROW_NR],1)ADD(ROW_NR,1,ROW_NR)[XIO(Common_set.Jacket_heat_standby) CONCAT(Text.Jacket_heat_standby,Text.off,PRT_Buffer[ROW_NR]) ,XIC(Common_set.Jacket_heat_standby) CONCAT(Text.Jacket_heat_standby,Text.on,PRT_Buffer[ROW_NR]) ]ADD(ROW_NR,1,ROW_NR);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[JACKET CONTROL:
Minimum temp for cycle start: xx
Jacket temperature setpoint: xx
Initial jacket fill time: xx
jacket cooling temp: xx
jacket draining delay: xx]]>
</Comment>
<Text>
<![CDATA[[JSR(Real_to_String,3,1,Text.Jacket_start_min,Common_set.Jacket_start_min_limit) ,JSR(Real_to_String,3,1,Text.Jacket_temp_setpoint,Common_set.Jacket_temp_setpoint) ,XIC(Option.C_process) XIO(Option.Jacket_closed_loop) JSR(Dint_to_String,2,Text.Jacket_fill_time,Common_set.Jacket_fill_time) ,XIC(Option.C_process) XIO(Option.Jacket_closed_loop) JSR(Real_to_String,3,1,Text.Jacket_cooling_temp,Common_set.Jacket_outlet_temp) ,XIC(Option.C_process) XIO(Option.Jacket_closed_loop) JSR(Dint_to_String,2,Text.Jacket_draining_time,Common_set.Jacket_draining_delay) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[PROCESS CONTROL:
Door unsealing delay: xx sec
Equalization abort vacuum level: xx Psia
Equalization abort vacuum delay: xx
Circulation tank draining (min): xx
Cycle counter for tank draining: xxx pcs
Cooling delay: xx
SAMX settings
DEC abort condensate vacuum (level): xx Psia
DEC abort condens heat time (min): xx
SCADA handshake used: OFF/ON]]>
</Comment>
<Text>
<![CDATA[[COP(Text.Process_cntrl,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.Door_unseal_time,Common_set.Door_unsealing_delay) ,JSR(Real_to_String,3,2,Text.Equalization_abort_level,Common_set.Equaliation_vacuum_level) ,JSR(Dint_to_String,2,Text.Equalization_abort_delay,Common_set.Equalization_vacuum_delay) ,[XIC(Option.Tank_LS896) ,XIC(Option.Vac_Pump_Water_Save) ] [JSR(Dint_to_String,2,Text.Circulation_tank_draining_time,Common_set.Circulation_tank_draining_time) ,JSR(Dint_to_String,2,Text.Cycle_counter_for_tank_draining,Common_set.Cycle_counter_for_tank_draining) ] ,[XIC(Option.C_process) ,XIC(Option.CA_process) ,XIC(Option.SAMX_process) ] JSR(Dint_to_String,2,Text.Cooling_delay,Common_set.Cooling_delay) ,XIC(Option.SAMX_process) JSR(Real_to_String,3,1,Text.SAMX_Bleed_Closing,Common_set.SAMX_Bleeder_closing_rate) ,XIC(Option.SAMX_process) JSR(Dint_to_String,2,Text.SAMX_Bleed_Opening,Common_set.SAMX_Bleeder_opening_min) ,XIC(Option.SAMX_process) JSR(Real_to_String,3,2,Text.SAMX_Reaction_lim,Common_set.SAMX_Bleeder_Press_dev_reac_limit) ,XIC(Option.SAMX_process) JSR(Real_to_String,3,1,Text.SAMX_Bleed_Reaction,Common_set.SAMX_Bleeder_reaction_rate) ,XIC(Option.SAMX_process) JSR(Real_to_String,3,1,Text.SAMX_Steam_Open_Rate,Common_set.SAMX_Steam_valve_opening_rate) ,XIC(Option.SAMX_process) JSR(Real_to_String,3,1,Text.SAMX_Auto_Mode_Temp,Common_set.SAMX_Steam_valve_auto_mode_temp) ,XIC(Option.DEC_process) JSR(Real_to_String,3,2,Text.DEC_abort_condensate_vac_lev,Common_set.DEC_abort_condensate_vacuum_level) ,XIC(Option.DEC_process) JSR(Dint_to_String,2,Text.DEC_abort_condensate_heat_time,Common_set.DEC_abort_condensate_heating_time) ,XIC(Option.SCADA_Handshake) [XIO(Common_set.SCADA_handshake) CONCAT(Text.SCADA_Handshake,Text.off,PRT_Buffer[ROW_NR]) ,XIC(Common_set.SCADA_handshake) CONCAT(Text.SCADA_Handshake,Text.on,PRT_Buffer[ROW_NR]) ] ADD(ROW_NR,1,ROW_NR) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[ALARM SETTINGS
Air in chamber alarm delay: xx sec
Air in chamber alarm limit: xx Psia
Temp deviation alarm delay: xx sec
Temp deviation alarm abort delay: xx sec
Filter heat up delay: xx sec]]>
</Comment>
<Text>
<![CDATA[[COP(Text.Alarm_settings,PRT_Buffer[ROW_NR],1) ADD(ROW_NR,1,ROW_NR) ,JSR(Dint_to_String,2,Text.Alarm_air_in_ch_delay,Common_set.Air_in_chamber_delay) ,JSR(Real_to_String,3,2,Text.Alarm_air_in_ch_limit,Common_set.Air_in_chamber_limit) ,JSR(Dint_to_String,2,Text.Alarm_temp_dev_delay,Common_set.Temp_dev_activation_delay) ,JSR(Dint_to_String,2,Text.Alarm_temp_dev_abort,Common_set.Temp_dev_abort_delay) ,XIC(Option.Filter_ster) JSR(Dint_to_String,2,Text.Alarm_Filter_heat_delay,Common_set.Filter_heat_up_delay) ];]]>
</Text>
