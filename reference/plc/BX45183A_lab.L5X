<Routines>
<Routine Name="Overshoot" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set overshoot calculation active]]>
</Comment>
<Text>
<![CDATA[[XIC(Step_bit[0].14) ,XIC(Step_bit[2].0) ,XIC(Step_bit[2].17) ]XIC(Run.Overshoot_selected)OTL(Overshoot);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Clear overshoot]]>
</Comment>
<Text>
<![CDATA[[XIO(Step_bit[0].14) XIO(Step_bit[0].15) XIO(Step_bit[2].0) XIO(Step_bit[2].1) XIO(Step_bit[2].17) XIO(Step_bit[2].18) ,EQ(Run.Exposure_type,4) ][CLR(Calculated_offset) ,OTU(Overshoot) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Overshoot calculation]]>
</Comment>
<Text>
<![CDATA[XIC(Overshoot)[SUB(Run.Exposure_temperature,Load_temp_min_PID,Calculated_offset) ,DIV(Calculated_offset,Run.Overshoot_rate,Calculated_offset) ,ADD(Calculated_offset,Run.Overshoot_offset,Calculated_offset) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Overshoot help setpoint for the control loop]]>
</Comment>
<Text>
<![CDATA[XIC(Overshoot)[GT(Calculated_offset,5) MOVE(5,Calculated_offset) ,ADD(Run.Exposure_temperature,Calculated_offset,Overshoot_setpoint) ,XIO(Option.LSR_Sterilizer) GT(Overshoot_setpoint,135) MOVE(135,Overshoot_setpoint) ,XIC(Option.LSR_Sterilizer) GT(Overshoot_setpoint,138) MOVE(138,Overshoot_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Stop overshoot when minimum load probe is above exposure transition limit]]>
</Comment>
<Text>
<![CDATA[GE(Load_temp_min_PID,Step_temperature_setpoint)OTU(Overshoot);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="PCV119_Bleeder" Type="RLL">
<Description>
<![CDATA[SAMX Bleeder]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set PID loop program manual mode]]>
</Comment>
<Text>
<![CDATA[[LIMIT(81,Process.Step,82) ,XIC(HMI.PCV119_force) XIO(Process.Running) EQ(Process.Service_cycle,0) ]OTL(PCV119_PID.SWM);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set PID loop program automatic mode for steps 83,84]]>
</Comment>
<Text>
<![CDATA[LIMIT(83,Process.Step,84)[OTU(PCV119_PID.SWM) ,OTU(HMI.PCV119_force) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[	Valve is 100% open during 
S81 Heating up start delay 15 seconds]]>
</Comment>
<Text>
<![CDATA[EQ(Process.Step,81)[TON(SAMX_heat_up_start_delay,?,?) ,XIO(SAMX_heat_up_start_delay.DN) XIO(heat_up_start_delay_done) MOVE(100,PCV119_PID.SO) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Heat up delay reset for new cycle]]>
</Comment>
<Text>
<![CDATA[XIO(Process.Running)OTU(heat_up_start_delay_done);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(SAMX_heat_up_start_delay.DN)[GT(PT549_Chamber.Pressure_mBar,Process.SAMX_pressure_sp) ,LE(PCV119_PID.SO,Common_set.SAMX_Bleeder_opening_min) ]OTL(heat_up_start_delay_done);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[PCV119 bleeder ramping up/down when pressure limit is reached
setpoit+deviation=open(close)limit]]>
</Comment>
<Text>
<![CDATA[LIMIT(81,Process.Step,82)XIC(heat_up_start_delay_done)[ADD(PCV119_PID.SP,Common_set.SAMX_Bleeder_Press_dev_reac_limit,PCV119_open_limit) SUB(PCV119_PID.SP,0,PCV119_close_limit) ,[GT(PT549_Chamber.Pressure_mBar,PCV119_open_limit) ,LT(PT549_Chamber.Pressure_mBar,PCV119_close_limit) ] OTE(SAMX_PCV119_reaction) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[After 15 seconds valve closes at pre-defined rate
if PCV119 output is greater than minimum value]]>
</Comment>
<Text>
<![CDATA[LIMIT(81,Process.Step,82)XIO(heat_up_start_delay_done)GT(PCV119_PID.SO,Common_set.SAMX_Bleeder_opening_min)EQ(Counter_50ms,0)SUB(PCV119_PID.SO,Common_set.SAMX_Bleeder_closing_rate,PCV119_PID.SO);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[PCV119 bleeder ramping up/down when pressure limit is reached
]]>
</Comment>
<Text>
<![CDATA[XIC(SAMX_PCV119_reaction)EQ(Counter_50ms,0)[GE(PT549_Chamber.Pressure_mBar,PCV119_open_limit) LT(PCV119_PID.SO,100) ADD(PCV119_PID.SO,Common_set.SAMX_Bleeder_reaction_rate,PCV119_PID.SO) ,LE(PT549_Chamber.Pressure_mBar,PCV119_close_limit) GT(PCV119_PID.SO,Common_set.SAMX_Bleeder_opening_min) SUB(PCV119_PID.SO,Common_set.SAMX_Bleeder_reaction_rate,PCV119_PID.SO) ,LT(PCV119_PID.SO,Common_set.SAMX_Bleeder_opening_min) MOVE(Common_set.SAMX_Bleeder_opening_min,PCV119_PID.SO) ,[GT(PCV119_PID.SO,100) ,XIC(PT549_Chamber.out_of_range) ] MOVE(100,PCV119_PID.SO) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Setpoint for the PID loop]]>
</Comment>
<Text>
<![CDATA[LIMIT(81,Process.Step,84)[MOVE(Process.SAMX_pressure_sp,PCV119_PID.SP) ,MOVE(Process.SAMX_pressure_sp,Step_pressure_setpoint) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[PID values scaled from panel]]>
</Comment>
<Text>
<![CDATA[[DIV(HMI.PID_SAMX_pressure_P,100,PCV119_PID.KP) ,DIV(HMI.PID_SAMX_pressure_I,100,PCV119_PID.KI) ,DIV(HMI.PID_SAMX_pressure_D,100,PCV119_PID.KD) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Close Bleeder when not SAMX step]]>
</Comment>
<Text>
<![CDATA[[LIMIT(85,Process.Step,80) XIC(Process.Running) ,XIO(Process.Running) [XIO(HMI.PCV119_force) ,NE(Process.Service_cycle,0) ] ][MOVE(PT549_Chamber.Pressure_mBar,PCV119_PID.SP) ,OTL(PCV119_PID.SWM) CLR(PCV119_PID.SO) OTU(HMI.PCV119_force) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[PID for Process air control]]>
</Comment>
<Text>
<![CDATA[PID(PCV119_PID,PT549_Chamber.Pressure_mBar,0,PCV119_PID_Out,0,0,0);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Move PCV119 PID out to analog output module word.]]>
</Comment>
<Text>
<![CDATA[XIC(Option.SAMX_process)[MOVE(PCV119_PID_Out,FESTO_HLP) DIV(PCV119_PID_Out,40.95,PCV119_Out) MOVE(PCV119_PID_Out,PCV119_PID_output) ,GT(Option.Festo_AO_modules,0) BTD(FESTO_HLP,0,U784:O.Data[2],0,8) BTD(FESTO_HLP,8,U784:O.Data[3],0,8) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIC(heat_up_start_delay_done)OTE(heat_up_start_delay_done_controller_tag);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="PID_main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[JSR(TCV112,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[JSR(PCV119_Bleeder,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[JSR(T_P_Curve,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[JSR(Overshoot,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[ADD(Counter_50ms,1,Counter_50ms)EQ(Counter_50ms,19)CLR(Counter_50ms);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Subroutine_T_P_Check" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Subroutine to check where current measured value is in the table]]>
</Comment>
<Text>
<![CDATA[SBR()ADD(Value,1,Value_1);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Heating up curve: If next point is lower copy previous value]]>
</Comment>
<Text>
<![CDATA[[LT(Run.Precond_temp[Value_1],Run.Precond_temp[Value]) MOVE(Run.Precond_temp[Value],Run.Precond_temp[Value_1]) ,LT(Run.Precond_press[Value_1],Run.Precond_press[Value]) MOVE(Run.Precond_press[Value],Run.Precond_press[Value_1]) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Compare current temperature to the table and move low and high values during Heating up]]>
</Comment>
<Text>
<![CDATA[LIMIT(81,Process.Step,82)GE(Load_temp_max_PID,Run.Precond_temp[Value])GT(Run.Precond_temp[Value_1],Run.Precond_temp[Value])[MOVE(Run.Precond_temp[Value],Tmin) MOVE(Run.Precond_press[Value],Pmin) ,MOVE(Run.Precond_temp[Value_1],Tmax) MOVE(Run.Precond_press[Value_1],Pmax) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Cooling curve: If next point is higher copy previous value]]>
</Comment>
<Text>
<![CDATA[[GT(Run.Postcond_temp[Value_1],Run.Postcond_temp[Value]) MOVE(Run.Postcond_temp[Value],Run.Postcond_temp[Value_1]) ,GT(Run.Postcond_press[Value_1],Run.Postcond_press[Value]) MOVE(Run.Postcond_press[Value],Run.Postcond_press[Value_1]) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Compare current max load temperature to the table and move low and high values during Cooling]]>
</Comment>
<Text>
<![CDATA[LIMIT(83,Process.Step,84)LE(Load_temp_max_PID,Run.Postcond_temp[Value])[MOVE(Run.Postcond_temp[Value],Tmax) MOVE(Run.Postcond_press[Value],Pmax) ,MOVE(Run.Postcond_temp[Value_1],Tmin) MOVE(Run.Postcond_press[Value_1],Pmin) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[RET();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="TCV112" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set ramp active]]>
</Comment>
<Text>
<![CDATA[[EQ(Process.Step,81) EQ(TCV112_PID.SO,0) OTL(TCV112_ramp) ,[GT(SAMX_Control_temperature,Common_set.SAMX_Steam_valve_auto_mode_temp) ,NE(Process.Step,81) ] OTU(TCV112_ramp) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[On SAMX S81 Heating Up TCV112 Fist ramped open. Opening rate and automatic mode 
transition point are defined in common settings.
]]>
</Comment>
<Text>
<![CDATA[XIC(TCV112_ramp)EQ(Counter_50ms,0)[LT(TCV112_PID.SO,100) ADD(TCV112_PID.SO,Common_set.SAMX_Steam_valve_opening_rate,TCV112_PID.SO) ,LT(TCV112_PID.SO,10) MOVE(10,TCV112_PID.SO) ,GT(TCV112_PID.SO,100) MOVE(100,TCV112_PID.SO) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Set chamber PID auto mode]]>
</Comment>
<Text>
<![CDATA[[LIMIT(14,Process.Step,15) NE(Run.Exposure_type,4) GT(TE517_Chamber.Temperature,105) ,LIMIT(14,Process.Step,15) EQ(Run.Exposure_type,4) GT(TE517_1_Filter.Temperature,105) ,LIMIT(64,Process.Step,65) [XIO(Option.DecV_process) GT(TE517_2_DEC.Temperature,105) ,XIC(Option.DecV_process) GT(TE517_Chamber.Temperature,105) ] ,LIMIT(81,Process.Step,82) XIO(TCV112_ramp) ]XIO(HMI.TCV112_force)OTU(TCV112_PID.SWM);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Setpoint for the PID loop]]>
</Comment>
<Text>
<![CDATA[[LIMIT(14,Process.Step,15) ,LIMIT(64,Process.Step,65) ,LIMIT(81,Process.Step,82) ][XIO(Overshoot) MOVE(Run.Exposure_temperature,TCV112_PID.SP) ,XIC(Overshoot) MOVE(Overshoot_setpoint,TCV112_PID.SP) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[PID values for chamber or filter]]>
</Comment>
<Text>
<![CDATA[[[NE(Run.Exposure_type,4) NE(Run.Precond_1_type,3) [DIV(HMI.PID_chamber_P,100,TCV112_PID.KP) ,DIV(HMI.PID_chamber_I,100,TCV112_PID.KI) ,DIV(HMI.PID_chamber_D,100,TCV112_PID.KD) ] ,NE(Run.Exposure_type,4) EQ(Run.Precond_1_type,3) [DIV(HMI.PID_DEC_P,100,TCV112_PID.KP) ,DIV(HMI.PID_DEC_I,100,TCV112_PID.KI) ,DIV(HMI.PID_DEC_D,100,TCV112_PID.KD) ] ] ,EQ(Run.Exposure_type,4) [DIV(HMI.PID_filter_P,100,TCV112_PID.KP) ,DIV(HMI.PID_filter_I,100,TCV112_PID.KI) ,DIV(HMI.PID_filter_D,100,TCV112_PID.KD) ] ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Set chamber setpoint from software]]>
</Comment>
<Text>
<![CDATA[[LIMIT(0,Process.Step,13) ,LIMIT(16,Process.Step,42) ,LIMIT(60,Process.Step,63) ,LIMIT(83,Process.Step,84) ,EQ(Process.Step,66) ,EQ(Process.Step,67) ,EQ(Process.Step,68) ,XIC(HMI.TCV112_force) ,XIC(TCV112_ramp) ]OTL(TCV112_PID.SWM);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Clear PID output force mode if Cycle aborted or user is logged out]]>
</Comment>
<Text>
<![CDATA[[XIC(Process.Cycle_aborted) ,EQ(Password_level,0) ]OTU(HMI.TCV112_force);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Set chamber PID output = 0 %]]>
</Comment>
<Text>
<![CDATA[XIO(Step_bit[0].14)XIO(Step_bit[0].15)XIO(Step_bit[2].0)XIO(Step_bit[2].1)XIO(Step_bit[2].17)XIO(Step_bit[2].18)XIO(HMI.TCV112_force)CLR(TCV112_PID.SO);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Set chamber PID output = 100 %]]>
</Comment>
<Text>
<![CDATA[XIO(HMI.TCV112_force)[LIMIT(13,Process.Step,15) [NE(Run.Exposure_type,4) LE(TE517_Chamber.Temperature,105) ,EQ(Run.Exposure_type,4) LE(TE517_1_Filter.Temperature,105) ] ,LIMIT(64,Process.Step,65) [XIO(Option.DecV_process) LE(TE517_2_DEC.Temperature,105) ,XIC(Option.DecV_process) LE(TE517_Chamber.Temperature,105) ] ]MOVE(100,TCV112_PID.SO);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Process variable for the PID loop]]>
</Comment>
<Text>
<![CDATA[[NE(Run.Exposure_type,4) NE(Run.Precond_1_type,3) MOVE(TE517_Chamber.Temperature,TCV112_PID.PV) ,EQ(Run.Exposure_type,4) MOVE(TE517_1_Filter.Temperature,TCV112_PID.PV) ,EQ(Run.Precond_1_type,3) [XIO(Option.DecV_process) MOVE(TE517_2_DEC.Temperature,TCV112_PID.PV) ,XIC(Option.DecV_process) MOVE(TE517_Chamber.Temperature,TCV112_PID.PV) ] ,EQ(Run.Precond_1_type,4) MOVE(SAMX_Control_temperature,TCV112_PID.PV) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[PID loop for chamber and filter steam]]>
</Comment>
<Text>
<![CDATA[PID(TCV112_PID,TCV112_PID.PV,0,TCV112_Out,0,0,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="T_P_Curve" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set Curve values during Heating and Exposure 
when control temp is below start value]]>
</Comment>
<Text>
<![CDATA[LIMIT(81,Process.Step,82)SUB(Run.Number_of_precond_TP_values,1,Calc_limit)LT(Load_temp_max_PID,Run.Precond_temp[0])[MOVE(Run.Precond_temp[0],Tmin) ,MOVE(Run.Precond_temp[1],Tmax) ,MOVE(Run.Precond_press[0],Pmin) ,MOVE(Run.Precond_press[1],Pmax) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set Curve values during cooling
 when control temp is below start value]]>
</Comment>
<Text>
<![CDATA[LIMIT(83,Process.Step,84)SUB(Run.Number_of_postcond_TP_values,1,Calc_limit)GT(Load_temp_max_PID,Run.Postcond_temp[0])[MOVE(Run.Postcond_temp[0],Tmin) ,MOVE(Run.Postcond_temp[1],Tmax) ,MOVE(Run.Postcond_press[0],Pmin) ,MOVE(Run.Postcond_press[1],Pmax) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Check curve T_P high and low values]]>
</Comment>
<Text>
<![CDATA[FOR(Subroutine_T_P_Check,Value,0,Calc_limit,1);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Calculate pressure setpoint from curve]]>
</Comment>
<Text>
<![CDATA[[NE(Tmax,Tmin) [CPT(K_value,(Pmax-Pmin)/(Tmax-Tmin)) ,CPT(Process.SAMX_pressure_sp,K_value*(Load_temp_max_PID-Tmin)+Pmin) ] ,EQ(Tmax,Tmin) MOVE(Pmin,Process.SAMX_pressure_sp) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
<Program Name="Printing" TestEdits="false" MainRoutineName="Print_main" Disabled="false" UseAsFolder="false">
<Tags>
<Tag Name="AC_precond" TagType="Base" DataType="BOOL" Radix="Decimal" Constant="false" ExternalAccess="Read/Write" OpcUaAccess="None">
<Description>
<![CDATA[help bit
for subroutine]]>
</Description>
<Data Format="L5K">
<![CDATA[0]]>
</Data>
<Data Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</Data>
</Tag>
<Tag Name="air_detect_ons" TagType="Base" DataType="BOOL" Radix="Decimal" Constant="false" ExternalAccess="Read/Write" OpcUaAccess="None">
<Description>
<![CDATA[Print air detect point values help]]>
</Description>
<Data Format="L5K">
<![CDATA[0]]>
</Data>
<Data Format="Decorated">
