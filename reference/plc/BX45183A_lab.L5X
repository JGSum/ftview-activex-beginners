<Routines>
<Routine Name="Cycle_abort" Type="RLL">
<Description>
<![CDATA[Aborting control]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[User abort]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Abort)MOVE(44,HMI.Force_NS)OTL(Process.Cycle_aborted);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Process abort before equalization]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)XIC(Process.Running)NE(Process.Step,21)NE(Process.Step,67)NE(Process.Step,1)LIMIT(31,Process.Step,24)OTL(Process.Abort_before_Equalization);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Interlock type for abort]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)XIC(Process.Running)XIO(Step_bit[0].21)XIO(Step_bit[2].3)[LE(Run.Interlock_type,3) MOVE(3,Interlock_type_help) ,GE(Run.Interlock_type,4) MOVE(6,Interlock_type_help) ,[XIC(Step_bit[0].4) ,LIMIT(7,Process.Step,15) ,LIMIT(33,Process.Step,35) ,LIMIT(40,Process.Step,42) ,LIMIT(81,Process.Step,82) ,EQ(44,Process.Step) ] CLR(Process.Prec_status) OTL(Process.Precond_abort) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Abort step if cycle aborted before precondition]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)[XIC(Step_bit[0].4) NE(Run.Precond_1_type,3) ,XIC(Step_bit[0].7) NE(Run.Precond_1_type,3) ,XIC(Step_bit[1].12) ,LIMIT(33,Process.Step,35) ,LIMIT(40,Process.Step,42) ]MOVE(21,Process.Step);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Cycle aborted when Postcondition is running and double door cycle is selected]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)XIC(Process.Running)XIC(Option.Double_door)XIO(Process.Precond_abort)[LIMIT(16,Process.Step,20) ,LIMIT(22,Process.Step,24) ,LIMIT(83,Process.Step,84) ,XIO(Process.Abort_before_Equalization) XIO(Process.Abort_Equal_unload_confirmed) [EQ(Process.Step,21) ,EQ(Process.Step,67) ] ]NE(Run.Interlock_type,3)NE(Run.Interlock_type,6)MOVE(1,Unload_confirm);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Abort when B-process is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)LIMIT(8,Process.Step,19)[LT(Run.Postcond_1_type,3) ,EQ(Run.Postcond_1_type,5) ]NE(Run.Postcond_2_type,3)[XIO(Process.B_cycle_abort) LE(PT549_Chamber.Pressure_mBar,Process.ATM_high) MOVE(21,Process.Step) ,XIO(Step_bit[0].17) [OTL(Process.B_cycle_abort) ,MOVE(16,Process.Step) ] ,CLR(Pulse_counter) CLR(Process.Postc_status) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Abort when C-process or Slow exhaust is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)LIMIT(8,Process.Step,19)NE(Process.Postc_status,2)[[EQ(Run.Postcond_1_type,3) MOVE(1,Process.Postc_status) ,EQ(Run.Postcond_2_type,3) MOVE(2,Process.Postc_status) ] MOVE(22,Process.Step) ,EQ(Run.Postcond_1_type,4) MOVE(1,Process.Postc_status) MOVE(20,Process.Step) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Abort when C-process or Slow exhaust is selected and postcond 2 is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)LIMIT(16,Process.Step,19)EQ(Process.Postc_status,2)XIO(Process.B_cycle_abort)LIMIT(3,Run.Postcond_1_type,4)MOVE(21,Process.Step);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Abort if door seal failure during cooling]]>
</Comment>
<Text>
<![CDATA[[XIC(Alarm_ACT[0].5) ,XIC(Alarm_ACT[0].6) ,XIC(Alarm_ACT[0].7) ]LIMIT(22,Process.Step,24)[MOVE(100,Run.Slow_exhaust_temp) ,MOVE(20,Process.Step) XIO(Option.Jacket_closed_loop) OTL(Process.Jacket_air) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Abort step when VHP process is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)LIMIT(50,Process.Step,55)[LIMIT(50,Process.Step,51) OTL(Process.VHP_Abort) ,MOVE(56,Process.Step) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Abort step when Dec process is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)[LIMIT(60,Process.Step,65) ,[XIC(Step_bit[0].4) ,XIC(Step_bit[0].7) ] EQ(Run.Precond_1_type,3) ]MOVE(66,Process.Step);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Abort step when 10.4.41 VHP Biodec is running]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Biodec)[XIC(Process.Cycle_aborted) ,XIC(DIG_IN[0].12) ]LIMIT(36,Process.Step,38)[EQ(36,Process.Step) OTL(Process.VHP_Abort) ,MOVE(38,Process.Step) ,XIC(DIG_IN[0].12) OTL(Process.VHP_Gen_Abort) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Abort step when 10.4.40 VHP Ports is running]]>
</Comment>
<Text>
<![CDATA[XIC(Option.VHP_Ports)XIC(Process.Cycle_aborted)EQ(37,Process.Step)OTL(Process.VHP_Abort);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Abort step when SAMX process is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)[LIMIT(81,Process.Step,83) ,LIMIT(12,Process.Step,15) EQ(Run.Postcond_1_type,6) ]MOVE(83,Process.Step);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Abort step when FIT test process is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)LIMIT(89,Process.Step,92)MOVE(21,Process.Step);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Abort step when FIT test process is running]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Cycle_aborted)LIMIT(94,Process.Step,97)MOVE(98,Process.Step);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="F0_Calculation" Type="RLL">
<Description>
<![CDATA[Fo for exposure]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[F0 value calculation
Clear values when loading / unloading
Clear value if temperature is out-of-limits
]]>
</Comment>
<Text>
<![CDATA[[LIMIT(2,Process.Step,7) ,LIMIT(25,Process.Step,32) ,EQ(Run.Exposure_type,4) ,LIMIT(150,Load_temp_min,100) ][FLL(0,FO_value[0],8) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Set probe value for calculation]]>
</Comment>
<Text>
<![CDATA[NE(Run.Exposure_type,4)MOVE(Load_temp_min,FO_value[1]);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Calculate F0 momentary value]]>
</Comment>
<Text>
<![CDATA[MOVE(10,FO_value[2])CPT(FO_value[0],10**((FO_value[1]-121.1)/FO_value[2]));]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Convert F0 value in seconds]]>
</Comment>
<Text>
<![CDATA[MUL(Run.Exposure_F0,60.0,FO_value[3]);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Increment F0 total value = elapsed F0 time]]>
</Comment>
<Text>
<![CDATA[XIO(HMI.Wait_pressed)XIC(Process.S_pulse)LT(FO_value[4],180000.0)LT(FO_value[0],1000.0)ADD(FO_value[0],FO_value[4],FO_value[4]);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[F0 value in minutes for operator panel]]>
</Comment>
<Text>
<![CDATA[LT(FO_value[4],180000.0)[MUL(FO_value[4],10.0,FO_value[5]) ,DIV(FO_value[5],600,FO_value[6]) ,GE(FO_value[7],0) SUB(Run.Exposure_F0,FO_value[6],FO_value[7]) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="First_scan" Type="RLL">
<Description>
<![CDATA[First scan routine
initialize program
and stop time check]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[First Scan routine
Initialize variables]]>
</Comment>
<Text>
<![CDATA[[MOVE(1,Process.Step) ,CLR(HMI.Force_NS) ,OTU(PrintingACT) ,FLL(0,Alarm_ACT[0],1) FLL(0,Alarm_ACT[1],1) FLL(0,Alarm_ACT[2],1) ,FLL(-1,Alarm_ACK[0],1) FLL(-1,Alarm_ACK[1],1) FLL(-1,Alarm_ACK[2],1) ,CLR(HMI.Alarm_banner) ,XIC(Process.Running) [MOVE(1,Process.Power_brake_status) ,OTU(Process.Power_brake_1) ] ,OTU(HMI.ServiceHMI) OTU(ServiceHMI_control) ,XIO(Process.Running) RES(Step_timer) RET() ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Power brake time calculation]]>
</Comment>
<Text>
<![CDATA[SUB(Current_time,Date_Time_memory,Date_Time_diff);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Power brake over 30 minutes]]>
</Comment>
<Text>
<![CDATA[GT(Date_Time_diff,1800)[MOVE(3,Process.Power_brake_status) ,OTU(Process.Power_brake_3) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Power brake between 60 seconds and 30 minutes]]>
</Comment>
<Text>
<![CDATA[NE(Process.Power_brake_status,3)GT(Date_Time_diff,60)MOVE(2,Process.Power_brake_status);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
