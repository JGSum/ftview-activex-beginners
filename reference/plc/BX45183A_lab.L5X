<![CDATA[XIC(Option.Filter_ster)[XIO(Option.Test_AI) BTD(U784:I.Data[10],0,A_In_Raw[3],0,8) BTD(U784:I.Data[11],0,A_In_Raw[3],8,8) DIV(A_In_Raw[3],100,TE517_1_Filter.Input_raw) ,XIO(Option.Test_AI) XIO(TE517_1_Filter.out_of_range) JSR(AI_scaling,5,TE517_1_Filter.Input_raw,TE517_1_Filter.In_raw_min,TE517_1_Filter.In_raw_max,TE517_1_Filter.Scale_value_min,TE517_1_Filter.Scale_value_max,TE517_1_Filter.Temperature) ,XIC(TE517_1_Filter.Probe_selected) XIC(Set_calib_value) XIO(HMI.Calib_failed) [XIO(Calib_HIGH_LOW) JSR(AI_Calibration,3,TE517_1_Filter.Input_raw,TE517_1_Filter.Temperature,HMI.Calib_temp_value,TE517_1_Filter.In_raw_min,TE517_1_Filter.Previous_calib_min,TE517_1_Filter.Scale_value_min,TE517_1_Filter.Calib_low_user,TE517_1_Filter.Calib_low_time) ,XIC(Calib_HIGH_LOW) JSR(AI_Calibration,3,TE517_1_Filter.Input_raw,TE517_1_Filter.Temperature,HMI.Calib_temp_value,TE517_1_Filter.In_raw_max,TE517_1_Filter.Previous_calib_max,TE517_1_Filter.Scale_value_max,TE517_1_Filter.Calib_high_user,TE517_1_Filter.Calib_high_time) ] ,LIMIT(15400,A_In_Raw[3],-90) MOVE(-9999,TE517_1_Filter.Temperature) OTE(TE517_1_Filter.out_of_range) ];]]>
