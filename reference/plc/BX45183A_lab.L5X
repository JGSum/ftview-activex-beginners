<![CDATA[XIC(Option.Door_type)[LIMIT(5,Process.Step,6) ,EQ(Process.Step,26) [XIC(HMI.E_Sign_Approved) ,XIC(HMI.E_Sign_Rejected) ] ,EQ(Process.Step,27) ,EQ(Process.Service_cycle,1) ]XIO(DIG_IN[1].18)LIMIT(Process.ATM_low,PT549_Chamber.Pressure_mBar,Process.ATM_high)XIC(DIG_IN[0].1)XIC(DIG_IN[0].0)[XIC(DIG_IN[1].19) ,XIC(DIG_IN[1].20) ,XIC(HMI.Close_ST) ,XIC(HMI.Open_ST) ][XIC(Clamp_V_delay_ST.DN) ,XIC(DIG_IN[1].7) ]TOF(Clamp_off_delay_st,?,?);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="MPA_6_YY610" Type="RLL">
<Description>
<![CDATA[TCV112 ON/OFF steam to chamber]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[YY610 TCV112 Heating steam to chamber]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Doors_locked)[XIO(HMI.TCV112_force) [[XIC(Step_bit[0].9) ,XIC(Step_bit[0].11) ] LT(PT549_Chamber.Pressure_mBar,Step_pressure_setpoint) ,[XIC(Step_bit[0].10) ,XIC(Step_bit[0].13) ] [XIO(Run.Rates_selected) ,XIC(Run.Rates_selected) LT(PT549_Chamber.Pressure_mBar,Process.Rate_value) ] ,XIC(Step_bit[0].12) LT(PT549_Chamber.Pressure_mBar,Process.Saturated_P) ,[XIC(Step_bit[0].14) ,XIC(Step_bit[0].15) ,XIC(Step_bit[2].17) ,XIC(Step_bit[2].18) ] [LT(TCV112_Open_time.ACC,TCV112_Out) GT(TCV112_Out,250) ,EQ(TCV112_Out,5000) ] ] ,XIC(HMI.TCV112_force) [LT(TCV112_Open_time.ACC,TCV112_Out) GT(TCV112_Out,250) ,EQ(TCV112_Out,5000) ] LIMIT(9,Process.Step,15) ]OTE(DIG_OUT[1].6);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIO(TCV112_Open_time.DN)TON(TCV112_Open_time,?,?);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIO(On_Off_Control_timer.DN)TON(On_Off_Control_timer,?,?);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="MPA_8_YY661" Type="RLL">
