<Routines>
<Routine Name="Configure_limits" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Rates is not possible with leak rate test]]>
</Comment>
<Text>
<![CDATA[LIMIT(1,Config.Precycle_type,3)OTU(Config.Rates_selected);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[ Precondition, Exposure and Postcondition types are forced to None when VIRASURE flow test precycle type is selected]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precycle_type,3)[CLR(Config.Precond_1_type) ,CLR(Config.Precond_2_type) ,CLR(Config.Exposure_type) ,CLR(Config.Postcond_1_type) ,CLR(Config.Postcond_2_type) ,OTU(Config.Overshoot_selected) ,OTU(Config.Air_detec_select) ,OTU(Config.Prec_1_jacket_heat) ,OTU(Config.Prec_2_jacket_heat) ,OTU(Config.Postc_1_jacket_heat) ,OTU(Config.Postc_2_jacket_heat) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Calculation VHP total sterilization time]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precycle_type,4)CPT(HMI.VHP_Sterilization_time,Config.VHP_Door_open_time+Config.VHP_Door_cycling_time+Config.VHP_Door_sealing_time);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Precond 2 is forced to None if Forced air removal is selected ]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precond_1_type,1)EQ(Config.Precond_2_type,1)CLR(Config.Precond_2_type);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Decontamination precondition 1 type is selected: 
Precond 2 is forced to None, exposure type is forced to Time if None or Filter is selected.]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precond_1_type,3)[NE(Config.Precond_2_type,0) CLR(Config.Precond_2_type) ,[EQ(Config.Exposure_type,4) ,EQ(Config.Exposure_type,0) ] MOVE(1,Config.Exposure_type) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Cooling  limiting for postcondition 2]]>
</Comment>
<Text>
<![CDATA[LIMIT(3,Config.Postcond_1_type,4)EQ(Config.Postcond_2_type,3)CLR(Config.Postcond_2_type);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Precondition, Exposure and Postcondition types are forced to None if VHP Ready or VHP Ports precycle type is selected ]]>
</Comment>
<Text>
<![CDATA[[EQ(Config.Precycle_type,6) ,EQ(Config.Precycle_type,7) ][CLR(Config.Precond_1_type) ,CLR(Config.Precond_2_type) ,CLR(Config.Exposure_type) ,CLR(Config.Postcond_1_type) ,CLR(Config.Postcond_2_type) ,OTU(Config.Overshoot_selected) ,OTU(Config.Air_detec_select) ,OTU(Config.Jacket_heat_leak_test) ,OTU(Config.Prec_1_jacket_heat) ,OTU(Config.Prec_2_jacket_heat) ,OTU(Config.Postc_1_jacket_heat) ,OTU(Config.Postc_2_jacket_heat) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[When precondition 1 type SAMX Heating Up is selected: 
Precond 2 is forced to None, 
Postcond1 is forced to SAMX Cooling,
Postcond2 type Cooling is not possible]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precond_1_type,4)[NE(Config.Precond_2_type,0) CLR(Config.Precond_2_type) ,[EQ(Config.Exposure_type,4) ,EQ(Config.Exposure_type,0) ] MOVE(1,Config.Exposure_type) ,EQ(Config.Postcond_2_type,3) CLR(Config.Postcond_2_type) ,NE(Config.Postcond_1_type,6) MOVE(6,Config.Postcond_1_type) ,NE(Config.Postcond_2_type,1) NE(Config.Postcond_2_type,2) NE(Config.Postcond_2_type,5) OTU(Config.Rates_selected) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[When precondition 1 type SAMX Heating Up is not selected set postcondition1 to None if postcondition1 type is SAMX Cooling]]>
</Comment>
<Text>
<![CDATA[NE(Config.Precond_1_type,4)EQ(Config.Postcond_1_type,6)CLR(Config.Postcond_1_type);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Air Detection off if option is not valid]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Air_detector)[OTU(Run.Air_detec_select) ,OTU(Config.Air_detec_select) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Check DEC VIRASURE precondition pulse vacuum/pressure settings and set default value if out of limits.]]>
</Comment>
<Text>
<![CDATA[XIC(Option.DecV_process)EQ(Config.Precond_1_type,3)[[XIO(Option.Press_unit) LIMIT(1000.1,Config.Prec_1_1st_vacuum_level,79.9) ,XIC(Option.Press_unit) LIMIT(1034.5,Config.Prec_1_1st_vacuum_level,82.6) ] MOVE(100.0,Config.Prec_1_1st_vacuum_level) ,[XIO(Option.Press_unit) LIMIT(2000.1,Config.Prec_1_1st_pressure_level,99.9) ,XIC(Option.Press_unit) LIMIT(2000.1,Config.Prec_1_1st_pressure_level,96.4) ] MOVE(1500.0,Config.Prec_1_1st_pressure_level) ,[XIO(Option.Press_unit) LIMIT(1000.1,Config.Prec_1_2nd_pressure_level,99.9) ,XIC(Option.Press_unit) LIMIT(1000.1,Config.Prec_1_1st_pressure_level,96.4) ] MOVE(1000.0,Config.Prec_1_2nd_pressure_level) ,[XIO(Option.Press_unit) LIMIT(1000.1,Config.Prec_1_3rd_pressure_level,99.9) ,XIC(Option.Press_unit) LIMIT(1000.1,Config.Prec_1_1st_pressure_level,96.4) ] MOVE(1000.0,Config.Prec_1_3rd_pressure_level) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Configure_main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Copy cycle parameters when Configure Mode]]>
</Comment>
<Text>
<![CDATA[JSR(Copy_cycle_data,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Screen control when cycle phase is selected]]>
</Comment>
<Text>
<![CDATA[JSR(Config_Screen_control,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Cycle parameters modification control]]>
</Comment>
<Text>
<![CDATA[JSR(Configure_limits,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Copy Cycle parameters when Run Mode is selected]]>
</Comment>
<Text>
<![CDATA[JSR(Select_Run_cycle,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[SAMX Temperature Pressure Curve Configuration from panel]]>
</Comment>
<Text>
<![CDATA[JSR(Pressure_Curve,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Config_Screen_control" Type="RLL">
<Description>
<![CDATA[Change screen and
select phase type]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Pretest type Finn-Aqua Leak rate test selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,1)[MOVE(1,Config.Precycle_type) ,MOVE(500,HMI.Force_NS) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Pretest type DIN rate test selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,2)[MOVE(2,Config.Precycle_type) ,MOVE(502,HMI.Force_NS) ,XIC(Option.Press_unit) CLR(HMI.View_LRT_help) ,XIO(Option.Press_unit) MOVE(1,HMI.View_LRT_help) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Pretest type VIRASURE flow test selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,3)[MOVE(3,Config.Precycle_type) ,MOVE(506,HMI.Force_NS) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Precycle type VHP Sterilization selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,4)[MOVE(4,Config.Precycle_type) ,MOVE(503,HMI.Force_NS) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Pretest type Preheating selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,5)[MOVE(5,Config.Precycle_type) ,MOVE(504,HMI.Force_NS) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Precycle type VHP 10.4.41 Biodec selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,6)[MOVE(6,Config.Precycle_type) ,MOVE(505,HMI.Force_NS) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Precycle type 10.4.40 VHP Ports selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,7)[MOVE(7,Config.Precycle_type) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Precycle type FIT sanitization selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,8)[MOVE(8,Config.Precycle_type) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Precycle type FIT filling selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,9)[MOVE(9,Config.Precycle_type) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Precycle type FIT test selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precycle,10)[MOVE(10,Config.Precycle_type) ,CLR(HMI.Sel_Precycle) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Precondition, Exposure and Postcondition type selection HMI button tags are cleared if VIRASURE flow test precycle type is selected
Jump out from the subroutine ]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precycle_type,3)[CLR(HMI.Sel_Precond1) ,CLR(HMI.Sel_Precond2) ,CLR(HMI.Sel_Exposure) ,CLR(HMI.Sel_Postcond1) ,CLR(HMI.Sel_Postcond2) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Precondition, Exposure and Postcondition type selection HMI button tags are cleared if VHP Biodec or VHP Ports precycle type is selected
Jump out from the subroutine ]]>
</Comment>
<Text>
<![CDATA[[EQ(Config.Precycle_type,6) ,EQ(Config.Precycle_type,7) ][CLR(HMI.Sel_Precond1) ,CLR(HMI.Sel_Precond2) ,CLR(HMI.Sel_Exposure) ,CLR(HMI.Sel_Postcond1) ,CLR(HMI.Sel_Postcond2) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Precond 1 type Forced air removal selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precond1,1)[MOVE(1,Config.Precond_1_type) ,MOVE(510,HMI.Force_NS) ,CLR(HMI.Sel_Precond1) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Precond 1 type Pulsed air removal selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precond1,2)[MOVE(2,Config.Precond_1_type) ,MOVE(511,HMI.Force_NS) ,CLR(HMI.Sel_Precond1) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Precond 1 type DEC air removal selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precond1,3)[MOVE(3,Config.Precond_1_type) ,XIO(Option.DecV_process) MOVE(512,HMI.Force_NS) ,XIC(Option.DecV_process) MOVE(514,HMI.Force_NS) ,CLR(HMI.Sel_Precond1) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Precond 1 type SAMX Process 10.1.7 selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precond1,4)[MOVE(4,Config.Precond_1_type) CLR(Config.Precond_2_type) ,MOVE(6,Config.Postcond_1_type) ,CLR(HMI.Temp_Press_pointer) ,XIC(Option.Press_unit) MOVE(513,HMI.Force_NS) ,XIO(Option.Press_unit) MOVE(5130,HMI.Force_NS) ,CLR(HMI.Sel_Precond1) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[Precond 2 type Forced air removal selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precond2,1)[MOVE(1,Config.Precond_2_type) ,MOVE(510,HMI.Force_NS) ,CLR(HMI.Sel_Precond2) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[Precond 2 type Pulsed air removal selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Precond2,2)[MOVE(2,Config.Precond_2_type) ,MOVE(521,HMI.Force_NS) ,CLR(HMI.Sel_Precond2) ];]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[Exposure type time selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Exposure,1)[MOVE(1,Config.Exposure_type) ,MOVE(540,HMI.Force_NS) ,CLR(HMI.Sel_Exposure) ];]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[Exposure type Fo selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Exposure,2)[MOVE(2,Config.Exposure_type) ,MOVE(541,HMI.Force_NS) ,CLR(HMI.Sel_Exposure) ];]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[Exposure type Filter Sterilization selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Exposure,4)[MOVE(4,Config.Exposure_type) ,MOVE(543,HMI.Force_NS) ,CLR(HMI.Sel_Exposure) ];]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[Postcondition 1 type Vacuum Drying selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond1,1)NE(Config.Precond_1_type,4)[MOVE(1,Config.Postcond_1_type) ,MOVE(550,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[Postcondition 1 type Pulse Drying selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond1,2)NE(Config.Precond_1_type,4)[MOVE(2,Config.Postcond_1_type) ,MOVE(551,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[Postcondition 1 type Cooling selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond1,3)NE(Config.Postcond_2_type,3)NE(Config.Precond_1_type,4)[MOVE(3,Config.Postcond_1_type) ,MOVE(552,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Comment>
<![CDATA[Postcondition 1 type Slow Exhaust selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond1,4)NE(Config.Precond_1_type,4)[MOVE(4,Config.Postcond_1_type) ,MOVE(553,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[Postcondition 1 type HPPD selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond1,5)NE(Config.Precond_1_type,4)[MOVE(5,Config.Postcond_1_type) ,MOVE(551,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[Postcondition 1 type SAMX Process 10.1.7 selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond1,6)EQ(Config.Precond_1_type,4)[MOVE(6,Config.Postcond_1_type) ,XIC(Option.Press_unit) MOVE(5542,HMI.Force_NS) ,XIO(Option.Press_unit) MOVE(5542,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[Postcondition1 Show SAMX Cooling Curve Configuration Display]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Sel_SAMX_Cooling_Curve)[CLR(HMI.Temp_Press_pointer) ,XIC(Option.Press_unit) MOVE(5540,HMI.Force_NS) ,XIO(Option.Press_unit) MOVE(5541,HMI.Force_NS) ,CLR(HMI.Sel_Postcond1) ];]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Comment>
<![CDATA[Postcondition 2 type Vacuum Drying selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond2,1)[MOVE(1,Config.Postcond_2_type) ,MOVE(560,HMI.Force_NS) ,CLR(HMI.Sel_Postcond2) ];]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Comment>
<![CDATA[Postcondition 2 type Pulse Drying selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond2,2)[MOVE(2,Config.Postcond_2_type) ,MOVE(561,HMI.Force_NS) ,CLR(HMI.Sel_Postcond2) ];]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Comment>
<![CDATA[Postcondition 2 type Cooling selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond2,3)NE(Config.Postcond_1_type,3)NE(Config.Precond_1_type,4)[MOVE(3,Config.Postcond_2_type) ,MOVE(552,HMI.Force_NS) ,CLR(HMI.Sel_Postcond2) ];]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Comment>
<![CDATA[Postcondition 2 type HPPD selected]]>
</Comment>
<Text>
<![CDATA[EQ(HMI.Sel_Postcond2,5)[MOVE(5,Config.Postcond_2_type) ,MOVE(561,HMI.Force_NS) ,CLR(HMI.Sel_Postcond2) ];]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Comment>
<![CDATA[Previous from Forced air removal screen]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Previous510)[EQ(Config.Precond_1_type,1) MOVE(51,HMI.Force_NS) ,EQ(Config.Precond_2_type,1) MOVE(52,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Comment>
<![CDATA[Previous from Cooling screen]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Previous552)[EQ(Config.Postcond_1_type,3) MOVE(55,HMI.Force_NS) ,EQ(Config.Postcond_2_type,3) MOVE(56,HMI.Force_NS) ];]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Comment>
<![CDATA[Previous from SAMX Cooling screen]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Previous5542)EQ(Config.Postcond_1_type,6)MOVE(55,HMI.Force_NS);]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Comment>
<![CDATA[Previous from Slow Exhaust screen]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Previous553)EQ(Config.Postcond_1_type,4)MOVE(55,HMI.Force_NS);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Copy_cycle_data" Type="RLL">
<Description>
<![CDATA[Copy selected
cycle parameters
when selected / saved]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Change Configure main screen when cycle is selected
Running cycle is not able to configure]]>
</Comment>
<Text>
<![CDATA[NE(HMI.Select_config_cycle,0)[XIC(Process.Running) NE(HMI.Select_config_cycle,Process.Started_cycle) ,XIO(Process.Running) ]MOVE(HMI.Select_config_cycle,Config_number);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Running cycle is not able to configure
clear selected cycle number]]>
</Comment>
<Text>
<![CDATA[XIC(Process.Running)EQ(HMI.Select_config_cycle,Process.Started_cycle)CLR(HMI.Select_config_cycle);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Copy cycle parameters for configure]]>
</Comment>
<Text>
<![CDATA[GT(HMI.Select_config_cycle,0)[COP(Cycle[HMI.Select_config_cycle],Config,1) ,CLR(HMI.Select_config_cycle) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Set parameter default values from panel]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Prm_defaults)[XIC(Option.Press_unit) COP(Cycle[0],Config,1) ,XIO(Option.Press_unit) COP(Default,Config,1) ,OTU(HMI.Prm_defaults) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Save cycle parameters]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Save_cycle)[COP(User_name,Config.Created_by,1) ,COP(time_date,Config.Created_time,1) ,COP(Config,Cycle[Config_number],1) ,OTU(HMI.Save_cycle) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Set constant values if DIN is selected]]>
</Comment>
<Text>
<![CDATA[EQ(Config.Precycle_type,2)[MOVE(5,Config.FA_vacuum_init_time) ,MOVE(5,Config.FA_stabilizat_time) ,OTL(Config.FA_pump_during_stabil) ,MOVE(133,Config.FA_vacuum_test_level) ,MOVE(10,Config.FA_vacuum_test_time) ,MOVE(15,Config.FA_acceptable_leak_rate) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Pressure_Curve" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[SAMX Precondition Move Curve point values to HMI setting tags]]>
</Comment>
<Text>
<![CDATA[EQ(HMI_Precond_or_Postcond,1)[NE(HMI.Temp_Press_pointer,TP_Pointer) ,ONS(ONS_1) ][MOVE(Config.Precond_temp[HMI.Temp_Press_pointer],HMI.Curve_temp) MOVE(Config.Precond_press[HMI.Temp_Press_pointer],HMI.Curve_press) ,MOVE(HMI.Temp_Press_pointer,TP_Pointer) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[SAMX Postcondition Move Curve point values to HMI setting tags]]>
</Comment>
<Text>
<![CDATA[EQ(HMI_Precond_or_Postcond,2)[NE(HMI.Temp_Press_pointer,TP_Pointer) ,ONS(ONS_2) ][MOVE(Config.Postcond_temp[HMI.Temp_Press_pointer],HMI.Curve_temp) MOVE(Config.Postcond_press[HMI.Temp_Press_pointer],HMI.Curve_press) ,MOVE(HMI.Temp_Press_pointer,TP_Pointer) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Move HMI setting tags to cycle parameters area]]>
</Comment>
<Text>
<![CDATA[XIC(HMI.Set_curve_values)[EQ(HMI_Precond_or_Postcond,1) [MOVE(HMI.Curve_temp,Config.Precond_temp[TP_Pointer]) MOVE(HMI.Curve_press,Config.Precond_press[TP_Pointer]) ,[GT(Config.Precond_temp[0],Config.Precond_temp[1]) ,GT(Config.Precond_press[0],Config.Precond_press[1]) ] FLL(Config.Precond_temp[0],Config.Precond_temp[1],9) FLL(Config.Precond_press[0],Config.Precond_press[1],9) ,[GT(Config.Precond_temp[1],Config.Precond_temp[2]) ,GT(Config.Precond_press[1],Config.Precond_press[2]) ] FLL(Config.Precond_temp[1],Config.Precond_temp[2],8) FLL(Config.Precond_press[1],Config.Precond_press[2],8) ,[GT(Config.Precond_temp[2],Config.Precond_temp[3]) ,GT(Config.Precond_press[2],Config.Precond_press[3]) ] FLL(Config.Precond_temp[2],Config.Precond_temp[3],7) FLL(Config.Precond_press[2],Config.Precond_press[3],7) ,[GT(Config.Precond_temp[3],Config.Precond_temp[4]) ,GT(Config.Precond_press[3],Config.Precond_press[4]) ] FLL(Config.Precond_temp[3],Config.Precond_temp[4],6) FLL(Config.Precond_press[3],Config.Precond_press[4],6) ,[[GT(Config.Precond_temp[4],Config.Precond_temp[5]) ,GT(Config.Precond_press[4],Config.Precond_press[5]) ] FLL(Config.Precond_temp[4],Config.Precond_temp[5],5) FLL(Config.Precond_press[4],Config.Precond_press[5],5) ,OTU(HMI.Set_curve_values) ] ] ,EQ(HMI_Precond_or_Postcond,2) [MOVE(HMI.Curve_temp,Config.Postcond_temp[TP_Pointer]) MOVE(HMI.Curve_press,Config.Postcond_press[TP_Pointer]) ,[LT(Config.Postcond_temp[0],Config.Postcond_temp[1]) ,LT(Config.Postcond_press[0],Config.Postcond_press[1]) ] FLL(Config.Postcond_temp[0],Config.Postcond_temp[1],9) FLL(Config.Postcond_press[0],Config.Postcond_press[1],9) ,[LT(Config.Postcond_temp[1],Config.Postcond_temp[2]) ,LT(Config.Postcond_press[1],Config.Postcond_press[2]) ] FLL(Config.Postcond_temp[1],Config.Postcond_temp[2],8) FLL(Config.Postcond_press[1],Config.Postcond_press[2],8) ,[LT(Config.Postcond_temp[2],Config.Postcond_temp[3]) ,LT(Config.Postcond_press[2],Config.Postcond_press[3]) ] FLL(Config.Postcond_temp[2],Config.Postcond_temp[3],7) FLL(Config.Postcond_press[2],Config.Postcond_press[3],7) ,[LT(Config.Postcond_temp[3],Config.Postcond_temp[4]) ,LT(Config.Postcond_press[3],Config.Postcond_press[4]) ] FLL(Config.Postcond_temp[3],Config.Postcond_temp[4],6) FLL(Config.Postcond_press[3],Config.Postcond_press[4],6) ,[[LT(Config.Postcond_temp[4],Config.Postcond_temp[5]) ,LT(Config.Postcond_press[4],Config.Postcond_press[5]) ] FLL(Config.Postcond_temp[4],Config.Postcond_temp[5],5) FLL(Config.Postcond_press[4],Config.Postcond_press[5],5) ,OTU(HMI.Set_curve_values) ] ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Select_Run_cycle" Type="RLL">
<Description>
<![CDATA[Copy selected
cycle parameters
when Run Mode]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Move selected cycle to help variable
Change batch number screen]]>
</Comment>
<Text>
<![CDATA[NE(HMI.Select_run_cycle,0)XIO(Process.Running)MOVE(HMI.Select_run_cycle,Process.Cycle_number);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Copy selected cycle parameters]]>
</Comment>
<Text>
<![CDATA[GT(HMI.Select_run_cycle,0)[TON(Select_delay,?,?) COP(Cycle[HMI.Select_run_cycle],Run,1) ,XIO(Option.Double_door) MOVE(3,Run.Interlock_type) ,XIC(Select_delay.DN) [CLR(HMI.Select_run_cycle) ,RES(Select_delay) ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
<Program Name="Controller_fault" TestEdits="false" MainRoutineName="Fault_Main" Disabled="false" UseAsFolder="false">
<Description>
<![CDATA[CPU fault control]]>
</Description>
<Tags/>
<Routines>
<Routine Name="Fault_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Get fault data from controller]]>
</Comment>
<Text>
<![CDATA[GSV(Program,THIS,MAJORFAULTRECORD,CPU_Fault.Time_low);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Store major error type and code numbers]]>
</Comment>
<Text>
<![CDATA[MOVE(CPU_Fault.Type,CPU.Major_type)MOVE(CPU_Fault.Code,CPU.Major_code)COP(time_date,CPU.Major_time,1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Clear active fault from CPU]]>
</Comment>
<Text>
<![CDATA[CLR(CPU_Fault.Type)CLR(CPU_Fault.Code)SSV(Program,THIS,MAJORFAULTRECORD,CPU_Fault.Time_low);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Generate alarm trigger]]>
</Comment>
<Text>
<![CDATA[OTL(CPU_Fault.Alarm_help);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
