</Routine>
<Routine Name="Separate_domain_username" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[If user belongs to domain, separate domain name and user name]]>
</Comment>
<Text>
<![CDATA[CLR(Find_result)FIND(User_name_full,Find_delimiter,1,Find_result)[EQ(Find_result,0) [GT(User_name_full.LEN,16) MID(User_name_full,16,1,User_name) ,LE(User_name_full.LEN,16) COP(User_name_full,User_name,1) ] ,GT(Find_result,0) [SUB(User_name_full.LEN,Find_result,Username_length) ADD(Find_result,1,Find_result) [GT(Username_length,16) MID(User_name_full,16,Find_result,User_name) ,LE(Username_length,16) MID(User_name_full,Username_length,Find_result,User_name) ] ,SUB(Find_result,2,Find_result) [GT(Find_result,17) MID(User_name_full,16,1,User_name_domain) ,LE(Find_result,17) MID(User_name_full,Find_result,1,User_name_domain) ] ] ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
