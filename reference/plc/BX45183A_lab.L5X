<Description>
<![CDATA[Copy parameters for last cycle data]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Copy parameters to last cycle data memory]]>
</Comment>
<Text>
<![CDATA[SBR()[COP(PRT_Buffer[BufferIX],LastCycle[BufferIX],1) ,RET() ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="RealToStringCValidPress" Type="RLL">
<Description>
<![CDATA[Make Real value print text]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[This subroutine adds decimal point for value string
Move dinteger value to help string when Psia is selected]]>
</Comment>
<Text>
<![CDATA[SBR(prm_real)[XIC(Option.Press_unit) MUL(prm_real,0.145,prm_dint) ,XIO(Option.Press_unit) ]DTOS(prm_dint,prm_string);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Move dinteger value for help string and add spaces when kPa selected]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Press_unit)EQ(type,2)DIV(prm_real,10,prm_dint)DTOS(prm_dint,prm_string)[LIMIT(0,prm_dint,9) INSERT(prm_string,Help_char[10],2,prm_string) ,LIMIT(10,prm_dint,99) INSERT(prm_string,Help_char[7],3,prm_string) ,LIMIT(100,prm_dint,999) INSERT(prm_string,Help_char[9],4,prm_string) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Add decimal point and spaces to help string]]>
</Comment>
<Text>
<![CDATA[[LE(prm_dint,-999) COP(Help_char[14],prm_string,1) ,LIMIT(-999,prm_dint,-100) INSERT(prm_string,Help_char[1],4,prm_string) ,LIMIT(-99,prm_dint,-10) INSERT(prm_string,Help_char[1],3,prm_string) ,LIMIT(-9,prm_dint,-1) INSERT(prm_string,Help_char[2],2,prm_string) ,LIMIT(0,prm_dint,9) INSERT(prm_string,Help_char[2],1,prm_string) INSERT(prm_string,Help_char[9],4,prm_string) ,LIMIT(10,prm_dint,99) INSERT(prm_string,Help_char[1],2,prm_string) INSERT(prm_string,Help_char[9],4,prm_string) ,LIMIT(100,prm_dint,999) INSERT(prm_string,Help_char[1],3,prm_string) INSERT(prm_string,Help_char[3],5,prm_string) ,LIMIT(1000,prm_dint,9999) INSERT(prm_string,Help_char[1],4,prm_string) ,RET() ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Real_to_String" Type="RLL">
<Description>
<![CDATA[Make Real value print text
 1=Temp 2=Press]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[This subroutine adds decimal point for value string
Move dinteger value to help string when Psia is selected]]>
</Comment>
<Text>
<![CDATA[SBR(type,Prm_text,prm_real)EQ(type,2)[XIO(Meas) CONCAT(Prm_text,Press_unit,Prm_text) ,XIC(Option.Press_unit) MUL(prm_real,0.145,prm_dint) DTOS(prm_dint,prm_string) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Move dinteger value for help string and add spaces when kPa selected]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Press_unit)EQ(type,2)DIV(prm_real,10,prm_dint)DTOS(prm_dint,prm_string)[LIMIT(0,prm_dint,9) INSERT(prm_string,Help_char[10],2,prm_string) ,LIMIT(10,prm_dint,99) INSERT(prm_string,Help_char[7],3,prm_string) ,LIMIT(100,prm_dint,999) INSERT(prm_string,Help_char[9],4,prm_string) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Add kPa string to print buffer]]>
</Comment>
<Text>
<![CDATA[XIO(Option.Press_unit)EQ(type,2)[XIO(Meas) CONCAT(Prm_text,prm_string,PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ,XIC(Meas) CONCAT(meas_text,prm_string,meas_text) ,RET() ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Move value for DINT if temperature convert is active]]>
</Comment>
<Text>
<![CDATA[EQ(type,1)[XIO(FIT_print_2decimal) MUL(prm_real,10,prm_dint) DTOS(prm_dint,prm_string) ,XIC(FIT_print_2decimal) MUL(prm_real,100,prm_dint) DTOS(prm_dint,prm_string) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Add decimal point and spaces to help string]]>
</Comment>
<Text>
<![CDATA[XIO(FIT_print_2decimal)[LE(prm_dint,-999) COP(Help_char[14],prm_string,1) ,LIMIT(-999,prm_dint,-100) INSERT(prm_string,Help_char[1],4,prm_string) ,LIMIT(-99,prm_dint,-10) INSERT(prm_string,Help_char[1],3,prm_string) ,LIMIT(-9,prm_dint,-1) INSERT(prm_string,Help_char[2],2,prm_string) ,LIMIT(0,prm_dint,9) INSERT(prm_string,Help_char[2],1,prm_string) INSERT(prm_string,Help_char[9],4,prm_string) ,LIMIT(10,prm_dint,99) INSERT(prm_string,Help_char[1],2,prm_string) INSERT(prm_string,Help_char[9],4,prm_string) ,LIMIT(100,prm_dint,999) INSERT(prm_string,Help_char[1],3,prm_string) INSERT(prm_string,Help_char[3],5,prm_string) ,LIMIT(1000,prm_dint,9999) INSERT(prm_string,Help_char[1],4,prm_string) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Add decimal point and spaces to help string]]>
</Comment>
<Text>
<![CDATA[XIC(FIT_print_2decimal)[LE(prm_dint,-10) COP(Help_char[14],prm_string,1) ,LIMIT(-9.99999,prm_dint,-1.0) INSERT(prm_string,Help_char[1],3,prm_string) ,LIMIT(-0.99999,prm_dint,-0.1) INSERT(prm_string,Help_char[1],2,prm_string) ,LIMIT(-0.09999,prm_dint,-0.01) INSERT(prm_string,Help_char[2],2,prm_string) ,LIMIT(0.0,prm_real,0.09999) INSERT(prm_string,Help_char[11],1,prm_string) ,LIMIT(0.1,prm_real,0.99999) INSERT(prm_string,Help_char[2],1,prm_string) ,LIMIT(1.0,prm_real,9.99999) INSERT(prm_string,Help_char[1],2,prm_string) ,LIMIT(10.0,prm_real,99.99999) INSERT(prm_string,Help_char[1],3,prm_string) ,LIMIT(100.0,prm_real,1000.0) INSERT(prm_string,Help_char[1],4,prm_string) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Add string to print buffer]]>
</Comment>
<Text>
<![CDATA[[XIO(Meas) XIO(FIT_printing) CONCAT(Prm_text,prm_string,PRT_Buffer[ROW_NR]) ADD(ROW_NR,1,ROW_NR) ,XIC(Meas) XIO(FIT_printing) CONCAT(meas_text,prm_string,meas_text) CONCAT(meas_text,Prm_text,meas_text) ,XIC(FIT_printing) CONCAT(Prm_text,prm_string,LastCycle[S_Pointer]) LT(S_Pointer,2499) ADD(S_Pointer,1,S_Pointer) ,RET() ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
