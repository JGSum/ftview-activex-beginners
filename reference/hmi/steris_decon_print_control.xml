                <![CDATA[Public filetxt As String
Public line As String

Private Sub Display_AnimationStart()
On Error GoTo ErrorHandler
    Dim objFSO, strFolder
    
    
    'If folder does not exist, then create it
    strFolder = "C:\Data\"
    Set objFSO = CreateObject("Scripting.FileSystemObject")
    If Not objFSO.FolderExists(strFolder) Then
       objFSO.CreateFolder (strFolder)
    End If

    filetxt = "C:\Data\Reprint.txt"
    
    If Not objFSO.FileExists(filetxt) Then
       Open filetxt For Output As #1
       Close #1
    End If
    
Exit Sub
ErrorHandler:
    LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: Display_AnimationStart(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
    Resume Next
End Sub

Private Sub NumericDisplay_PrintingAct_Change()
On Error GoTo ErrorHandler
    If NumericDisplay_PrintingAct.Value = 0 Then
    
        'Wait for 5 seconds to make sure HMI client has loaded completely before continuing printing
        Dim PauseTime, Start, Finish, TotalTime
        PauseTime = 5    ' Set duration.
        Start = Timer    ' Set start time.
        Do While Timer < Start + PauseTime
            DoEvents    ' Yield to other processes.
        Loop
        
        ExecuteCommand "Set {[Steris_Decon]PrintingACT} 1"
    End If
    
Exit Sub
ErrorHandler:
    LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: NumericDisplay_PrintingAct_Change(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
    Resume Next
End Sub

Private Sub NumericDisplay_Trigger_Change()
On Error GoTo ErrorHandler
    If (NumericDisplay_CycleRunning.Value = 1) And (NumericDisplay_PrintingAct.Value = 1) Then
        If NumericDisplay_Trigger.Value = 1 Then
            line = StringDisplay_PrtString.Value
            Open filetxt For Append As #1
            Print #1, "" & line 'add line to txt file
            Close #1
            ExecuteCommand "Set {::[Steris_Decon]Program:Printing.PrintingDone} 1"
        End If
    End If
    
Exit Sub
ErrorHandler:
    LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: NumericDisplay_Trigger_Change(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
    Resume Next
End Sub
]]>
