                <![CDATA[Dim xlApp As Object
Dim WithEvents ogroup As TagGroup
Attribute ogroup.VB_VarHelpID = -1
Public PrintTagGroup As TagGroup
Public Filename As String
Public filepath As String

Private WithEvents HMIAppCli As DisplayClient.Application    'app events used to update real time status
Attribute HMIAppCli.VB_VarHelpID = -1

Private Sub Display_AnimationStart()

    Dim Pass As Long
    Dim PauseTime, Start
    
On Error GoTo ErrorHandler

    If PrintingInactiveDisplay.Value = 1 Then
        Dim objFSO, strFolder
        strFolder = "C:\Data\Reports\"
        
        Set objFSO = CreateObject("Scripting.FileSystemObject")
        If Not objFSO.FolderExists(strFolder) Then
           objFSO.CreateFolder (strFolder)          'Create report folder if it does not exist
        End If
        
        Set HMIAppCli = Me.Application
        
        ListBox1.Clear
        Text1.Visible = False
        Text3.Visible = True
        
        If PrintTagGroup Is Nothing Then
            Set PrintTagGroup = Application.CreateTagGroup(Me.AreaName)
            
            PrintTagGroup.Add "{[Steris_Decon]Date_time[0]}"
            PrintTagGroup.Add "{[Steris_Decon]Date_time[1]}"
            PrintTagGroup.Add "{[Steris_Decon]Date_time[2]}"
            PrintTagGroup.Add "{[Steris_Decon]Date_time[3]}"
            PrintTagGroup.Add "{[Steris_Decon]Date_time[4]}"
            PrintTagGroup.Add "{[Steris_Decon]Date_time[5]}"
            PrintTagGroup.Add "{[Steris_Decon]User_name}"
            PrintTagGroup.Add "{[Steris_Decon]Printer_enabled}"
        End If
        
        FillListbox
        
        ExecuteCommand "Set {Steris_Decon\ESignLoadedNS} 1"
        Text1.Visible = True
    End If
    
    Exit Sub
    
ErrorHandler:
    Select Case Err.Number
        Case &H80040F80
            PauseTime = 1    ' Set duration.
            Start = Timer    ' Set start time.
            Do While Timer < Start + PauseTime
                DoEvents    ' Yield to other processes.
            Loop
            ' need to handle situation where there is an actual fault preventing a tag read, therefore
            ' used variable Pass to allow a number of failures (in this case 5) before handling as
            ' true failure
            If Pass > 5 Then
                LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: Display_AnimationStart(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
                Set PrintTagGroup = Nothing
                Resume Next
            Else
                Pass = Pass + 1
                Resume    'returns to line that failed and tries again
            End If
        Case Else
            LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: Display_AnimationStart(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
            Set PrintTagGroup = Nothing
            Resume Next
    End Select
End Sub


Private Sub FillListbox()

On Error GoTo ErrorHandler

    Dim DataLine As String
    Dim FilenameReprint As String
    FilenameReprint = "C:\Data\Reprint.txt"
    
    'Open the file and read each line
    Open FilenameReprint For Input As #1
    While Not EOF(1)
        Line Input #1, DataLine ' read in data 1 line at a time
        ListBox1.AddItem DataLine
    Wend
    Close #1
    
    Text3.Visible = False
    Exit Sub
    
ErrorHandler:
    LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: FillListbox(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
    Resume Next
End Sub


Private Sub PrintLastCycle(action As Boolean, user As String)
'Append e-signature and checksum to batch report file. Print the file, and copy to batch reports folder.
    
    Dim Pass As Long
    Dim PauseTime, Start
    
On Error GoTo ErrorHandler
    Dim xlApp As Object
    Set xlApp = CreateObject("WScript.shell")
    Dim year As String
    Dim month As String
    Dim day As String
    Dim hour As String
    Dim minute As String
    Dim second As String
    Dim actionTime As String
    Dim filepath_batch As String
    Dim PrinterEnabled As Boolean
    
    PrinterEnabled = PrintTagGroup.Item("{[Steris_Decon]Printer_enabled}").Value
    
    'Get current time for e-signature from PLC
    year = CStr(PrintTagGroup.Item("{[Steris_Decon]Date_time[0]}").Value)
    month = CStr(PrintTagGroup.Item("{[Steris_Decon]Date_time[1]}").Value)
    day = CStr(PrintTagGroup.Item("{[Steris_Decon]Date_time[2]}").Value)
    hour = CStr(PrintTagGroup.Item("{[Steris_Decon]Date_time[3]}").Value)
    minute = CStr(PrintTagGroup.Item("{[Steris_Decon]Date_time[4]}").Value)
    second = CStr(PrintTagGroup.Item("{[Steris_Decon]Date_time[5]}").Value)
    
    'Add zero in front of date/time members if value is less than 10 to make the file names consistent. (YYYYMMdd_HHmmss format)
    If Len(month) = 1 Then
        month = "0" & month
    End If
    If Len(day) = 1 Then
        day = "0" & day
    End If
    If Len(hour) = 1 Then
        hour = "0" & hour
    End If
    If Len(minute) = 1 Then
        minute = "0" & minute
    End If
    If Len(second) = 1 Then
        second = "0" & second
    End If
    
    actionTime = hour & ":" & minute & ":" & second
    
    Filename = "DC_Batch_" & year & month & day & "_" & hour & minute & second & ".txt"
    filepath = "C:\Data\reprint.txt"
    filepath_batch = "C:\Data\Reports\" & Filename
    
    'Fill batch file
    Open filepath For Append As #1
        'Print electronic signature
        Print #1, ""
        Print #1, "ELECTRONIC SIGNATURE"
        If action = True Then
            Print #1, actionTime & " ACCEPTED BY: " & PrintTagGroup.Item("{[Steris_Decon]User_name}").Value
        ElseIf action = False Then
            Print #1, actionTime & " REJECTED BY: " & PrintTagGroup.Item("{[Steris_Decon]User_name}").Value
        End If
    Close #1
    PutChecksum (filepath) 'Add checksum at the end of the file
    FileCopy filepath, filepath_batch
    FileCopy filepath, "C:\Data\Reprint_last_cycle.txt"
    
    'Print batch file
    If PrinterEnabled Then
        xlApp.Run ("notepad /p " & filepath_batch)
    End If
    'Print batch file to PDF
    xlApp.Run ("notepad /PT """ & filepath_batch & """ ""PDFCreator""")
    
    'Empty reprint.txt for next cycle
    Open filepath For Output As #1
    Close #1
Exit Sub
    
ErrorHandler:
    Select Case Err.Number
        Case &H80040F80
            PauseTime = 1    ' Set duration.
            Start = Timer    ' Set start time.
            Do While Timer < Start + PauseTime
                DoEvents    ' Yield to other processes.
            Loop
            ' need to handle situation where there is an actual fault preventing a tag read, therefore
            ' used variable Pass to allow a number of failures (in this case 5) before handling as
            ' true failure
            If Pass > 5 Then
                LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: PrintLastCycle(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
                Set PrintTagGroup = Nothing
                Resume Next
            Else
                Pass = Pass + 1
                Resume    'returns to line that failed and tries again
            End If
        Case Else
            LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: PrintLastCycle(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError
            Set PrintTagGroup = Nothing
            Resume Next
    End Select
End Sub


Private Sub PutChecksum(Filename As String)
' This function calculates a checksum for a file by using Fletcher-16 algorithm
On Error GoTo ErrorHandler

Dim strDataLine, strFileName As String, lStrLen, lSum1, lSum2, lChecksum, lCRC, lSeed As Long, i As Integer
    strFileName = Filename
    lSum1 = 255
    lSum2 = 255
    lChecksum = 0
    Open strFileName For Input As #1
        While Not EOF(1)
            Line Input #1, strDataLine                          ' read data 1 line at a time
            lStrLen = Len(strDataLine)
            For i = 1 To lStrLen
                lSum1 = (lSum1 + Asc(strDataLine)) Mod 255
                lSum2 = (lSum2 + lSum1) Mod 255
                strDataLine = Right(strDataLine, lStrLen - i)
            Next
        Wend
    Close #1
    lChecksum = (lSum2 * (2 ^ 8)) Or lSum1                      ' Shift lSum2 left by 8 bits and combine with lSum1
    
    Open strFileName For Append As #1
    Print #1, "Checksum: " & lChecksum                               ' Write Fletcher-16 checksum at the end of the file
    Close #1
Exit Sub

ErrorHandler:
    LogDiagnosticsMessage "Error creating checksum", ftDiagSeverityError, ftDiagAudienceEngineer
    LogDiagnosticsMessage "VBA Error - Screen Name: " & Me.FullName & ", Procedure Name: PutChecksum(): " & Hex(Err.Number) & " - " & Err.Description, ftDiagSeverityError

End Sub


Private Sub Display_BeforeAnimationStop()
    'Destroy tag group
    Set PrintTagGroup = Nothing
End Sub

Private Sub ListBox1_Click()

End Sub

Private Sub PrintingInactiveDisplay_Change()
    If PrintingInactiveDisplay.Value = 1 Then
        Display_AnimationStart
    End If
End Sub


Private Sub ESignRejected_Change()
    If ESignRejected.Value = 1 Then
        Dim action As Boolean
        Dim PerformerUser As String
        PerformerUser = "NULL"
        action = False
        PrintLastCycle action, PerformerUser
        ExecuteCommand "Display Steris_Decon_cyclestatus_main /M1"
    End If
End Sub


Private Sub ESignAccepted_Change()
    If ESignAccepted.Value = 1 Then
        Dim action As Boolean
        Dim PerformerUser As String
        PerformerUser = "NULL"
        action = True
        PrintLastCycle action, PerformerUser
        ExecuteCommand "Display Steris_Decon_cyclestatus_main /M1"
    End If
End Sub
